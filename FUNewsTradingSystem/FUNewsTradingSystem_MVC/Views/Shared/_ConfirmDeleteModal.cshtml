<div class="modal fade"
     id="confirmDeleteModal"
     tabindex="-1"
     aria-labelledby="confirmDeleteModalLabel"
     aria-hidden="true">

    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="confirmDeleteModalLabel">
                    Confirm Delete
                </h5>

                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal"
                        aria-label="Close">
                </button>
            </div>

            <div class="modal-body">

                <p class="mb-0">
                    Are you sure you want to delete
                    <strong id="deleteEntityName"></strong>?
                </p>

            </div>

            <div class="modal-footer">

                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>

                <form id="confirmDeleteForm"
                      method="post">

                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="btn btn-danger">
                        Confirm Delete
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>

<script>
    function openDeleteModal(entityName, deleteUrl) {

        document.getElementById("deleteEntityName").innerText = entityName;

        document.getElementById("confirmDeleteForm").action = deleteUrl;

        const modal = new bootstrap.Modal(
            document.getElementById("confirmDeleteModal")
        );

        modal.show();
    }
</script>