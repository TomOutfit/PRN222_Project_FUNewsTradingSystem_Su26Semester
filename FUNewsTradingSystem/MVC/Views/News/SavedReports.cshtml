@model IEnumerable<FUNewsTradingSystem_MVC.ViewModels.Report.SavedReportViewModel>

@{
    ViewData["Title"] = "My Saved Reports";
}

<div class="container px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">
                <i class="bi bi-bookmark-fill me-2" style="background:linear-gradient(135deg,#10b981,#0284c7);-webkit-background-clip:text;-webkit-text-fill-color:transparent"></i>
                My Saved Reports
            </h2>
            <p class="text-muted mb-0">Reports you have bookmarked for later reference</p>
        </div>
        <a asp-controller="Report" asp-action="Index" class="btn fintech-btn-outline btn-sm rounded-pill px-3">
            <i class="bi bi-newspaper me-1"></i> Browse All Reports
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="fintech-card p-5 text-center" style="border-radius: 16px;">
            <i class="bi bi-bookmark text-muted" style="font-size: 3rem; opacity: 0.4;"></i>
            <h5 class="mt-3 text-muted">No saved reports yet</h5>
            <p class="text-muted mb-4" style="font-size: 0.9rem;">
                Browse the report list and click the <i class="bi bi-bookmark"></i> button to save reports here.
            </p>
            <a asp-controller="Report" asp-action="Index" class="btn fintech-btn-primary px-4">
                <i class="bi bi-newspaper me-1"></i> Browse Reports
            </a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var saved in Model)
            {
                var decisionClass = saved.Article.Decision switch
                {
                    "BUY" => "fintech-badge-buy",
                    "SELL" => "fintech-badge-sell",
                    _ => "fintech-badge-hold"
                };
                var decisionIcon = saved.Article.Decision switch
                {
                    "BUY" => "bi-graph-up-arrow",
                    "SELL" => "bi-graph-down-arrow",
                    _ => "bi-dash-circle-fill"
                };

                <div class="col-12" id="saved-item-@saved.SavedReportID">
                    <div class="fintech-card p-4" style="border-radius: 16px; border: 1px solid var(--border); transition: all 0.2s;">
                        <div class="d-flex justify-content-between align-items-start gap-3">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
                                    <span class="badge @decisionClass px-2 py-1 fw-bold" style="font-size: 0.72rem; letter-spacing: .03em;">
                                        <i class="bi @decisionIcon me-1"></i>@saved.Article.Decision
                                    </span>
                                    <span class="text-muted" style="font-size: 0.78rem;">
                                        <i class="bi bi-folder2 me-1"></i>@saved.Article.CategoryName
                                    </span>
                                    @foreach (var tag in saved.Article.TagNames.Take(3))
                                    {
                                        <span class="badge" style="background: rgba(56,189,248,0.15); color: var(--accent); font-size: 0.72rem;">#@tag</span>
                                    }
                                    @if (saved.Article.ConfidenceScore > 0)
                                    {
                                        <span class="text-muted" style="font-size: 0.72rem;">
                                            <i class="bi bi-shield-check me-1"></i>@saved.Article.ConfidenceScore% AI Confidence
                                        </span>
                                    }
                                </div>

                                <h5 class="mb-1 fw-semibold text-main" style="font-size: 1rem; line-height: 1.4;">
                                    <a asp-controller="Report" asp-action="Detail" asp-route-id="@saved.Article.NewsArticleId"
                                       class="text-decoration-none text-main stretched-link-title">
                                        @saved.Article.NewsTitle
                                    </a>
                                </h5>

                                <p class="text-muted mb-0" style="font-size: 0.82rem; line-height: 1.5;">
                                    @saved.Article.Headline
                                </p>
                            </div>

                            <div class="d-flex flex-column align-items-end gap-2 flex-shrink-0">
                                <span class="text-muted" style="font-size: 0.72rem; white-space: nowrap;">
                                    <i class="bi bi-bookmark-fill text-success me-1"></i>
                                    Saved @saved.SavedDate.ToString("MMM dd, yyyy")
                                </span>
                                <span class="text-muted" style="font-size: 0.72rem; white-space: nowrap;">
                                    <i class="bi bi-calendar3 me-1"></i>
                                    Published @saved.Article.CreatedDate.ToString("MMM dd, yyyy")
                                </span>
                                <div class="d-flex gap-2 mt-1">
                                    <a asp-controller="Report" asp-action="Detail" asp-route-id="@saved.Article.NewsArticleId"
                                       class="btn fintech-btn-outline btn-sm px-3" style="font-size: 0.78rem;">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                    <button class="btn btn-sm btn-outline-danger px-3"
                                            style="font-size: 0.78rem; border-radius: 8px;"
                                            onclick="removeBookmark(@saved.Article.NewsArticleId, @saved.SavedReportID)">
                                        <i class="bi bi-bookmark-x me-1"></i>Remove
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function removeBookmark(articleId, savedItemId) {
            var token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!token) return;

            fetch('/News/RemoveBookmark/' + articleId, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token.value,
                    'Content-Type': 'application/json'
                }
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    var el = document.getElementById('saved-item-' + savedItemId);
                    if (el) {
                        el.style.opacity = '0';
                        el.style.transform = 'translateY(-10px)';
                        el.style.transition = 'all 0.3s ease';
                        setTimeout(function () { el.remove(); }, 300);
                    }
                }
            })
            .catch(function () {
                console.error('Failed to remove bookmark');
            });
        }
    </script>
}
