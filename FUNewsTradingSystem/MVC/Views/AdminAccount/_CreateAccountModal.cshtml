@model FUNewsTradingSystem_MVC.ViewModels.Accounts.CreateAccountViewModel

<form id="createAccountForm" novalidate>
    @Html.AntiForgeryToken()
    <div id="createErrors" class="alert alert-danger d-none"></div>

    <div class="mb-3">
        <label asp-for="AccountName" class="form-label fw-semibold"></label>
        <input asp-for="AccountName" class="form-control" placeholder="Enter full name" />
        <span asp-validation-for="AccountName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AccountEmail" class="form-label fw-semibold"></label>
        <input asp-for="AccountEmail" class="form-control" type="email" placeholder="Enter email address" />
        <span asp-validation-for="AccountEmail" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AccountPassword" class="form-label fw-semibold">Password</label>
        <input asp-for="AccountPassword" class="form-control" type="password" placeholder="Enter password" />
        <span asp-validation-for="AccountPassword" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AccountRole" class="form-label fw-semibold"></label>
        <select asp-for="AccountRole" class="form-select">
            <option value="1">Staff</option>
            <option value="2">Lecturer</option>
        </select>
        <span asp-validation-for="AccountRole" class="text-danger small"></span>
    </div>
</form>
