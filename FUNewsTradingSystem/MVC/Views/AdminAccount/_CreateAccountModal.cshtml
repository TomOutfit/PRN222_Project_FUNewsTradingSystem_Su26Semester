@model FUNewsTradingSystem_MVC.ViewModels.Accounts.CreateAccountViewModel

<div class="modal fade" id="createAccountModal" tabindex="-1" aria-labelledby="createAccountModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createAccountModalLabel">Create New Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="createAccountForm" novalidate>
                    @Html.AntiForgeryToken()
                    <div id="createErrors" class="alert alert-danger d-none"></div>

                    <div class="mb-3">
                        <label asp-for="AccountName" class="form-label"></label>
                        <input asp-for="AccountName" class="form-control" />
                        <span asp-validation-for="AccountName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AccountEmail" class="form-label"></label>
                        <input asp-for="AccountEmail" class="form-control" type="email" />
                        <span asp-validation-for="AccountEmail" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AccountPassword" class="form-label">Password</label>
                        <input asp-for="AccountPassword" class="form-control" type="password" />
                        <span asp-validation-for="AccountPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AccountRole" class="form-label"></label>
                        <select asp-for="AccountRole" class="form-select">
                            <option value="1">Staff</option>
                            <option value="2">Lecturer</option>
                        </select>
                        <span asp-validation-for="AccountRole" class="text-danger"></span>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitCreateForm()">Save Account</button>
            </div>
        </div>
    </div>
</div>
