@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col">
            <h2>Welcome to Admin Dashboard</h2>
            <p class="text-muted">Manage system accounts and view statistical reports.</p>
        </div>
    </div>

    <div class="row g-4">
        <!-- Account Management Card -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-people-fill text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="card-title">Account Management</h4>
                    <p class="card-text flex-grow-1 text-muted">
                        Create, update, and manage Staff and Lecturer accounts. Delete inactive users to maintain security.
                    </p>
                    <a href="/Admin/Accounts" class="btn btn-outline-primary mt-3">
                        Manage Accounts
                    </a>
                </div>
            </div>
        </div>

        <!-- Statistical Report Card -->
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-bar-chart-fill text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="card-title">Statistical Reports</h4>
                    <p class="card-text flex-grow-1 text-muted">
                        View comprehensive reports on AI-generated trading analyses. Filter by date ranges.
                    </p>
                    <a href="/Admin/Statistics" class="btn btn-outline-success mt-3">
                        View Reports
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
