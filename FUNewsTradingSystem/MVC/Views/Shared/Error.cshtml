@model ErrorViewModel
@using Microsoft.AspNetCore.Hosting
@inject IWebHostEnvironment Env
@{
    ViewData["Title"] = "System Error";

    // Đọc mã trạng thái lỗi từ ViewData nếu có (do hệ thống hoặc Controller truyền sang)
    var statusCode = ViewData["StatusCode"]?.ToString() ?? "Error";
    var friendlyMessage = ViewData["Message"]?.ToString() ?? "An unexpected error occurred while processing your request.";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            @* Icon cảnh báo lỗi trực quan *@
            <div class="mb-4">
                <i class="bi bi-exclamation-circle-fill text-danger" style="font-size: 5rem;"></i>
            </div>

            @* Hiển thị Mã lỗi lớn (Ví dụ: 404, 500) *@
            <h1 class="display-1 fw-bold text-danger mb-2">@statusCode</h1>

            @* Thông báo lỗi thân thiện với người dùng *@
            <h3 class="h4 text-secondary mb-4">@friendlyMessage</h3>

            @* Hiển thị Request ID để phục vụ việc tra cứu Log hệ thống nếu có lỗi phát sinh *@
            @if (Model?.ShowRequestId == true)
            {
                <div class="card bg-light border-0 mb-4 py-2">
                    <div class="card-body p-2">
                        <span class="text-muted small">
                            <i class="bi bi-bug me-1"></i>Request ID: <code class="text-dark fw-medium">@Model.RequestId</code>
                        </span>
                    </div>
                </div>
            }

            @* Cảnh báo môi trường Development (Thu gọn, tinh tế hơn code mặc định) *@
            @if (Env.IsDevelopment())
            {
                <div class="alert alert-warning text-start border-0 shadow-sm mb-4" role="alert">
                    <h5 class="alert-heading fw-semibold"><i class="bi bi-cone-striped me-2"></i>Development Mode Hint</h5>
                    <p class="mb-0 small text-muted">
                        Detailed exception tracking is active in local development. For deployed applications, ensure the
                        <code>ASPNETCORE_ENVIRONMENT</code> environment variable is set to <code>Production</code> to prevent exposing sensitive internal data.
                    </p>
                </div>
            }

            @* Các nút bấm điều hướng lối thoát cho người dùng *@
            <div class="d-flex justify-content-center gap-2">
                <a asp-controller="Report" asp-action="Index" class="btn btn-primary px-4 shadow-sm">
                    <i class="bi bi-house-door me-2"></i>Go to Reports
                </a>
                <button onclick="window.history.back()" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-arrow-left me-2"></i>Go Back
                </button>
            </div>
        </div>
    </div>
</div>