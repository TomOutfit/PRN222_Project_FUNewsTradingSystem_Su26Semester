<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FUNewsTradingSystem</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    FNTS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @* 1. GUEST HOẶC LECTURER (ROLE 2) -> CHỈ XEM REPORTS *@
                        @if (!User.Identity?.IsAuthenticated == true || User.IsInRole("2"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                                   asp-controller="Report" asp-action="Index">Reports</a>
                            </li>
                        }

                        @* THÀNH VIÊN ĐÃ ĐĂNG NHẬP *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @* 2. STAFF NAVIGATION (ROLE 1) *@
                            @if (User.IsInRole("1"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RunAnalysis" ? "active" : "")"
                                       asp-controller="RunAnalysis" asp-action="Index">Run Analysis</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                                       asp-controller="Category" asp-action="Index">Categories</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tag" ? "active" : "")"
                                       asp-controller="Tag" asp-action="Index">Tags</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")"
                                       asp-controller="Report" asp-action="History">My Reports</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")"
                                       asp-controller="Account" asp-action="Profile">Profile</a>
                                </li>
                            }

                            @* 3. ADMIN NAVIGATION (ROLE 3) *@
                            @if (User.IsInRole("3"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                                       asp-controller="Admin" asp-action="Index">Accounts</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" && ViewContext.RouteData.Values["action"]?.ToString() == "StatisticalReport" ? "active" : "")"
                                       asp-controller="Admin" asp-action="StatisticalReport">Statistics</a>
                                </li>
                            }
                        }
                    </ul>

                    @* KHU VỰC ĐĂNG NHẬP / ĐĂNG XUẤT PHÍA BÊN PHẢI NAVBAR *@
                    <div class="d-flex align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="navbar-text me-3 text-secondary">
                                Hello, <strong>@User.Identity.Name</strong>
                                <span class="badge bg-light text-dark border">
                                    @(User.IsInRole("3") ? "Admin" : User.IsInRole("1") ? "Staff" : "Lecturer")
                                </span>
                            </span>

                            @* Bắt buộc sử dụng FORM POST + AntiForgeryToken cho nút Logout *@
                            <form class="form-inline" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm fw-medium">Logout</button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm fw-medium px-3" asp-controller="Account" asp-action="Login">Login</a>
                        }
                    </div>

                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3 bg-light">
        <div class="container text-center text-sm-start">
            &copy; 2026 — FUNewsTradingSystem (Automated AI Trading Analysis)
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Render section Scripts đúng chuẩn không bắt buộc ở cuối trang *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>