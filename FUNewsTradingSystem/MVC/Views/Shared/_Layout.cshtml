<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FNTS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <style>
        @@keyframes pulse-green {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
        .pulse-dot {
            width: 8px; height: 8px;
            background-color: #10b981;
            border-radius: 50%;
            display: inline-block;
            animation: pulse-green 2s infinite;
        }
        
        /* ── Header Animations ── */
        @@keyframes slideHeaderDown {
            from {
                transform: translateY(-100%);
                opacity: 0;
            }
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
        
        header {
            animation: slideHeaderDown 0.65s cubic-bezier(0.16, 1, 0.3, 1) both;
            transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s ease;
            will-change: transform;
        }
        .header-hidden {
            transform: translateY(-100%);
        }
        
        /* ── Glowing gradient line below header ── */
        .header-glow-line {
            height: 2px;
            background: linear-gradient(90deg, #6d28d9, #10b981, #db2777, #6d28d9);
            background-size: 300% 100%;
            animation: gradientShift 8s linear infinite;
            width: 100%;
            position: absolute;
            bottom: 0;
            left: 0;
            opacity: 0.8;
        }
        
        @@keyframes gradientShift {
            0% { background-position: 0% 50%; }
            100% { background-position: 300% 50%; }
        }
        
        /* Interactive clock icon hover effect */
        .clock-widget:hover i {
            transform: rotate(15deg) scale(1.1);
        }
        .clock-widget i {
            transition: transform 0.3s ease;
        }

        /* ── CẤU TRÚC KỊCH BẢN CHUYỂN TRANG MỚI (CYBER SLIDE WIPE) ── */
        body {
            overflow-x: hidden;
        }
        
        /* Wrapper bao bọc toàn bộ nội dung để tạo hiệu ứng thu nhỏ (Scale) */
        #page-wrapper {
            transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s ease;
            will-change: transform, opacity;
            opacity: 1;
        }
        .page-scale-down {
            transform: scale(0.96);
            opacity: 0.4;
        }

        /* Thanh quét dữ liệu khi chuyển trang */
        #cyber-wipe-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 99999;
            pointer-events: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Lớp nền quét chính */
        .wipe-block {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #1e1b4b 0%, #0f172a 100%);
            transform: translateX(-100%);
            will-change: transform;
        }

        /* Hiệu ứng quét khi RỜI TRANG (Animate Out) */
        .wipe-out .wipe-block {
            animation: wipeToRight 0.55s cubic-bezier(0.76, 0, 0.24, 1) forwards;
        }

        /* Hiệu ứng quét khi VÀO TRANG MỚI (Animate In) */
        .wipe-in .wipe-block {
            transform: translateX(0);
            animation: wipeLeaveRight 0.55s cubic-bezier(0.76, 0, 0.24, 1) forwards;
        }

        /* Container cho logo và status */
        .wipe-content {
            position: relative;
            z-index: 99999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transform: scale(0.95);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }
        
        .wipe-out .wipe-content {
            opacity: 1;
            transform: scale(1);
            transition-delay: 0.15s;
        }

        .wipe-in .wipe-content {
            opacity: 1;
            transform: scale(1);
        }

        .transition-logo {
            width: 90px;
            height: 90px;
            object-fit: contain;
            border-radius: 20px;
            box-shadow: 0 0 25px rgba(16, 185, 129, 0.3), 0 0 50px rgba(109, 40, 217, 0.2);
            border: 2px solid rgba(16, 185, 129, 0.4);
            background: #0d0b1e;
            padding: 6px;
        }

        /* Khối text Terminal nhỏ chạy theo dải quét */
        .wipe-status {
            color: #10b981;
            font-family: 'Inter', monospace;
            font-size: 0.85rem;
            font-weight: 700;
            letter-spacing: 2px;
            padding: 8px 16px;
            border-left: 3px solid #6d28d9;
            background: rgba(0,0,0,0.3);
        }

        @@keyframes wipeToRight {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(0); }
        }

        @@keyframes wipeLeaveRight {
            0% { transform: translateX(0); }
            100% { transform: translateX(100%); }
        }

        .spin {
            animation: spinIcon 1.5s linear infinite;
            display: inline-block;
        }
        @@keyframes spinIcon {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        /* Đường Loading Bar tối giản siêu mảnh ở top */
        .page-loading-bar {
            position: fixed;
            top: 0;
            left: 0;
            height: 2px;
            background: #10b981;
            box-shadow: 0 0 8px #10b981;
            z-index: 100000;
            width: 0;
            transition: width 0.4s ease, opacity 0.3s ease;
            pointer-events: none;
        }

        /* ── CUSTOM CRUD TOASTS ── */
        .custom-toast-container {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 99999;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .custom-crud-toast {
            display: flex;
            align-items: flex-start;
            padding: 14px 16px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            min-width: 320px;
            max-width: 420px;
            animation: slideInToast 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
            position: relative;
            overflow: hidden;
            font-family: 'Inter', sans-serif;
        }
        .custom-crud-toast.hiding {
            animation: slideOutToast 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .custom-crud-toast.type-create {
            background-color: #e0f7fa; /* Light blue */
            border-left: 4px solid #0284c7;
        }
        .custom-crud-toast.type-update {
            background-color: #f3e8ff; /* Light purple */
            border-left: 4px solid #9333ea;
        }
        .custom-crud-toast.type-delete {
            background-color: #ffe4e6; /* Light red */
            border-left: 4px solid #e11d48;
        }
        
        .custom-toast-icon {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            margin-right: 14px;
            flex-shrink: 0;
            margin-top: 2px;
            color: white;
            font-size: 14px;
        }
        .type-create .custom-toast-icon { background-color: #0284c7; }
        .type-update .custom-toast-icon { background-color: #9333ea; }
        .type-delete .custom-toast-icon { background-color: #e11d48; }

        .custom-toast-content {
            flex-grow: 1;
        }
        .custom-toast-title {
            font-weight: 700;
            font-size: 0.95rem;
            margin-bottom: 3px;
        }
        .type-create .custom-toast-title { color: #0369a1; }
        .type-update .custom-toast-title { color: #7e22ce; }
        .type-delete .custom-toast-title { color: #be123c; }

        .custom-toast-message {
            font-size: 0.85rem;
            color: #475569;
            line-height: 1.4;
        }
        
        .custom-toast-close {
            background: none;
            border: none;
            color: #6b7280;
            cursor: pointer;
            font-size: 1.5rem;
            line-height: 0.8;
            padding: 0;
            margin-left: 10px;
        }
        .custom-toast-close:hover {
            color: #374151;
        }

        @@keyframes slideInToast {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        @@keyframes slideOutToast {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(120%); opacity: 0; }
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <div id="page-loading-bar" class="page-loading-bar"></div>

    <div id="cyber-wipe-overlay" class="wipe-in">
        <div class="wipe-block"></div>
        <div class="wipe-content">
            <img src="/images/fnts_transition_logo.png" alt="FNTS" class="transition-logo animate-pulse mb-3" />
            <div class="wipe-status text-uppercase">
                <i class="bi bi-cpu-fill me-2 spin"></i>Waiting for Loading...
            </div>
        </div>
    </div>

    <div id="page-wrapper" class="d-flex flex-column min-vh-100 w-100">
        <header class="sticky-top position-relative">
            <nav class="navbar navbar-expand-sm">
                <div class="container-fluid px-4">

                    <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="/images/fnts_transition_logo.png" alt="FNTS Logo" style="height:32px;width:auto;object-fit:contain;" />
                        <span class="ms-2 fw-bold" style="font-size:1.05rem;letter-spacing:.04em">FNTS</span>
                        <span class="d-none d-md-inline text-muted fs-6 fw-normal border-start border-secondary border-opacity-30 ps-2 ms-2">Consumer Finance & Business Portal</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                            data-bs-target=".navbar-collapse" aria-controls="navbarContent"
                            aria-expanded="false" aria-label="Toggle navigation">
                        <i class="bi bi-list text-secondary-emphasis fs-4"></i>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1 gap-1">
                            @* GUEST / LECTURER (ROLE 2) *@
                            @if (!User.Identity?.IsAuthenticated == true || User.IsInRole("2"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                                       asp-controller="Report" asp-action="Index">
                                        <i class="bi bi-newspaper me-1"></i>Reports
                                    </a>
                                </li>
                            }

                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @* STAFF (ROLE 1) *@
                                @if (User.IsInRole("1"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RunAnalysis" ? "active" : "")"
                                           asp-controller="RunAnalysis" asp-action="Index">
                                            <i class="bi bi-cpu me-1"></i>Run Analysis
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                                           asp-controller="Category" asp-action="Index">
                                            <i class="bi bi-folder2 me-1"></i>Categories
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tag" ? "active" : "")"
                                           asp-controller="Tag" asp-action="Index">
                                            <i class="bi bi-tags me-1"></i>Tags
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" && ViewContext.RouteData.Values["action"]?.ToString() == "MyReports" ? "active" : "")"
                                           asp-controller="Staff" asp-action="MyReports">
                                            <i class="bi bi-journal-text me-1"></i>My Reports
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "News" && ViewContext.RouteData.Values["action"]?.ToString() == "SavedReports" ? "active" : "")"
                                           asp-controller="News" asp-action="SavedReports">
                                            <i class="bi bi-bookmark-fill me-1"></i>Saved Reports
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")"
                                           asp-controller="Staff" asp-action="Profile">
                                            <i class="bi bi-person-circle me-1"></i>Profile
                                        </a>
                                    </li>
                                }

                                @* LECTURER (ROLE 2) *@
                                @if (User.IsInRole("2"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "News" && ViewContext.RouteData.Values["action"]?.ToString() == "SavedReports" ? "active" : "")"
                                           asp-controller="News" asp-action="SavedReports">
                                            <i class="bi bi-bookmark-fill me-1"></i>Saved Reports
                                        </a>
                                    </li>
                                }

                                @* ADMIN (ROLE 3) *@
                                @if (User.IsInRole("3"))
                                {
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminAccount" && ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")"
                                           asp-controller="AdminAccount" asp-action="Dashboard">
                                            <i class="bi bi-grid-1x2-fill me-1"></i>Dashboard
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminAccount" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                                           asp-controller="AdminAccount" asp-action="Index">
                                            <i class="bi bi-people-fill me-1"></i>Accounts
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminStatistics" ? "active" : "")"
                                           asp-controller="AdminStatistics" asp-action="Index">
                                            <i class="bi bi-bar-chart-line-fill me-1"></i>Statistics
                                        </a>
                                    </li>
                                }
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-2">
                            <div class="d-flex align-items-center gap-1 px-2.5 py-1 rounded bg-body-tertiary border border-secondary border-opacity-10 text-secondary-emphasis small clock-widget" style="font-size: .8rem; font-weight: 600;" title="Current local time">
                                <i class="bi bi-clock me-1 text-primary"></i>
                                <span id="headerClock" style="font-family: monospace;">00:00:00 AM</span>
                            </div>

                            <div class="d-flex align-items-center gap-1 me-2 px-2 py-1 rounded bg-body-tertiary border border-secondary border-opacity-10 text-success small" style="font-size: .8rem; font-weight: 600;">
                                <span class="pulse-dot me-1"></span>
                                <span id="presenceCount">1</span> Active
                            </div>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <span class="navbar-text d-none d-md-inline">
                                    Hello, <strong>@User.Identity.Name</strong>
                                    <span class="badge @(User.IsInRole("3") ? "bg-danger" : User.IsInRole("1") ? "bg-primary" : "bg-secondary") ms-1">
                                        @(User.IsInRole("3") ? "Admin" : User.IsInRole("1") ? "Staff" : "Lecturer")
                                    </span>
                                </span>

                                <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="mb-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a class="btn btn-primary btn-sm px-3" asp-controller="Account" asp-action="Login">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>Login
                                </a>
                            }

                            <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1"
                                    id="themeToggle" type="button" aria-label="Toggle theme">
                                <span id="themeIcon">🌙</span>
                                <span class="d-none d-sm-inline" style="font-size:.75rem">Theme</span>
                            </button>
                        </div>
                    </div>
                </div>
            </nav>
            <div class="header-glow-line"></div>
        </header>

        <div class="container flex-grow-1">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="footer mt-auto py-5">
            <div class="container">
                <div class="row g-4 text-start">
                    <!-- Branding & Description -->
                    <div class="col-12 col-md-4">
                        <h5 class="fw-bold mb-3 d-flex align-items-center gap-2">
                            <img src="/images/fnts_transition_logo.png" alt="FNTS Logo" style="height:24px;width:auto;object-fit:contain;" />
                            <span class="gradient-text">FNTS</span>
                        </h5>
                        <p class="text-white-50 mb-3" style="max-width: 340px; font-size: 0.85rem; line-height: 1.6; font-weight:bold; color: #fff;">
                            FNTS Consumer Finance Platform delivers real-time AI-powered sentiment analysis, news correlations, and business performance metrics, allowing investors and educators to trace target stock and index trends.
                        </p>
                        <!-- Social/Platform Links -->
                        <div class="d-flex gap-2 flex-wrap">
                            <a href="#" class="btn btn-sm btn-outline-light rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;padding:0;" title="Twitter/X">
                                <i class="bi bi-twitter-x"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-outline-light rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;padding:0;" title="GitHub">
                                <i class="bi bi-github"></i>
                            </a>
                            <a href="#" class="btn btn-sm btn-outline-light rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;padding:0;" title="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>
                        </div>
                        <p class="small text-secondary mb-0 mt-3" style="font-size: 0.75rem; font-weight:bold; color:white;">
                            &copy; @DateTime.Now.Year FU NEWS TRADING SYSTEM. All rights reserved.
                        </p>
                    </div>

                    <!-- Consumer Services -->
                    <div class="col-6 col-md-2">
                        <h6 class="text-uppercase fw-bold text-white small mb-3 tracking-wider">Consumer Services</h6>
                        <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                            <li>
                                <a asp-controller="Home" asp-action="About" class="text-white-50 text-decoration-none footer-link">
                                    <i class="bi bi-chevron-right small me-1"></i>About Us
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="FAQ" class="text-white-50 text-decoration-none footer-link">
                                    <i class="bi bi-chevron-right small me-1"></i>FAQ
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="Contact" class="text-white-50 text-decoration-none footer-link">
                                    <i class="bi bi-chevron-right small me-1"></i>Contact Support
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Report" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                                    <i class="bi bi-chevron-right small me-1"></i>Analysis Reports
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Business Portal -->
                    <div class="col-6 col-md-2">
                        <h6 class="text-uppercase fw-bold text-white small mb-3 tracking-wider">Business Portal</h6>
                        <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                @if (User.IsInRole("1"))
                                {
                                    <li>
                                        <a asp-controller="RunAnalysis" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                                            <i class="bi bi-chevron-right small me-1"></i>Run Analysis
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Staff" asp-action="MyReports" class="text-white-50 text-decoration-none footer-link">
                                            <i class="bi bi-chevron-right small me-1"></i>My Reports
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Category" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                                            <i class="bi bi-chevron-right small me-1"></i>Categories
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="Tag" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                                            <i class="bi bi-chevron-right small me-1"></i>Tags
                                        </a>
                                    </li>
                                }
                                else if (User.IsInRole("3"))
                                {
                                    <li>
                                        <a asp-controller="AdminAccount" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                                            <i class="bi bi-chevron-right small me-1"></i>Manage Accounts
                                        </a>
                                    </li>
                                    <li>
                                        <a asp-controller="AdminStatistics" asp-action="Index" class="text-white-50 text-decoration-none footer-link">
                                            <i class="bi bi-chevron-right small me-1"></i>View Statistics
                                        </a>
                                    </li>
                                }
                            }
                            else
                            {
                                <li>
                                    <a asp-controller="Account" asp-action="Login" class="text-white-50 text-decoration-none footer-link">
                                        <i class="bi bi-chevron-right small me-1"></i>Login to Portal
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>

                    <!-- Compliance & Legal -->
                    <div class="col-6 col-md-2">
                        <h6 class="text-uppercase fw-bold text-white small mb-3 tracking-wider">Compliance & Legal</h6>
                        <ul class="list-unstyled d-flex flex-column gap-2 mb-0">
                            <li>
                                <a asp-controller="Home" asp-action="Terms" class="text-white-50 text-decoration-none footer-link">
                                    <i class="bi bi-chevron-right small me-1"></i>Terms of Service
                                </a>
                            </li>
                            <li>
                                <a asp-controller="Home" asp-action="Privacy" class="text-white-50 text-decoration-none footer-link">
                                    <i class="bi bi-chevron-right small me-1"></i>Privacy Policy
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Disclaimer -->
                    <div class="col-12 col-md-2">
                        <h6 class="text-uppercase fw-bold text-white small mb-3 tracking-wider">Disclaimer</h6>
                        <p class="text-muted mb-0" style="font-size: 0.78rem; line-height: 1.5; text-align:left; font-weight:bold; color: #fff">
                            Trading assets involves substantial risk. Synthesized reports, sentiment triggers, and decision signals generated by this system are for educational and informational purposes only. Do not treat any signals as financial advice.
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </div> <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function syncModalsToBody() {
            // Remove closed duplicate modals from body before appending new ones to prevent backdrop multiplication bugs
            $('body > .modal:not(.show)').remove();
            // Append new modals to body
            $('.modal').each(function() {
                if (this.parentNode !== document.body) {
                    document.body.appendChild(this);
                }
            });
        }

        $(document).ready(function () {
            syncModalsToBody();
        });
    </script>

    <script>
        (function () {
            const getStored  = () => localStorage.getItem('theme');
            const setStored  = t  => localStorage.setItem('theme', t);
            const preferred  = () => getStored() || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

            const apply = t => {
                document.documentElement.setAttribute('data-bs-theme', t);
                const icon = document.getElementById('themeIcon');
                if (icon) icon.textContent = t === 'dark' ? '☀️' : '🌙';
            };

            apply(preferred());

            document.getElementById('themeToggle')?.addEventListener('click', () => {
                const cur  = document.documentElement.getAttribute('data-bs-theme');
                const next = cur === 'dark' ? 'light' : 'dark';
                setStored(next);
                apply(next);
            });

            // Sticky & shrink transitions for header on scroll
            window.addEventListener('scroll', () => {
                const currentScrollY = window.scrollY;
                const nav = document.querySelector('.navbar');

                if (currentScrollY > 30) {
                    nav.classList.add('navbar-scrolled');
                } else {
                    nav.classList.remove('navbar-scrolled');
                }
            });

            // Real-time ticking Clock
            function updateClock() {
                const clockEl = document.getElementById("headerClock");
                if (clockEl) {
                    const now = new Date();
                    clockEl.textContent = now.toLocaleTimeString();
                }
            }
            updateClock();
            setInterval(updateClock, 1000);

            // ── ĐỔI MỚI: Javascript điều khiển hiệu ứng Cyber Wipe
            const overlay = document.getElementById('cyber-wipe-overlay');
            const loadBar = document.getElementById('page-loading-bar');
            const wrapper = document.getElementById('page-wrapper');

            // Khi vừa tải trang: Dải quét chạy lướt qua để lộ trang mới (wipe-in)
            if (loadBar) loadBar.style.width = '60%';

            window.addEventListener('load', () => {
                if (loadBar) {
                    loadBar.style.width = '100%';
                    setTimeout(() => { loadBar.style.opacity = '0'; }, 200);
                }
                
                // Sau khi dải quét lướt qua bên phải, dọn dẹp class để không chặn tương tác
                setTimeout(() => {
                    if (overlay) overlay.className = ''; 
                }, 550);
            });

            // Bắt sự kiện click chuyển link để thực hiện hiệu ứng Outbound độc đáo
            document.addEventListener('click', (e) => {
                const link = e.target.closest('a');
                if (!link) return;

                const href = link.getAttribute('href');
                const target = link.getAttribute('target');

                if (!href || href.startsWith('#') || href.startsWith('javascript:') || target === '_blank') {
                    return;
                }

                if (link.hostname !== window.location.hostname) {
                    return;
                }

                if (link.closest('form') || link.classList.contains('no-transition')) {
                    return;
                }

                e.preventDefault();

                // Kích hoạt thanh quét sang phải che màn hình + thu nhỏ nhẹ trang cũ
                if (loadBar) {
                    loadBar.style.opacity = '1';
                    loadBar.style.width = '100%';
                }
                if (wrapper) {
                    wrapper.classList.add('page-scale-down');
                }
                if (overlay) {
                    overlay.className = 'wipe-out';
                }

                // Chuyển hướng sau khi hiệu ứng quét phủ toàn bộ màn hình hoàn tất
                setTimeout(() => {
                    window.location.href = href;
                }, 500); 
            });
        })();
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function() {
            var presenceConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/presence")
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            presenceConnection.on("UpdateOnlineCount", function (count) {
                var el = document.getElementById("presenceCount");
                if (el) el.textContent = count;
            });

            presenceConnection.start().catch(function (err) {
                console.error("PresenceHub connection failed: ", err);
            });

            // Notification Hub Connection
            var notificationConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notifications")
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            window.refreshPageContentRealtime = function() {
                const mainContent = document.querySelector('main[role="main"]');
                if (mainContent) {
                    fetch(window.location.href)
                        .then(res => res.text())
                        .then(html => {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const newMain = doc.querySelector('main[role="main"]');
                            if (newMain) {
                                mainContent.innerHTML = newMain.innerHTML;
                                if (typeof syncModalsToBody === 'function') {
                                    syncModalsToBody();
                                }
                            }
                        })
                        .catch(err => console.error("Realtime main content refresh failed:", err));
                }
            };

            window.showCustomToast = function (action, title, message) {
                let container = document.getElementById("customToastContainer");
                if (!container) {
                    container = document.createElement("div");
                    container.id = "customToastContainer";
                    container.className = "custom-toast-container";
                    document.body.appendChild(container);
                }

                let iconClass = "bi-check-lg";
                let typeClass = "type-create";
                
                if (action === "update" || action === "info") {
                    iconClass = "bi-pencil-square";
                    typeClass = "type-update";
                } else if (action === "delete" || action === "error") {
                    iconClass = action === "error" ? "bi-exclamation-triangle-fill" : "bi-trash-fill";
                    typeClass = "type-delete";
                }

                const toast = document.createElement("div");
                toast.className = `custom-crud-toast ${typeClass}`;
                toast.innerHTML = `
                    <div class="custom-toast-icon">
                        <i class="bi ${iconClass}"></i>
                    </div>
                    <div class="custom-toast-content">
                        <div class="custom-toast-title">${title}</div>
                        <div class="custom-toast-message">${message}</div>
                    </div>
                    <button class="custom-toast-close" aria-label="Close">&times;</button>
                `;

                const closeBtn = toast.querySelector(".custom-toast-close");
                closeBtn.onclick = function() {
                    toast.classList.add("hiding");
                    setTimeout(() => toast.remove(), 400);
                };

                container.appendChild(toast);

                setTimeout(() => {
                    if (document.body.contains(toast)) {
                        toast.classList.add("hiding");
                        setTimeout(() => toast.remove(), 400);
                    }
                }, 5000);
            };

            notificationConnection.on("ReceiveCRUDNotification", function (action, title, message) {
                if (typeof window.showCustomToast === 'function') {
                    window.showCustomToast(action, title, message);
                }

                // Auto-refresh main content area in real-time
                if (typeof window.refreshPageContentRealtime === 'function') {
                    window.refreshPageContentRealtime();
                }
            });

            notificationConnection.start().catch(function (err) {
                console.error("NotificationHub connection failed: ", err);
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>