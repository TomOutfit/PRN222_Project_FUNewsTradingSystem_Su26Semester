<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — FNTS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <header>
        <nav class="navbar navbar-expand-sm">
            <div class="container-fluid px-4">

                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    📈 FNTS
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="bi bi-list text-white fs-4"></i>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">

                        @* GUEST / LECTURER (ROLE 2) → only Reports *@
                        @if (!User.Identity?.IsAuthenticated == true || User.IsInRole("2"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                                   asp-controller="Report" asp-action="Index">
                                    <i class="bi bi-newspaper me-1"></i>Reports
                                </a>
                            </li>
                        }

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @* STAFF (ROLE 1) *@
                            @if (User.IsInRole("1"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "RunAnalysis" ? "active" : "")"
                                       asp-controller="RunAnalysis" asp-action="Index">
                                        <i class="bi bi-cpu me-1"></i>Run Analysis
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                                       asp-controller="Category" asp-action="Index">
                                        <i class="bi bi-folder2 me-1"></i>Categories
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tag" ? "active" : "")"
                                       asp-controller="Tag" asp-action="Index">
                                        <i class="bi bi-tags me-1"></i>Tags
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" && ViewContext.RouteData.Values["action"]?.ToString() == "MyReports" ? "active" : "")"
                                       asp-controller="Staff" asp-action="MyReports">
                                        <i class="bi bi-journal-text me-1"></i>My Reports
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" && ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")"
                                       asp-controller="Staff" asp-action="Profile">
                                        <i class="bi bi-person-circle me-1"></i>Profile
                                    </a>
                                </li>
                            }

                            @* ADMIN (ROLE 3) *@
                            @if (User.IsInRole("3"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminAccount" ? "active" : "")"
                                       asp-controller="AdminAccount" asp-action="Index">
                                        <i class="bi bi-people me-1"></i>Accounts
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminStatistics" ? "active" : "")"
                                       asp-controller="AdminStatistics" asp-action="Index">
                                        <i class="bi bi-bar-chart-line me-1"></i>Statistics
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <span class="navbar-text d-none d-md-inline">
                                Hello, <strong>@User.Identity.Name</strong>
                                <span class="badge @(User.IsInRole("3") ? "bg-danger" : User.IsInRole("1") ? "bg-primary" : "bg-secondary") ms-1">
                                    @(User.IsInRole("3") ? "Admin" : User.IsInRole("1") ? "Staff" : "Lecturer")
                                </span>
                            </span>

                            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="mb-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary btn-sm px-3" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login
                            </a>
                        }

                        <button class="btn btn-outline-secondary btn-sm d-flex align-items-center gap-1"
                                id="themeToggle" type="button" aria-label="Toggle theme">
                            <span id="themeIcon">🌙</span>
                            <span class="d-none d-sm-inline" style="font-size:.75rem">Theme</span>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container text-center" style="font-size:.8125rem">
            &copy; @DateTime.Now.Year — <span class="gradient-text fw-semibold">FUNewsTradingSystem</span> · AI Trading Analysis
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        (function () {
            const getStored  = () => localStorage.getItem('theme');
            const setStored  = t  => localStorage.setItem('theme', t);
            const preferred  = () => getStored() || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

            const apply = t => {
                document.documentElement.setAttribute('data-bs-theme', t);
                const icon = document.getElementById('themeIcon');
                if (icon) icon.textContent = t === 'dark' ? '☀️' : '🌙';
            };

            apply(preferred());

            document.getElementById('themeToggle')?.addEventListener('click', () => {
                const cur  = document.documentElement.getAttribute('data-bs-theme');
                const next = cur === 'dark' ? 'light' : 'dark';
                setStored(next);
                apply(next);
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>