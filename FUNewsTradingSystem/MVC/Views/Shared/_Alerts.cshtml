@*
    Reusable alert partial for success / error / warning / info alerts.
    Usage:
    <partial name="_Alerts"
             model='new { Type = "success", Message = "Saved!" }' />
*@

@model dynamic

@{
    var type = Model?.Type?.ToString()?.ToLowerInvariant();

    var alertClass = type switch
    {
        "success" => "alert-success",
        "danger" or "error" => "alert-danger",
        "warning" => "alert-warning",
        "info" => "alert-info",
        _ => "alert-secondary"
    };
}

<div class="alert @alertClass alert-dismissible fade show" role="alert">
    @Model?.Message

    <button type="button"
            class="btn-close"
            data-bs-dismiss="alert"
            aria-label="Close">
    </button>
</div>