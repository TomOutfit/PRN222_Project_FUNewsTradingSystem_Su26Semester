@model FUNewsTradingSystem_MVC.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In — FUNewsTradingSystem";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sign in to FUNewsTradingSystem — AI-powered market news & trading analysis." />
    <title>@ViewData["Title"]</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>

    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-secondary-fixed": "#002113",
                        "surface-container-lowest": "#ffffff",
                        "inverse-on-surface": "#eff1f3",
                        "surface-variant": "#e0e3e5",
                        "surface-dim": "#d8dadc",
                        "on-secondary-fixed-variant": "#005236",
                        "primary-fixed-dim": "#bec6e0",
                        "tertiary": "#000000",
                        "tertiary-container": "#0d1c2f",
                        "surface-bright": "#f7f9fb",
                        "tertiary-fixed-dim": "#b9c7e0",
                        "error-container": "#ffdad6",
                        "surface-tint": "#565e74",
                        "on-surface": "#191c1e",
                        "secondary-fixed-dim": "#4edea3",
                        "tertiary-fixed": "#d5e3fd",
                        "outline-variant": "#c6c6cd",
                        "on-primary-fixed": "#131b2e",
                        "on-tertiary-fixed": "#0d1c2f",
                        "error": "#ba1a1a",
                        "inverse-surface": "#2d3133",
                        "primary-fixed": "#dae2fd",
                        "on-secondary": "#ffffff",
                        "on-tertiary-container": "#76859b",
                        "inverse-primary": "#bec6e0",
                        "surface-container-highest": "#e0e3e5",
                        "surface-container-high": "#e6e8ea",
                        "on-tertiary": "#ffffff",
                        "on-surface-variant": "#45464d",
                        "on-tertiary-fixed-variant": "#3a485c",
                        "surface-container-low": "#f2f4f6",
                        "outline": "#76777d",
                        "background": "#f7f9fb",
                        "secondary-container": "#6cf8bb",
                        "surface-container": "#eceef0",
                        "on-primary-container": "#7c839b",
                        "on-error": "#ffffff",
                        "secondary": "#006c49",
                        "on-primary-fixed-variant": "#3f465c",
                        "secondary-fixed": "#6ffbbe",
                        "primary-container": "#131b2e",
                        "on-secondary-container": "#00714d",
                        "on-primary": "#ffffff",
                        "primary": "#000000",
                        "on-error-container": "#93000a",
                        "surface": "#f7f9fb",
                        "on-background": "#191c1e"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "gutter": "24px",
                        "margin-mobile": "16px",
                        "margin-desktop": "40px",
                        "base": "8px",
                        "container-max": "1440px"
                    },
                    "fontFamily": {
                        "display-lg": ["Inter"],
                        "body-sm": ["Inter"],
                        "body-lg": ["Inter"],
                        "title-md": ["Inter"],
                        "headline-lg": ["Inter"],
                        "label-caps": ["Inter"],
                        "headline-lg-mobile": ["Inter"],
                        "data-mono": ["Inter"]
                    },
                    "fontSize": {
                        "display-lg": ["48px", { "lineHeight": "56px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-sm": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "body-lg": ["16px", { "lineHeight": "26px", "fontWeight": "400" }],
                        "title-md": ["18px", { "lineHeight": "24px", "fontWeight": "600" }],
                        "headline-lg": ["32px", { "lineHeight": "40px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "label-caps": ["12px", { "lineHeight": "16px", "letterSpacing": "0.05em", "fontWeight": "700" }],
                        "headline-lg-mobile": ["24px", { "lineHeight": "32px", "fontWeight": "600" }],
                        "data-mono": ["14px", { "lineHeight": "20px", "letterSpacing": "-0.01em", "fontWeight": "500" }]
                    }
                }
            }
        }
    </script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f7f9fb;
        }
        [data-bs-theme="dark"] body {
            background-color: #0f0f1a;
        }
        
        /* ── Entry Keyframes ── */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(24px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        @@keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(45px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        @@keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-45px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        @@keyframes panZoom {
            0% { transform: scale(1); }
            100% { transform: scale(1.12) translate(-1%, -1%); }
        }
        @@keyframes shakeIn {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-6px); }
            40%       { transform: translateX(6px); }
            60%       { transform: translateX(-4px); }
            80%       { transform: translateX(4px); }
        }

        .animate-fade-in {
            animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        .animate-fade-in-up {
            animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        .animate-slide-in-right {
            animation: slideInRight 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
        }
        .animate-slide-in-left {
            animation: slideInLeft 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        .delay-1 { animation-delay: 0.12s; }
        .delay-2 { animation-delay: 0.22s; }
        .delay-3 { animation-delay: 0.32s; }
        .delay-4 { animation-delay: 0.42s; }
        .delay-5 { animation-delay: 0.52s; }
    </style>
</head>
<body class="h-screen w-full flex overflow-hidden bg-background dark:bg-surface text-on-surface">

    <!-- Left Side: Hero / Brand Area -->
    <div class="hidden lg:flex lg:w-1/2 relative bg-primary-container text-on-primary overflow-hidden">
        <!-- Background Image with Overlay -->
        <div class="absolute inset-0">
            <img alt="FNTS Global Trading Network" class="w-full h-full object-cover animate-[panZoom_25s_ease_infinite_alternate]" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBGxyMW8k8-uJQR66A7s_mG7wJrXh3jLpeBF1CdWkSTgHjKV1Q0MFKLgIb3DGky2lvqKLyNcNNrYzPdi81r16XRjycMVpba8vVmQDtFuFe8FN3-SALRixpAw79cuMjf6jSWrwf5YEn1R2ZWOxtlrRrSTLj6M9J4LFAEvyQ0YG-XpYRJLQHuSthe3lqx27YOCiQQ4b838BshPoUoxtSkB7FzRVf31vjR1wFhG6NT7kVSA5bOCCEDQQ15"/>
            <div class="absolute inset-0 bg-primary-container/85 backdrop-blur-sm mix-blend-multiply"></div>
            <!-- Additional gradient for depth -->
            <div class="absolute inset-0 bg-gradient-to-t from-primary-container via-transparent to-transparent opacity-95"></div>
        </div>

        <!-- Canvas for live ticking line chart -->
        <canvas id="hero-chart-canvas" class="absolute inset-0 w-full h-full opacity-50 mix-blend-screen pointer-events-none"></canvas>

        <!-- Content -->
        <div class="relative z-10 p-margin-desktop flex flex-col justify-between h-full w-full animate-slide-in-left">
            <!-- Logo -->
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-secondary-fixed-dim" style="font-size: 32px; font-variation-settings: 'FILL' 1;">
                    monitoring
                </span>
                <span class="font-title-md text-title-md text-on-primary tracking-tight">FNTS</span>
            </div>
            <!-- Value Prop -->
            <div class="max-w-md">
                <h1 class="font-display-lg text-display-lg text-on-primary mb-6">
                    AI-Powered<br/>Financial Insights
                </h1>
                <p class="font-body-lg text-body-lg text-primary-fixed-dim opacity-90">
                    Real-time market news analysis and automated trading signals engineered for high-stakes decision-making.
                </p>
                <!-- Stylized data visualization element -->
                <div class="mt-12 flex gap-4 opacity-75">
                    <div class="flex flex-col gap-1">
                        <div class="h-1 w-8 bg-secondary-fixed-dim rounded-full"></div>
                        <span class="font-label-caps text-label-caps text-primary-fixed-dim uppercase">Latency</span>
                        <span class="font-data-mono text-data-mono text-on-primary">&lt; 5ms</span>
                    </div>
                    <div class="w-px bg-on-primary-fixed-variant mx-4"></div>
                    <div class="flex flex-col gap-1">
                        <div class="h-1 w-12 bg-secondary-fixed-dim rounded-full"></div>
                        <span class="font-label-caps text-label-caps text-primary-fixed-dim uppercase">Sources</span>
                        <span class="font-data-mono text-data-mono text-on-primary">150+ Global</span>
                    </div>
                </div>
            </div>
            <!-- Minimal footer note -->
            <div class="font-body-sm text-body-sm text-primary-fixed-dim opacity-80">
                &copy; @DateTime.Now.Year FU News Trading System. Secure Institutional Access.
            </div>
        </div>
    </div>

    <!-- Right Side: Login Form -->
    <div id="right-panel-wrapper" class="w-full lg:w-1/2 flex items-center justify-center bg-surface-container-lowest dark:bg-inverse-surface/10 p-margin-mobile md:p-margin-desktop relative z-20 shadow-[-4px_0_24px_rgba(0,0,0,0.05)] overflow-y-auto group">
        
        <!-- Interactive Spotlight Glow -->
        <div id="mouse-glow" class="absolute pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-700 w-[450px] h-[450px] rounded-full bg-secondary/[0.04] dark:bg-secondary-fixed-dim/[0.04] blur-[80px]" style="transform: translate(-50%, -50%); top: 0; left: 0;"></div>

        <!-- Theme Toggle & Logo top bar -->
        <div class="absolute top-margin-mobile left-margin-mobile right-margin-mobile flex justify-between items-center z-30 animate-fade-in">
            <!-- Mobile Logo (visible only on small screens) -->
            <div class="flex items-center gap-2 lg:hidden">
                <span class="material-symbols-outlined text-secondary dark:text-secondary-fixed-dim" style="font-size: 24px; font-variation-settings: 'FILL' 1;">
                    monitoring
                </span>
                <span class="font-title-md text-title-md text-on-surface dark:text-white tracking-tight">FNTS</span>
            </div>
            <div class="lg:hidden"></div>
            <!-- Theme Toggle Button -->
            <button class="flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg border border-outline-variant bg-surface-container-low text-on-surface-variant hover:bg-surface-container hover:text-on-surface transition-all cursor-pointer dark:bg-white/5 dark:border-white/10 dark:text-white/70 dark:hover:bg-white/10 dark:hover:text-white active:scale-95 shadow-sm" id="themeToggle" type="button" aria-label="Toggle theme">
                <span id="themeIcon">🌙</span>
                <span>Theme</span>
            </button>
        </div>

        <div class="w-full max-w-[400px] flex flex-col mt-12 lg:mt-0 animate-slide-in-right relative z-10">
            <div class="mb-8 text-center lg:text-left">
                <h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface dark:text-white mb-2">
                    System Access
                </h2>
                <p class="font-body-sm text-body-sm text-on-surface-variant dark:text-white/60">
                    Authenticate to enter the terminal environment.
                </p>
            </div>

            @* Server-side validation alert *@
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="flex items-start gap-2.5 p-3.5 rounded-lg bg-red-50 border border-red-200 text-red-600 dark:bg-red-950/20 dark:border-red-900/50 dark:text-red-400 text-sm mb-5 animate-[shakeIn_0.4s_ease_both]" role="alert" id="validation-summary">
                    <span class="material-symbols-outlined text-red-500 dark:text-red-400" style="font-size: 20px;">error</span>
                    <div asp-validation-summary="ModelOnly" class="font-medium"></div>
                </div>
            }

            <form id="login-form" asp-controller="Account" asp-action="Login" method="post" class="space-y-5" novalidate>
                @Html.AntiForgeryToken()

                @if (ViewData["ReturnUrl"] is string returnUrl && !string.IsNullOrEmpty(returnUrl))
                {
                    <input type="hidden" name="returnUrl" value="@returnUrl" />
                }

                <!-- Email Field (Floating Label & Glow) -->
                <div class="space-y-1.5 animate-fade-in-up delay-1">
                    <div class="relative group/input flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-outline dark:text-white/40 group-focus-within/input:text-secondary dark:group-focus-within/input:text-secondary-fixed-dim transition-colors" style="font-size: 20px;">
                            mail
                        </span>
                        <input asp-for="Email" class="peer block w-full pl-12 pr-10 pt-6 pb-2 border border-outline-variant dark:border-white/10 rounded-xl bg-surface-container-lowest dark:bg-white/5 text-on-surface dark:text-white font-body-sm text-body-sm focus:outline-none focus:ring-2 focus:ring-secondary/15 focus:border-secondary dark:focus:ring-secondary-fixed-dim/20 dark:focus:border-secondary-fixed-dim hover:border-outline dark:hover:border-white/20 transition-all placeholder=" " required="" type="email" autocomplete="email" autofocus/>
                        <label for="Email" class="absolute left-12 top-4 text-on-surface-variant/70 dark:text-white/50 pointer-events-none transition-all duration-300 origin-left transform scale-100 translate-y-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-3 peer-focus:text-secondary dark:peer-focus:text-secondary-fixed-dim font-medium uppercase text-[10px] tracking-wider select-none peer-[:not(:placeholder-shown)]:scale-75 peer-[:not(:placeholder-shown)]:-translate-y-3">
                            Email Address
                        </label>
                        <!-- Active Pulsing Dot Indicator -->
                        <div class="absolute right-4 top-1/2 -translate-y-1/2 flex items-center pointer-events-none opacity-0 group-focus-within/input:opacity-100 transition-opacity duration-300">
                            <span class="relative flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-secondary"></span>
                            </span>
                        </div>
                    </div>
                    <span asp-validation-for="Email" class="text-xs text-red-500 dark:text-red-400 block mt-1 pl-1"></span>
                </div>

                <!-- Password Field (Floating Label & Glow) -->
                <div class="space-y-1.5 animate-fade-in-up delay-2">
                    <div class="flex justify-between items-center px-1">
                        <div class="h-1"></div>
                        <a class="font-body-sm text-body-sm text-secondary dark:text-secondary-fixed-dim hover:underline transition-colors" href="#">
                            Forgot Password?
                        </a>
                    </div>
                    <div class="relative group/input flex items-center">
                        <span class="material-symbols-outlined absolute left-4 text-outline dark:text-white/40 group-focus-within/input:text-secondary dark:group-focus-within/input:text-secondary-fixed-dim transition-colors" style="font-size: 20px;">
                            lock
                        </span>
                        <input asp-for="Password" class="peer block w-full pl-12 pr-12 pt-6 pb-2 border border-outline-variant dark:border-white/10 rounded-xl bg-surface-container-lowest dark:bg-white/5 text-on-surface dark:text-white font-body-sm text-body-sm focus:outline-none focus:ring-2 focus:ring-secondary/15 focus:border-secondary dark:focus:ring-secondary-fixed-dim/20 dark:focus:border-secondary-fixed-dim hover:border-outline dark:hover:border-white/20 transition-all placeholder=" " required="" type="password" autocomplete="current-password"/>
                        <label for="Password" class="absolute left-12 top-4 text-on-surface-variant/70 dark:text-white/50 pointer-events-none transition-all duration-300 origin-left transform scale-100 translate-y-0 peer-placeholder-shown:scale-100 peer-placeholder-shown:translate-y-0 peer-focus:scale-75 peer-focus:-translate-y-3 peer-focus:text-secondary dark:peer-focus:text-secondary-fixed-dim font-medium uppercase text-[10px] tracking-wider select-none peer-[:not(:placeholder-shown)]:scale-75 peer-[:not(:placeholder-shown)]:-translate-y-3">
                            Password
                        </label>
                        <button id="pwToggle" aria-label="Toggle password visibility" class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-outline dark:text-white/40 hover:text-on-surface dark:hover:text-white transition-colors focus:outline-none" type="button">
                            <span id="pwToggleIcon" class="material-symbols-outlined" style="font-size: 20px;">
                                visibility_off
                            </span>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-xs text-red-500 dark:text-red-400 block mt-1 pl-1"></span>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center animate-fade-in-up delay-3 px-1">
