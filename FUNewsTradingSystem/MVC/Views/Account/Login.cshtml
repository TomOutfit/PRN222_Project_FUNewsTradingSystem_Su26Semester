    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        /* ════════ MAIN CHART ════════ */
        (function () {
            const canvas = document.getElementById('main-chart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let W = 0, H = 100;

            function resize() {
                W = canvas.offsetWidth * (window.devicePixelRatio || 1);
                canvas.width = W;
                canvas.height = H * (window.devicePixelRatio || 1);
                ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
            }
            resize();
            window.addEventListener('resize', resize);

            let points = [], base = H * 0.6;
            for (let i = 0; i < 60; i++) {
                base += (Math.random() - 0.48) * 6;
                base = Math.max(H * 0.3, Math.min(H * 0.75, base));
                points.push(base);
            }

            function draw() {
                if (!canvas) return;
                const cw = canvas.offsetWidth, ch = H;
                ctx.clearRect(0, 0, cw, ch);

                const grad = ctx.createLinearGradient(0, 0, 0, ch);
                grad.addColorStop(0, 'rgba(16,185,129,0.25)');
                grad.addColorStop(1, 'rgba(16,185,129,0)');
                ctx.beginPath();
                ctx.moveTo(0, ch);
                points.forEach((p, i) => ctx.lineTo((i / (points.length - 1)) * cw, p));
                ctx.lineTo(cw, ch);
                ctx.closePath();
                ctx.fillStyle = grad;
                ctx.fill();

                ctx.beginPath();
                points.forEach((p, i) => i === 0 ? ctx.moveTo(0, p) : ctx.lineTo((i / (points.length - 1)) * cw, p));
                ctx.strokeStyle = '#10b981';
                ctx.lineWidth = 2;
                ctx.shadowBlur = 8;
                ctx.shadowColor = 'rgba(16,185,129,0.5)';
                ctx.stroke();
                ctx.shadowBlur = 0;

                const lastX = cw - 2, lastY = points[points.length - 1];
                ctx.beginPath();
                ctx.arc(lastX, lastY, 4, 0, Math.PI * 2);
                ctx.fillStyle = '#10b981';
                ctx.shadowBlur = 12;
                ctx.shadowColor = '#10b981';
                ctx.fill();
                ctx.shadowBlur = 0;

                points.shift();
                base += (Math.random() - 0.48) * 5;
                base = Math.max(ch * 0.3, Math.min(ch * 0.75, base));
                points.push(base);

                setTimeout(() => requestAnimationFrame(draw), 120);
            }
            draw();
        })();

        /* ════════ BAR CHART ════════ */
        (function () {
            const canvas = document.getElementById('bar-chart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let W = 0, H = 100;

            function resize() {
                W = canvas.offsetWidth * (window.devicePixelRatio || 1);
                canvas.width = W;
                canvas.height = H * (window.devicePixelRatio || 1);
                ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
            }
            resize();
            window.addEventListener('resize', resize);

            const sectors = ['Tech', 'Fin', 'Ener', 'Hlth', 'Ret', 'Util'];
            const colors  = ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ec4899', '#06b6d4'];
            let values = sectors.map(() => Math.random() * 0.6 + 0.2);

            function draw() {
                if (!canvas) return;
                const cw = canvas.offsetWidth, ch = H;
                ctx.clearRect(0, 0, cw, ch);
                const bw = cw / sectors.length - 4;

                sectors.forEach((s, i) => {
                    const x = i * (bw + 4) + 2;
                    const bh = values[i] * (ch - 8);
                    const y = ch - bh;

                    const grad = ctx.createLinearGradient(x, y, x, ch);
                    grad.addColorStop(0, colors[i] + 'cc');
                    grad.addColorStop(1, colors[i] + '33');

                    ctx.beginPath();
                    ctx.roundRect(x, y, bw, bh, [3, 3, 0, 0]);
                    ctx.fillStyle = grad;
                    ctx.fill();

                    ctx.strokeStyle = colors[i] + '88';
                    ctx.lineWidth = 1;
                    ctx.stroke();

                    values[i] += (Math.random() - 0.48) * 0.07;
                    values[i] = Math.max(0.1, Math.min(0.9, values[i]));
                });

                setTimeout(() => requestAnimationFrame(draw), 800);
            }
            draw();
        })();

        /* ════════ SPOTLIGHT ════════ */
        (function () {
            const panel = document.getElementById('right-panel');
            const spot  = document.getElementById('spotlight');
            if (!panel || !spot) return;
            panel.addEventListener('mousemove', e => {
                const r = panel.getBoundingClientRect();
                spot.style.left = (e.clientX - r.left) + 'px';
                spot.style.top  = (e.clientY - r.top)  + 'px';
            });
        })();

        /* ════════ THEME SWITCHER ════════ */
        (function () {
            const themes = [
                { key: 'dark',  label: 'Dark',  icon: 'dark_mode' },
                { key: 'light', label: 'Light', icon: 'light_mode' },
                { key: 'blue',  label: 'Blue',  icon: 'water_drop' },
            ];
            let idx = 0;

            function applyTheme(i) {
                document.body.className = '';
                if (themes[i].key !== 'dark') document.body.classList.add('theme-' + themes[i].key);
                document.getElementById('themeIcon').textContent  = themes[i].icon;
                document.getElementById('themeLabel').textContent = themes[i].label;
                localStorage.setItem('fnts-theme', i);
            }

            const saved = localStorage.getItem('fnts-theme');
            if (saved !== null) { idx = parseInt(saved); applyTheme(idx); }
            else applyTheme(0);

            document.getElementById('themeSwitcher').addEventListener('click', function () {
                idx = (idx + 1) % themes.length;
                applyTheme(idx);
            });
        })();

        /* ════════ PASSWORD TOGGLE ════════ */
        document.getElementById('pwToggle').addEventListener('click', function () {
            const input = document.getElementById('Password');
            const icon  = document.getElementById('pwIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        });

        /* ════════ VALIDITY INDICATOR ════════ */
        document.querySelectorAll('.fnts-input').forEach(input => {
            input.addEventListener('blur', function () {
                if (this.value && this.checkValidity()) this.classList.add('is-valid');
                else this.classList.remove('is-valid');
            });
        });

        /* ════════ SUBMIT LOADER ════════ */
        document.getElementById('login-form').addEventListener('submit', function (e) {
            if (!$(this).valid()) return;
            const btn      = document.getElementById('login-submit');
            const content  = document.getElementById('btn-content');
            const spinner  = document.getElementById('btn-spinner');
            btn.disabled = true;
            content.classList.add('hidden');
            spinner.classList.add('show');
        });
    </script>
</body>
</html>
