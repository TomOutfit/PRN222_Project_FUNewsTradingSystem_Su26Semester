                <!-- Submit Button -->
                <div class="animate-fade-in-up delay-4">
                    <button type="submit" id="login-submit" class="w-full flex justify-center items-center gap-2 py-3 px-4 border border-transparent rounded-xl shadow-sm font-title-md text-title-md text-on-secondary bg-secondary hover:bg-on-secondary-container dark:bg-secondary dark:hover:bg-secondary/90 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-secondary transition-all hover:scale-[1.01] active:scale-[0.99] cursor-pointer" style="min-height: 52px;">
                        <span id="btn-text" class="flex items-center gap-2">
                            <span class="material-symbols-outlined animate-pulse" style="font-size: 20px;">login</span>
                            Sign In
                        </span>
                        <div class="hidden w-5 h-5 border-2 border-white/40 border-t-white rounded-full animate-spin" id="btn-spinner"></div>
                    </button>
                </div>
            </form>

            <div class="mt-8 pt-6 border-t border-surface-variant dark:border-white/10 text-center animate-fade-in-up delay-5">
                <p class="font-body-sm text-body-sm text-on-surface-variant dark:text-white/60">
                    Need technical assistance? <a class="text-secondary dark:text-secondary-fixed-dim hover:underline underline-offset-2 font-medium" href="#">Contact Support</a>
                </p>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        // ── Canvas Live Ticking Chart
        (function() {
            const canvas = document.getElementById('hero-chart-canvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let width = canvas.width = canvas.offsetWidth;
            let height = canvas.height = canvas.offsetHeight;

            window.addEventListener('resize', () => {
                if (!canvas) return;
                width = canvas.width = canvas.offsetWidth;
                height = canvas.height = canvas.offsetHeight;
            });

            let points = [];
            const maxPoints = 40;
            let lastVal = height * 0.55;

            // Initialize points
            for (let i = 0; i < maxPoints; i++) {
                lastVal += (Math.random() - 0.5) * 15;
                if (lastVal < height * 0.3) lastVal = height * 0.3;
                if (lastVal > height * 0.8) lastVal = height * 0.8;
                points.push(lastVal);
            }

            function draw() {
                if (!canvas) return;
                ctx.clearRect(0, 0, width, height);

                // Draw grid
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.02)';
                ctx.lineWidth = 1;
                const gridSize = 45;
                for (let x = 0; x < width; x += gridSize) {
                    ctx.beginPath();
                    ctx.moveTo(x, 0);
                    ctx.lineTo(x, height);
                    ctx.stroke();
                }
                for (let y = 0; y < height; y += gridSize) {
                    ctx.beginPath();
                    ctx.moveTo(0, y);
                    ctx.lineTo(width, y);
                    ctx.stroke();
                }

                // Update chart values
                points.shift();
                lastVal += (Math.random() - 0.5) * 12;
                if (lastVal < height * 0.35) lastVal = height * 0.35;
                if (lastVal > height * 0.75) lastVal = height * 0.75;
                points.push(lastVal);

                // Draw area under chart
                ctx.beginPath();
                ctx.moveTo(0, height);
                for (let i = 0; i < points.length; i++) {
                    const x = (i / (points.length - 1)) * width;
                    ctx.lineTo(x, points[i]);
                }
                ctx.lineTo(width, height);
                ctx.closePath();
                let areaGrd = ctx.createLinearGradient(0, height * 0.3, 0, height);
                areaGrd.addColorStop(0, 'rgba(16, 185, 129, 0.06)');
                areaGrd.addColorStop(1, 'rgba(16, 185, 129, 0)');
                ctx.fillStyle = areaGrd;
                ctx.fill();

                // Draw line
                ctx.beginPath();
                ctx.moveTo(0, points[0]);
                for (let i = 1; i < points.length; i++) {
                    const x = (i / (points.length - 1)) * width;
                    ctx.lineTo(x, points[i]);
                }
                ctx.strokeStyle = 'rgba(16, 185, 129, 0.3)';
                ctx.lineWidth = 2.5;
                ctx.stroke();

                // Draw glowing point at current price
                const lastX = width;
                const lastY = points[points.length - 1];
                ctx.beginPath();
                ctx.arc(lastX - 2, lastY, 5, 0, Math.PI * 2);
                ctx.fillStyle = '#10b981';
                ctx.fill();
                ctx.beginPath();
                ctx.arc(lastX - 2, lastY, 14, 0, Math.PI * 2);
                ctx.fillStyle = 'rgba(16, 185, 129, 0.2)';
                ctx.fill();

                setTimeout(() => requestAnimationFrame(draw), 100);
            }
            draw();
        })();

        // ── Cursor Spotlight Parallax Effect
        (function () {
            const panel = document.getElementById('right-panel-wrapper');
            const glow = document.getElementById('mouse-glow');
            if (!panel || !glow) return;

            panel.addEventListener('mousemove', function (e) {
                const rect = panel.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                glow.style.left = x + 'px';
                glow.style.top = y + 'px';
                glow.style.opacity = '1';
            });

            panel.addEventListener('mouseleave', function () {
                glow.style.opacity = '0';
            });
        })();

        // ── Password toggle
        document.getElementById('pwToggle').addEventListener('click', function () {
            const input = document.getElementById('Password');
            const icon = document.getElementById('pwToggleIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        });

        // ── Submit loading state
        document.getElementById('login-form').addEventListener('submit', function (e) {
            if (!$(this).valid()) return;

            const btn = document.getElementById('login-submit');
            const text = document.getElementById('btn-text');
            const spinner = document.getElementById('btn-spinner');
            
            btn.disabled = true;
            btn.classList.add('opacity-75', 'cursor-not-allowed');
            text.classList.add('hidden');
            spinner.classList.remove('hidden');
        });

        // ── Theme toggle
        (function () {
            const getStored = () => localStorage.getItem('theme');
            const setStored = t => localStorage.setItem('theme', t);
            const preferred = () => getStored() || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');

            const apply = t => {
                document.documentElement.setAttribute('data-bs-theme', t);
                if (t === 'dark') {
                    document.documentElement.classList.add('dark');
                } else {
                    document.documentElement.classList.remove('dark');
                }
                document.getElementById('themeIcon').textContent = t === 'dark' ? '☀️' : '🌙';
            };

            apply(preferred());

            document.getElementById('themeToggle').addEventListener('click', function () {
                const cur = document.documentElement.getAttribute('data-bs-theme');
                const next = cur === 'dark' ? 'light' : 'dark';
                setStored(next);
                apply(next);
            });
        })();
    </script>
</body>
</html>
