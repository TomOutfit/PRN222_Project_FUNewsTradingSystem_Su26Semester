@model FUNewsTradingSystem_MVC.ViewModels.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In — FUNewsTradingSystem";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sign in to FUNewsTradingSystem — AI-powered market news & trading analysis." />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet"/>

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #070b14;
            --surface:   #0d1424;
            --card:      #111827;
            --border:    rgba(255,255,255,0.08);
            --emerald:   #10b981;
            --emerald2:  #059669;
            --blue:      #3b82f6;
            --red:       #ef4444;
            --amber:     #f59e0b;
            --text:      #f9fafb;
            --muted:     #9ca3af;
            --faint:     #4b5563;
            --glow:      rgba(16,185,129,0.15);
        }

        /* ── Light theme ── */
        body.theme-light {
            --bg:        #f5f6fa;
            --surface:   #ffffff;
            --card:      #f0f1f5;
            --border:    rgba(0,0,0,0.08);
            --emerald:   #059669;
            --emerald2:  #047857;
            --blue:      #2563eb;
            --text:      #111827;
            --muted:     #6b7280;
            --faint:     #9ca3af;
            --glow:      rgba(5,150,105,0.12);
        }

        /* ── Blue theme ── */
        body.theme-blue {
            --bg:        #050a18;
            --surface:   #07122b;
            --card:      #0a1830;
            --border:    rgba(59,130,246,0.12);
            --emerald:   #3b82f6;
            --emerald2:  #2563eb;
            --blue:      #60a5fa;
            --text:      #e0f2fe;
            --muted:     #7dd3fc;
            --faint:     #38bdf8;
            --glow:      rgba(59,130,246,0.15);
        }

        body.theme-blue .form-title .accent,
        body.theme-blue .logo-text {
            background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        body.theme-blue .fnts-input:focus ~ .fnts-label,
        body.theme-blue .fnts-input:not(:placeholder-shown) ~ .fnts-label { color: #3b82f6; }
        body.theme-blue .fnts-input:focus { border-color: #3b82f6; box-shadow: 0 0 0 4px rgba(59,130,246,0.12); background: rgba(59,130,246,0.05); }
        body.theme-blue .submit-btn {
            background: linear-gradient(135deg, #3b82f6 0%, #2563eb 60%, #1d4ed8 100%);
        }
        body.theme-blue .submit-btn:hover { box-shadow: 0 8px 25px rgba(59,130,246,0.3); }
        body.theme-blue .live-badge { background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.25); color: #60a5fa; }
        body.theme-blue .live-dot { background: #3b82f6; }
        body.theme-blue .validity-dot .material-symbols-outlined { color: #3b82f6; }
        body.theme-blue .fnts-input.is-valid { border-color: rgba(59,130,246,0.5); }
        body.theme-blue .chart-card::after { background: linear-gradient(90deg, transparent, rgba(59,130,246,0.5), transparent); }
        body.theme-blue .right-panel::before {
            background-image:
                linear-gradient(rgba(59,130,246,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59,130,246,0.03) 1px, transparent 1px);
        }

        html, body {
            height: 100%;
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            background: var(--bg);
            color: var(--text);
            overflow: hidden;
        }

        /* ── Layout ── */
        .page {
            display: flex;
            height: 100vh;
            width: 100vw;
            overflow: hidden;
        }

        /* ════════════════════════════════════
           LEFT PANEL
           ════════════════════════════════════ */
        .left-panel {
            display: none;
            width: 50%;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            background: var(--bg);
            flex-shrink: 0;
        }
        @@media (min-width: 992px) { .left-panel { display: flex; } }

        /* Ambient glows */
        .left-panel::before {
            content: '';
            position: absolute;
            top: -200px; left: -150px;
            width: 500px; height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 70%);
            pointer-events: none;
            animation: orbFloat 8s ease-in-out infinite;
        }
        .left-panel::after {
            content: '';
            position: absolute;
            bottom: -150px; right: -100px;
            width: 400px; height: 400px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
            pointer-events: none;
            animation: orbFloat 10s ease-in-out infinite reverse;
        }
        @@keyframes orbFloat {
            0%, 100% { transform: translate(0, 0) scale(1); }
            50%       { transform: translate(20px, -20px) scale(1.05); }
        }

        /* Header bar */
        .l-header {
            position: relative;
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 28px 32px 0;
            animation: slideInLeft 0.9s cubic-bezier(0.16,1,0.3,1) both;
        }
        .logo-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .logo-icon {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--emerald), var(--emerald2));
            display: flex; align-items: center; justify-content: center;
            box-shadow: 0 4px 15px rgba(16,185,129,0.35);
        }
        .logo-text {
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            background: linear-gradient(135deg, var(--emerald) 0%, var(--blue) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .logo-version {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: var(--faint);
            margin-left: 2px;
        }
        .live-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 5px 12px;
            border-radius: 999px;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            background: rgba(16,185,129,0.1);
            border: 1px solid rgba(16,185,129,0.25);
            color: var(--emerald);
            animation: fadeIn 1s ease 0.3s both;
        }
        .live-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--emerald);
            animation: pulseDot 1.5s ease-in-out infinite;
        }
        @@keyframes pulseDot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50%       { opacity: 0.5; transform: scale(1.5); }
        }

        /* Ticker tape */
        .ticker-wrap {
            position: relative;
            z-index: 10;
            margin-top: 24px;
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            background: rgba(0,0,0,0.2);
            overflow: hidden;
            animation: fadeIn 1s ease 0.4s both;
        }
        .ticker-inner {
            display: flex;
            width: max-content;
            animation: tickerScroll 40s linear infinite;
        }
        .ticker-wrap:hover .ticker-inner { animation-play-state: paused; }
        @@keyframes tickerScroll {
            0%   { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .ticker-item {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 8px 20px;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            white-space: nowrap;
        }
        .ticker-sym  { color: var(--muted); }
        .ticker-val  { color: var(--text); font-weight: 600; }
        .ticker-up    { color: var(--emerald); }
        .ticker-down  { color: var(--red); }

        /* Main content */
        .l-content {
            position: relative;
            z-index: 10;
            flex: 1;
            padding: 20px 32px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* Hero text */
        .l-hero {
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.5s both;
        }
        .l-hero-eyebrow {
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: #34d399;
            margin-bottom: 10px;
        }
        .l-hero-title {
            font-size: clamp(1.6rem, 3vw, 2.1rem);
            font-weight: 800;
            letter-spacing: -0.03em;
            line-height: 1.15;
            color: var(--text);
            margin-bottom: 12px;
        }
        .l-hero-title .accent {
            background: linear-gradient(135deg, var(--emerald) 0%, var(--blue) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .l-hero-desc {
            font-size: 0.82rem;
            line-height: 1.65;
            color: var(--muted);
            max-width: 420px;
        }

        /* Charts grid */
        .charts-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.6s both;
        }
        .chart-card {
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--border);
            border-radius: 12px;
            overflow: hidden;
            position: relative;
        }
        .chart-card::after {
            content: '';
            position: absolute;
            left: 0; width: 100%; height: 1px;
            background: linear-gradient(90deg, transparent, rgba(16,185,129,0.5), transparent);
            animation: scanLine 4s linear infinite;
            pointer-events: none;
        }
        @@keyframes scanLine {
            0%   { top: 0; }
            100% { top: 100%; }
        }
        .chart-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            padding: 12px 14px 6px;
        }
        .chart-label {
            font-size: 0.65rem;
            font-weight: 600;
            color: var(--text);
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }
        .chart-value {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.05rem;
            font-weight: 700;
            color: var(--text);
            margin-top: 2px;
        }
        .chart-change {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: var(--emerald);
            margin-top: 1px;
        }
        .chart-canvas-wrap { padding: 0 14px 10px; }

        /* Stats row */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 8px;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.7s both;
        }
        .stat-card {
            background: rgba(255,255,255,0.025);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px;
            transition: all 0.3s ease;
        }
        .stat-card:hover {
            background: rgba(16,185,129,0.05);
            border-color: rgba(16,185,129,0.2);
            transform: translateY(-2px);
        }
        .stat-label {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 0.62rem;
            color: var(--faint);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 4px;
        }
        .stat-label .material-symbols-outlined { font-size: 12px; }
        .stat-val {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 2px;
        }
        .stat-chg {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            color: var(--emerald);
        }
        .stat-chg.neg { color: var(--red); }

        /* Index row */
        .index-row {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.8s both;
        }
        .index-card {
            background: rgba(255,255,255,0.025);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 10px 8px;
            text-align: center;
            transition: all 0.3s ease;
        }
        .index-card:hover {
            background: rgba(16,185,129,0.04);
            border-color: rgba(16,185,129,0.15);
        }
        .index-sym {
            font-size: 0.62rem;
            font-weight: 600;
            color: var(--faint);
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-bottom: 4px;
        }
        .index-val {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 2px;
        }
        .index-chg {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.62rem;
        }
        .index-chg.up   { color: var(--emerald); }
        .index-chg.down { color: var(--red); }

        /* Bottom bar */
        .l-footer {
            position: relative;
            z-index: 10;
            padding: 16px 32px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.9s both;
        }
        .l-footer p {
            font-size: 0.7rem;
            color: var(--faint);
        }
        .l-footer-live {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.7rem;
            color: var(--faint);
        }

        /* ════════════════════════════════════
           RIGHT PANEL
           ════════════════════════════════════ */
        .right-panel {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--surface);
            position: relative;
            overflow: hidden;
            flex-direction: column;
        }
        @@media (min-width: 992px) { .right-panel { width: 50%; } }

        /* Spotlight */
        .spotlight {
            position: absolute;
            pointer-events: none;
            width: 450px; height: 450px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 70%);
            transform: translate(-50%, -50%);
            transition: left 0.12s, top 0.12s;
            z-index: 0;
        }

        /* Grid background pattern */
        .right-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.015) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.015) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
        }
        /* Radial fade from edges */
        .right-panel::after {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at center, transparent 30%, var(--surface) 100%);
            pointer-events: none;
        }

        .form-container {
            position: relative;
            z-index: 10;
            width: 100%;
            max-width: 540px;
            padding: 48px 40px 32px;
            animation: slideInRight 0.9s cubic-bezier(0.16,1,0.3,1) both;
        }

        /* Mobile logo */
        .mobile-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 32px;
            animation: fadeIn 0.6s ease both;
        }
        @@media (min-width: 992px) { .mobile-logo { display: none; } }
        .mobile-logo .logo-icon { width: 34px; height: 34px; }
        .mobile-logo .logo-text { font-size: 1.1rem; }
        .mobile-live-tag {
            font-size: 0.6rem;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 999px;
            background: rgba(16,185,129,0.1);
            border: 1px solid rgba(16,185,129,0.2);
            color: var(--emerald);
            letter-spacing: 0.08em;
        }

        /* Form header */
        .form-header {
            margin-bottom: 28px;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both;
        }
        .form-header-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 32px;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) 0.1s both;
        }
        .form-title-group { flex: 1; }
        .form-title {
            font-size: 1.9rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            color: var(--text);
            margin-bottom: 8px;
        }
        .form-subtitle {
            font-size: 0.88rem;
            color: var(--faint);
        }

        /* Theme switcher */
        .theme-switcher {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            padding: 10px 14px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            border-radius: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            flex-shrink: 0;
        }
        .theme-switcher:hover {
            background: rgba(255,255,255,0.07);
            border-color: rgba(255,255,255,0.15);
        }
        .theme-switcher .material-symbols-outlined { font-size: 20px; color: var(--faint); transition: color 0.3s; }
        .theme-switcher span:last-child { font-size: 0.55rem; color: var(--faint); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.3s; }
        .theme-switcher:hover .material-symbols-outlined { color: var(--muted); }
        .theme-switcher:hover span:last-child { color: var(--muted); }

        /* Theme definitions */
        .theme-switcher[data-theme="dark"]  { }
        .theme-switcher[data-theme="light"] { }
        .theme-switcher[data-theme="blue"]  { }

        /* Alert */
        .form-alert {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 20px;
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.25);
            animation: shakeAnim 0.4s ease both;
        }
        @@keyframes shakeAnim {
            0%, 100% { transform: translateX(0); }
            20%       { transform: translateX(-5px); }
            40%       { transform: translateX(5px); }
            60%       { transform: translateX(-3px); }
            80%       { transform: translateX(3px); }
        }
        .form-alert .material-symbols-outlined { color: var(--red); font-size: 20px; flex-shrink: 0; margin-top: 1px; }
        .form-alert .validation { font-size: 0.82rem; color: #fca5a5; }

        /* Field groups */
        .field-group {
            margin-bottom: 22px;
            animation: fadeInUp 0.7s cubic-bezier(0.16,1,0.3,1) both;
        }
        .field-group:nth-child(2) { animation-delay: 0.18s; }
        .field-group:nth-child(3) { animation-delay: 0.26s; }
        .field-group:nth-child(4) { animation-delay: 0.34s; }
        .field-group:nth-child(5) { animation-delay: 0.42s; }

        .field-row-end {
            display: flex;
            justify-content: flex-end;
            margin-bottom: 4px;
        }
        .forgot-link {
            font-size: 0.75rem;
            color: var(--blue);
            text-decoration: none;
            transition: color 0.2s;
        }
        .forgot-link:hover { color: #60a5fa; text-decoration: underline; }

        /* Floating input */
        .input-wrap {
            position: relative;
        }
        .fnts-input {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1.5px solid rgba(255,255,255,0.12);
            border-radius: 14px;
            padding: 28px 48px 10px 18px;
            color: var(--text);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.3s, background 0.3s, box-shadow 0.3s;
            -webkit-appearance: none;
            line-height: 1;
        }
        .fnts-input:focus {
            border-color: var(--emerald);
            background: rgba(16,185,129,0.05);
            box-shadow: 0 0 0 4px rgba(16,185,129,0.12);
        }
        .fnts-input:hover:not(:focus) { border-color: rgba(255,255,255,0.22); }
        .fnts-input.is-valid { border-color: rgba(16,185,129,0.5); }

        .fnts-label {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--faint);
            font-size: 1rem;
            font-family: 'Plus Jakarta Sans', sans-serif;
            pointer-events: none;
            transition: all 0.22s ease;
        }
        .fnts-input:focus ~ .fnts-label,
        .fnts-input:not(:placeholder-shown) ~ .fnts-label {
            top: 12px;
            transform: translateY(0);
            font-size: 0.65rem;
            color: var(--emerald);
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 700;
        }

        .pw-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--faint);
            cursor: pointer;
            padding: 6px;
            display: flex;
            transition: color 0.2s;
            background: none;
            border: none;
        }
        .pw-toggle:hover { color: var(--muted); }
        .pw-toggle .material-symbols-outlined { font-size: 20px; }

        .validity-dot {
            position: absolute;
            right: 44px;
            top: 50%;
            transform: translateY(-50%);
            opacity: 0;
            transition: opacity 0.3s;
        }
        .fnts-input:focus ~ .validity-dot,
        .fnts-input.is-valid ~ .validity-dot { opacity: 1; }
        .validity-dot .material-symbols-outlined { font-size: 18px; color: var(--emerald); }

        .field-error {
            font-size: 0.72rem;
            color: var(--red);
            margin-top: 4px;
            padding-left: 4px;
            display: block;
        }

        /* Checkbox */
        .checkbox-row {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
        }
        .fnts-checkbox {
            width: 16px; height: 16px;
            accent-color: var(--emerald);
            cursor: pointer;
            border-radius: 4px;
            flex-shrink: 0;
        }
        .checkbox-label {
            font-size: 0.82rem;
            color: var(--muted);
            cursor: pointer;
            user-select: none;
        }

        /* Submit button */
        .submit-btn {
            width: 100%;
            padding: 14px 24px;
            background: linear-gradient(135deg, var(--emerald) 0%, var(--emerald2) 60%, #047857 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-weight: 700;
            font-size: 0.88rem;
            letter-spacing: 0.04em;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            min-height: 50px;
            margin-top: 4px;
        }
        .submit-btn::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 100%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
            transition: left 0.5s ease;
        }
        .submit-btn:hover::before { left: 100%; }
        .submit-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(16,185,129,0.3);
        }
        .submit-btn:active { transform: translateY(0); }
        .submit-btn:disabled {
            opacity: 0.7;
            cursor: wait;
            transform: none;
        }
        .submit-btn .btn-content { display: flex; align-items: center; gap: 8px; }
        .submit-btn .spinner {
            display: none;
            width: 18px; height: 18px;
            border: 2px solid rgba(255,255,255,0.35);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        .submit-btn .spinner.show { display: block; }
        .submit-btn .btn-content.hidden { display: none; }
        @@keyframes spin { to { transform: rotate(360deg); } }

        /* Form footer */
        .form-footer {
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
            text-align: center;
        }
        .form-footer p {
            font-size: 0.82rem;
            color: var(--faint);
        }
        .form-footer a {
            color: var(--blue);
            text-decoration: none;
            font-weight: 600;
        }
        .form-footer a:hover { text-decoration: underline; }

        /* Mobile market strip */
        .mobile-market {
            display: block;
            margin-top: 28px;
            padding-top: 20px;
            border-top: 1px solid var(--border);
        }
        @@media (min-width: 992px) { .mobile-market { display: none; } }
        .mobile-market-header {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 10px;
        }
        .mobile-market-header span {
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--faint);
        }
        .mobile-market-scroll {
            display: flex;
            gap: 8px;
            overflow-x: auto;
            padding-bottom: 4px;
        }
        .mobile-market-scroll::-webkit-scrollbar { height: 3px; }
        .mobile-market-scroll::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 2px;
        }
        .mm-card {
            flex-shrink: 0;
            padding: 8px 12px;
            border-radius: 8px;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
        }
        .mm-sym { font-size: 0.62rem; color: var(--faint); margin-bottom: 2px; }
        .mm-val { font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; font-weight: 600; color: var(--text); }
        .mm-chg { font-family: 'JetBrains Mono', monospace; font-size: 0.62rem; }
        .mm-chg.up   { color: var(--emerald); }
        .mm-chg.down { color: var(--red); }

        /* ── Shared animations ── */
        @@keyframes fadeInUp {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @@keyframes fadeIn {
            from { opacity: 0; }
            to   { opacity: 1; }
        }
        @@keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-40px); }
            to   { opacity: 1; transform: translateX(0); }
        }
        @@keyframes slideInRight {
            from { opacity: 0; transform: translateX(40px); }
            to   { opacity: 1; transform: translateX(0); }
        }
    </style>
</head>
