@{
    ViewData["Title"] = "Staff Dashboard";
    var accountName = ViewData["AccountName"] ?? "Staff";
    var reportCount = ViewData["ReportCount"] ?? 0;
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="mb-1">Welcome, @accountName!</h2>
        <p class="text-muted">Manage market data and run AI trading analyses.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    @* ── 1. Run Analysis ────────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-primary shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="bi bi-cpu text-primary" viewBox="0 0 16 16">
                        <path d="M5 3a5 5 0 0 1 0 10H3a5 5 0 0 1 0-10h2zm1 0h2a5 5 0 0 1 0 10H6a5 5 0 0 1 0-10zm5-3a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm0 8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/>
                        <path d="M9 0v1a1 1 0 0 1-1 1H3a1 1 0 0 0-1 1v1a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h1a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1v-1a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1H9z"/>
                    </svg>
                </div>
                <h5 class="card-title">Run Analysis</h5>
                <p class="card-text text-muted small">
                    Fetch the latest news and generate a BUY / SELL / HOLD trading recommendation powered by AI.
                </p>
                <a asp-controller="RunAnalysis" asp-action="Index" class="btn btn-primary stretched-link">
                    Get Started
                </a>
            </div>
        </div>
    </div>

    @* ── 2. Manage Categories ────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-success shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="bi bi-folder2 text-success" viewBox="0 0 16 16">
                        <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h2.764c.958 0 1.76.56 2.311 1.184C7.985 3.648 8.48 4 9 4h4.5A1.5 1.5 0 0 1 15 5.5v.64c.57.265.94.876.856 1.546l-.64 5.124A2.5 2.5 0 0 1 12.733 15H3.266a2.5 2.5 0 0 1-2.481-2.19l-.64-5.124A1.5 1.5 0 0 1 1 6.14V3.5zM2 6h12v-.5a.5.5 0 0 0-.5-.5H9c.964 0 1.71-.629 2.174-1.154.265-.354.512-.74.727-1.14H3.266A1.5 1.5 0 0 1 2 3.5V6z"/>
                    </svg>
                </div>
                <h5 class="card-title">Manage Categories</h5>
                <p class="card-text text-muted small">
                    Add, edit, or toggle market sector categories that group news articles.
                </p>
                <a asp-controller="Category" asp-action="Index" class="btn btn-success stretched-link">
                    Open
                </a>
            </div>
        </div>
    </div>

    @* ── 3. Manage Tags ─────────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-warning shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="bi bi-tags text-warning" viewBox="0 0 16 16">
                        <path d="M3 2v1l1.5 5H2v1h11v-1H9.5L11 3V2H3zm.5 0v1L5.5 8H2v1h7.5L8 3.5 3.5 2zm3 3v5h1v-5h-1zm2 0h1v5h-1v-5z"/>
                    </svg>
                </div>
                <h5 class="card-title">Manage Tags</h5>
                <p class="card-text text-muted small">
                    Add and edit stock ticker symbols (tags) used to label trading news articles.
                </p>
                <a asp-controller="Tag" asp-action="Index" class="btn btn-warning text-dark stretched-link">
                    Open
                </a>
            </div>
        </div>
    </div>

    @* ── 4. My Reports ──────────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-info shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="bi bi-journal-text text-info" viewBox="0 0 16 16">
                        <path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5zm0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5z"/>
                        <path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2z"/>
                        <path d="M1 5v-.5a.5.5 0 0 1 1 0V5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0V8h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1zm0 3v-.5a.5.5 0 0 1 1 0v.5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1H1z"/>
                    </svg>
                </div>
                <h5 class="card-title">
                    My Reports
                    <span class="badge bg-info text-white ms-1">@reportCount</span>
                </h5>
                <p class="card-text text-muted small">
                    View your trading analysis history — every BUY / SELL / HOLD recommendation you've generated.
                </p>
                <a asp-controller="Report" asp-action="History" class="btn btn-info text-white stretched-link">
                    View History
                </a>
            </div>
        </div>
    </div>

    @* ── 5. My Profile ─────────────────────────────────────────────────── *@
    <div class="col-md-4">
        <div class="card h-100 border-secondary shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="bi bi-person-circle text-secondary" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.58C4.62 13.48 6.17 14 8 14s3.38-.52 5.468-1.42A7 7 0 0 0 8 1z"/>
                    </svg>
                </div>
                <h5 class="card-title">My Profile</h5>
                <p class="card-text text-muted small">
                    Update your display name, change your password, and manage your account settings.
                </p>
                <a asp-controller="Staff" asp-action="Profile" class="btn btn-secondary stretched-link">
                    Manage
                </a>
            </div>
        </div>
    </div>
</div>
