@using X.PagedList;
@using X.PagedList.Mvc.Core;
@using FUNewsTradingSystem_DataAccessLayer.Models;
@model IPagedList<FUNewsTradingSystem_DataAccessLayer.Models.NewsArticle>

@{
    ViewData["Title"] = "My Reports";
    var activeCount   = Model.Count(r => r.NewsStatus);
    var archivedCount = Model.Count(r => !r.NewsStatus);

    var categories = ViewBag.Categories as IEnumerable<Category> ?? new List<Category>();
    var tags = ViewBag.Tags as IEnumerable<Tag> ?? new List<Tag>();
    int? selectedCategory = ViewBag.SelectedCategory as int?;
    int? selectedTag = ViewBag.SelectedTag as int?;
    string selectedDecision = ViewBag.SelectedDecision as string ?? "";
}

<style>
    .stat-chip { display:inline-flex;align-items:center;gap:.45rem;padding:.35rem .9rem;border-radius:30px;font-size:.8rem;font-weight:600; }
    .table tbody tr td:first-child { padding-left:1.25rem; }
    .table tbody tr td:last-child  { padding-right:1.25rem; }
    .table thead tr th:first-child { padding-left:1.25rem; }
    .table thead tr th:last-child  { padding-right:1.25rem; }
    .report-title { font-weight:600;font-size:.9rem;color:var(--text-main); }
    .report-date  { font-size:.78rem;color:var(--text-muted);white-space:nowrap; }
    .ticker-tag   { display:inline-flex;align-items:center;gap:.25rem;padding:.18em .55em;border-radius:12px;font-size:.75rem;font-weight:600;background:rgba(124,58,237,.1);color:var(--accent);border:1px solid rgba(124,58,237,.2); }
    [data-bs-theme="dark"] .ticker-tag { background:rgba(124,58,237,.2); }
    .empty-state { text-align:center;padding:4rem 2rem;color:var(--text-muted); }
    .empty-state .empty-icon { font-size:3.5rem;margin-bottom:1rem;opacity:.35; }
    .filter-card {
        background: var(--surface-card);
        border-radius: 16px;
        border: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-sm);
    }
    .filter-card .form-label {
        font-size: .78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-muted);
    }
</style>

<div class="page-header">
    <div>
        <h2><i class="bi bi-journal-text me-2" style="background:linear-gradient(135deg,#0284c7,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent"></i>My Reports</h2>
        <p class="text-muted mb-0">Your AI-generated trading analysis history.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="stat-chip" style="background:rgba(16,185,129,.1);color:#059669">
            <i class="bi bi-circle-fill" style="font-size:.5rem"></i>@activeCount Active
        </span>
        <span class="stat-chip" style="background:rgba(100,116,139,.1);color:var(--text-muted)">
            <i class="bi bi-archive-fill" style="font-size:.7rem"></i>@archivedCount Archived
        </span>
    </div>
</div>

<!-- Filter Card -->
<div class="filter-card">
    <form method="get" asp-controller="Report" asp-action="MyReports">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label"><i class="bi bi-folder2 me-1"></i>Sector (Category)</label>
                <select name="categoryId" class="form-select form-select-sm">
                    <option value="">All Sectors</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.CategoryID" selected="@(selectedCategory == cat.CategoryID ? "selected" : null)">
                            @cat.CategoryName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label"><i class="bi bi-hash me-1"></i>Ticker (Tag)</label>
                <select name="tagId" class="form-select form-select-sm">
                    <option value="">All Tickers</option>
                    @foreach (var tag in tags)
                    {
                        <option value="@tag.TagID" selected="@(selectedTag == tag.TagID ? "selected" : null)">
                            @tag.TagName
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label"><i class="bi bi-compass me-1"></i>Decision Type</label>
                <select name="decision" class="form-select form-select-sm">
                    <option value="">All Decisions</option>
                    <option value="BUY" selected="@(selectedDecision == "BUY" ? "selected" : null)">BUY 🚀</option>
                    <option value="SELL" selected="@(selectedDecision == "SELL" ? "selected" : null)">SELL 📉</option>
                    <option value="HOLD" selected="@(selectedDecision == "HOLD" ? "selected" : null)">HOLD ⚖️</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm flex-grow-1">
                    <i class="bi bi-funnel-fill me-1"></i>Filter
                </button>
                <a href="/Staff/MyReports" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-counterclockwise"></i> Reset
                </a>
            </div>
        </div>
    </form>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h6 style="color:var(--text-muted)">No reports found</h6>
                <p style="font-size:.875rem">No matching reports found or you haven't run analysis yet.</p>
                <a asp-controller="RunAnalysis" asp-action="Index" class="btn btn-primary btn-sm mt-1">
                    <i class="bi bi-play-fill me-1"></i>Run Analysis
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Date</th>
                            <th>Sector</th>
                            <th>Tickers</th>
                            <th>Status</th>
                            <th class="text-center">Action</th>
                            <th class="text-end">Detail</th>
                        </tr>
                    </thead>
                    <tbody id="reportTableBody">
                        @foreach (var item in Model)
                        {
                            <tr id="report-row-@item.NewsArticleID">
                                <td><span class="report-title">@item.NewsTitle</span></td>
                                <td><span class="report-date"><i class="bi bi-clock me-1"></i>@item.CreatedDate.ToString("yyyy-MM-dd HH:mm")</span></td>
                                <td>
                                    <span class="badge bg-secondary">@item.Category?.CategoryName</span>
                                </td>
                                <td>
                                    @foreach (var tag in item.NewsTagList)
                                    {
                                        <span class="ticker-tag me-1"><i class="bi bi-hash"></i>@tag.Tag.TagName</span>
                                    }
                                </td>
                                <td>
                                    <span id="status-badge-@item.NewsArticleID"
                                          class="badge @(item.NewsStatus ? "bg-success" : "bg-secondary")">
                                        @(item.NewsStatus ? "Active" : "Archived")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm @(item.NewsStatus ? "btn-outline-warning" : "btn-outline-success")"
                                            onclick="toggleStatus(@item.NewsArticleID)">
                                        <i class="bi @(item.NewsStatus ? "bi-archive" : "bi-arrow-counterclockwise") me-1"></i>
                                        @(item.NewsStatus ? "Archive" : "Restore")
                                    </button>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="/Report/Detail/@item.NewsArticleID">
                                        <i class="bi bi-eye me-1"></i>View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Pagination Controls -->
@await Html.PartialAsync("_Pagination", Model)

<form id="ajax-antiforgery">@Html.AntiForgeryToken()</form>
<script src="~/js/myreports.js"></script>
