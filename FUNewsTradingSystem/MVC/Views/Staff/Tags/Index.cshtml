@using X.PagedList;
@using X.PagedList.Mvc.Core;
@model IPagedList<FUNewsTradingSystem_DataAccessLayer.Models.Tag>

@{
    ViewData["Title"] = "Tag Management";
}

<div class="container">
    <div class="page-header">
        <div>
            <h2><i class="bi bi-tags me-2" style="background:linear-gradient(135deg,#d97706,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent"></i>Tag Management</h2>
            <p class="text-muted mb-0">Manage stock ticker symbols used for article categorization.</p>
        </div>
        <button class="btn btn-warning" onclick="openCreateModal()">
            <i class="bi bi-plus-circle me-1"></i> Add Tag
        </button>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info d-flex align-items-center gap-2">
            <i class="bi bi-info-circle"></i>
            <span>No tags found. Create your first ticker symbol tag.</span>
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th style="padding-left:1.25rem">#</th>
                                <th>Tag Name</th>
                                <th>Description</th>
                                <th class="text-end" style="padding-right:1.25rem">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tag in Model)
                            {
                                <tr>
                                    <td style="padding-left:1.25rem;color:var(--text-muted);font-size:.85rem;font-weight:600">
                                        @tag.TagID
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            <i class="bi bi-hash me-1"></i>
                                            @tag.TagName
                                        </span>
                                    </td>
                                    <td class="text-muted">
                                        @(string.IsNullOrEmpty(tag.Note) ? "—" : tag.Note)
                                    </td>
                                    <td class="text-end" style="padding-right:1.25rem">
                                        <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditModal(@tag.TagID)">
                                            <i class="bi bi-pencil me-1"></i>Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" onclick="deleteTag(@tag.TagID, '@tag.TagName')">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Pagination Controls -->
        @await Html.PartialAsync("_Pagination", Model)
    }

    <div id="createModalContainer"></div>
    <div id="editModalContainer"></div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/tags.js"></script>
    }
</div>
