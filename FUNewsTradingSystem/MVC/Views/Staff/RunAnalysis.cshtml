@model FUNewsTradingSystem_MVC.ViewModels.Report.RunAnalysisViewModel
@{
    ViewData["Title"] = "Run AI Analysis";
}

<style>
    .analysis-hero {
        background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #1e1b4b 100%);
        border-radius: 20px;
        padding: 2rem 2.25rem;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    .analysis-hero::after {
        content: '🤖';
        position: absolute;
        right: 2rem; top: 50%;
        transform: translateY(-50%);
        font-size: 5rem;
        opacity: 0.12;
        line-height: 1;
    }
    .analysis-hero h2 { font-weight: 800; font-size: 1.5rem; margin-bottom: .25rem; }
    .analysis-hero p  { margin: 0; opacity: .8; font-size: .9rem; }

    .analysis-card {
        background: var(--surface-card);
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }
    .analysis-card-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    #resultArea {
        border-radius: 14px;
        font-size: .9375rem;
        line-height: 1.75;
    }
    #resultArea.alert-success { border-left: 4px solid #10b981; }
    #resultArea.alert-danger  { border-left: 4px solid #ef4444; }
    #resultArea.alert-warning { border-left: 4px solid #f59e0b; }
    #resultArea.alert-info    { border-left: 4px solid #38bdf8; }
</style>

<div class="analysis-hero">
    <div>
        <h2><i class="bi bi-cpu-fill me-2"></i>Run AI Analysis</h2>
        <p>Select a ticker and market sector to generate an automated BUY / SELL / HOLD recommendation.</p>
    </div>
</div>

<div class="analysis-card">
    <div class="analysis-card-header">
        <i class="bi bi-sliders" style="color:var(--accent)"></i>
        Configure Analysis Parameters
    </div>
    <div class="card-body p-0" style="padding:1.5rem!important">
        <form id="runAnalysisForm" asp-action="Index" asp-controller="RunAnalysis" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label asp-for="SelectedTagId" class="form-label">
                        <i class="bi bi-hash me-1"></i>Ticker Symbol
                    </label>
                    <select asp-for="SelectedTagId" class="form-select" asp-items="Model.AvailableTags">
                        <option value="">— Select Ticker —</option>
                    </select>
                    <span asp-validation-for="SelectedTagId" class="text-danger" style="font-size:.78rem"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SelectedCategoryId" class="form-label">
                        <i class="bi bi-folder2 me-1"></i>Market Sector
                    </label>
                    <select asp-for="SelectedCategoryId" class="form-select" asp-items="Model.AvailableCategories">
                        <option value="">— Select Sector —</option>
                    </select>
                    <span asp-validation-for="SelectedCategoryId" class="text-danger" style="font-size:.78rem"></span>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <button type="button" id="btnRunAnalysis" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-play-fill me-2"></i>Run Analysis
                </button>

                <div id="loadingSpinner" class="d-none d-flex align-items-center gap-2" style="color:var(--text-muted)">
                    <div class="spinner-border text-primary" style="width:1.5rem;height:1.5rem" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span style="font-size:.875rem">Analyzing market data...</span>
                </div>
            </div>
        </form>

        <div id="resultArea" class="mt-4 d-none"></div>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Staff" asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/run-analysis.js"></script>
}
