@model FUNewsTradingSystem_MVC.ViewModels.Report.RunAnalysisViewModel
@{
    ViewData["Title"] = "Run AI Analysis";
}

<div class="row mb-4">
    <div class="col-12">
        <h2><i class="bi bi-cpu me-2"></i>Run AI Analysis</h2>
        <p class="text-muted">Select a ticker and sector to generate an automated trading analysis report.</p>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <form id="runAnalysisForm" asp-action="Index" asp-controller="RunAnalysis" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="SelectedTagId" class="form-label">Ticker Symbol</label>
                    <select asp-for="SelectedTagId" class="form-select" asp-items="Model.AvailableTags">
                        <option value="">-- Select Ticker --</option>
                    </select>
                    <span asp-validation-for="SelectedTagId" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="SelectedCategoryId" class="form-label">Market Sector</label>
                    <select asp-for="SelectedCategoryId" class="form-select" asp-items="Model.AvailableCategories">
                        <option value="">-- Select Sector --</option>
                    </select>
                    <span asp-validation-for="SelectedCategoryId" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />

            <div class="d-flex align-items-center gap-3">
                <button type="button" id="btnRunAnalysis" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-play-fill me-2"></i>Run Analysis
                </button>

                <div id="loadingSpinner" class="d-none">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2 text-muted">Analyzing...</span>
                </div>
            </div>
        </form>

        <div id="resultArea" class="mt-4 d-none">
        </div>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Staff" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/run-analysis.js"></script>
}
