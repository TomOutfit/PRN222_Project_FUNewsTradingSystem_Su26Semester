@model FUNewsTradingSystem_MVC.ViewModels.Report.RunAnalysisViewModel
@{
    ViewData["Title"] = "Run AI Analysis";
}

<style>
    .analysis-hero {
        background: var(--brand-gradient);
        border-radius: var(--radius-lg);
        padding: 2rem 2.25rem;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
        position: relative;
        overflow: hidden;
    }
    .analysis-hero::after {
        content: '🤖';
        position: absolute;
        right: 2rem; top: 50%;
        transform: translateY(-50%);
        font-size: 5rem;
        opacity: 0.12;
        line-height: 1;
    }
    .analysis-hero h2 { font-weight: 800; font-size: 1.5rem; margin-bottom: .25rem; }
    .analysis-hero p  { margin: 0; opacity: .8; font-size: .9rem; }

    .analysis-card {
        background: var(--surface-card);
        border: 1px solid var(--border);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
    }
    .analysis-card-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .6rem;
    }

    #resultArea {
        border-radius: 14px;
        font-size: .9375rem;
        line-height: 1.75;
    }
    #resultArea.alert-success { border-left: 4px solid #10b981; }
    #resultArea.alert-danger  { border-left: 4px solid #ef4444; }
    #resultArea.alert-warning { border-left: 4px solid #f59e0b; }
    #resultArea.alert-info    { border-left: 4px solid #38bdf8; }
</style>

<div class="analysis-hero">
    <div>
        <h2><i class="bi bi-cpu-fill me-2"></i>Run AI Analysis</h2>
        <p>Select a ticker and market sector to generate an automated BUY / SELL / HOLD recommendation.</p>
    </div>
</div>

<div class="analysis-card fintech-card border-0">
    <div class="analysis-card-header">
        <i class="bi bi-sliders" style="color:var(--accent)"></i>
        Configure Analysis Parameters
    </div>
    <div class="card-body p-0" style="padding:1.5rem!important">
        <form id="runAnalysisForm" asp-action="Index" asp-controller="RunAnalysis" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label">
                        <i class="bi bi-folder2 me-1"></i>Market Sector
                    </label>
                    <div class="position-relative">
                        <input type="text" id="sectorSearch" class="form-control fintech-form-control mb-1"
                               placeholder="Type to search sectors..." autocomplete="off"
                               style="font-size:.85rem;padding:.4rem .75rem;">
                        <select asp-for="SelectedCategoryId" id="SelectedCategoryId" class="form-select fintech-form-control" asp-items="Model.AvailableCategories" size="1">
                            <option value="">— All Sectors —</option>
                        </select>
                    </div>
                    <span asp-validation-for="SelectedCategoryId" class="text-danger" style="font-size:.78rem"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label">
                        <i class="bi bi-hash me-1"></i>Ticker Symbol
                    </label>
                    <div class="position-relative">
                        <input type="text" id="tickerSearch" class="form-control fintech-form-control mb-1"
                               placeholder="Type to search tickers..." autocomplete="off"
                               style="font-size:.85rem;padding:.4rem .75rem;">
                        <select asp-for="SelectedTagId" id="SelectedTagId" class="form-select fintech-form-control" asp-items="Model.AvailableTags">
                            <option value="">— All Tickers —</option>
                        </select>
                    </div>
                    <span asp-validation-for="SelectedTagId" class="text-danger" style="font-size:.78rem"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12">
                    <label class="form-label fw-semibold">
                        <i class="bi bi-cpu me-1"></i>Analysis Engine
                    </label>
                    <select name="SelectedPipeline" id="SelectedPipeline" class="form-select fintech-form-control">
                        <option value="classic">Classic — 3-Agent OpenAI Pipeline (Fast &middot; ~15s)</option>
                        <option value="tradingagents">Multi-Agents LLM Financial Trading Framework (Deep &middot; 3–8 min)</option>
                    </select>
                    <div id="engineHint" class="form-text mt-1" style="font-size:.78rem"></div>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <button type="button" id="btnRunAnalysis" class="btn fintech-btn-primary btn-lg px-5">
                    <i class="bi bi-play-fill me-2"></i>Run Analysis
                </button>

                <div id="loadingSpinner" class="d-none d-flex align-items-center gap-2" style="color:var(--text-muted)">
                    <div class="spinner-border text-primary" style="width:1.5rem;height:1.5rem" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span style="font-size:.875rem">Analyzing market data...</span>
                </div>
            </div>
        </form>

        <div id="progressArea" class="mt-4 d-none">
            <div class="card fintech-card p-4 border-0">
                <h6 class="fw-bold mb-3 text-main d-flex align-items-center justify-content-between">
                    <span><i class="bi bi-cpu text-primary me-2"></i>Analysis Pipeline Progress</span>
                    <span id="progressPercent" class="text-primary fw-extrabold">0%</span>
                </h6>
                <div class="progress mb-3" style="height: 10px; border-radius: 5px;">
                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div id="progressLogs" class="bg-dark text-light p-3 rounded-3 font-monospace small" style="max-height: 150px; overflow-y: auto; line-height: 1.5; border: 1px solid rgba(255,255,255,0.1)">
                    <div class="text-white-50">// Standing by for pipeline execution...</div>
                </div>
            </div>
        </div>

        <div id="resultArea" class="mt-4 d-none"></div>
    </div>
</div>

<div class="mt-4">
    <a asp-controller="Staff" asp-action="Index" class="btn fintech-btn-outline btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="~/js/run-analysis.js"></script>
    <script>
    (function () {
        var categorySelect = document.getElementById('SelectedCategoryId');
        var tagSelect     = document.getElementById('SelectedTagId');
        var sectorSearch  = document.getElementById('sectorSearch');
        var tickerSearch  = document.getElementById('tickerSearch');

        if (!categorySelect || !tagSelect) return;

        // ── Snapshot all options on load ────────────────────────────────────────
        var allCategoryOptions = Array.from(categorySelect.options).map(function (o) {
            return { value: o.value, text: o.text };
        });
        var allTagOptions = Array.from(tagSelect.options).map(function (o) {
            return { value: o.value, text: o.text };
        });

        // ── Search filter helper ────────────────────────────────────────────────
        function filterSelect(select, allOptions, term) {
            var lower = term.toLowerCase();
            select.innerHTML = '';
            allOptions.forEach(function (o) {
                if (!term || o.value === '' || o.text.toLowerCase().includes(lower)) {
                    var opt = document.createElement('option');
                    opt.value = o.value;
                    opt.text  = o.text;
                    select.appendChild(opt);
                }
            });
        }

        // ── Sector search ───────────────────────────────────────────────────────
        sectorSearch && sectorSearch.addEventListener('input', function () {
            filterSelect(categorySelect, allCategoryOptions, this.value);
        });

        // ── Ticker search ───────────────────────────────────────────────────────
        tickerSearch && tickerSearch.addEventListener('input', function () {
            filterSelect(tagSelect, allTagOptions, this.value);
        });

        // ── Sector → filter tickers (forward direction) ─────────────────────────
        categorySelect.addEventListener('change', function () {
            var categoryId = this.value;
            if (tickerSearch) tickerSearch.value = '';

            if (!categoryId) {
                // Restore all tickers
                filterSelect(tagSelect, allTagOptions, '');
                tagSelect.value = '';
                return;
            }

            fetch('/Staff/RunAnalysis/GetTagsByCategory?categoryId=' + encodeURIComponent(categoryId))
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    // Rebuild allTagOptions from server result + blank option
                    var fresh = [{ value: '', text: data.tags.length > 0 ? '— Select Ticker —' : '— No tickers for this sector —' }];
                    data.tags.forEach(function (t) { fresh.push({ value: String(t.id), text: t.name }); });
                    allTagOptions = fresh;
                    filterSelect(tagSelect, allTagOptions, '');
                    tagSelect.value = '';
                })
                .catch(function () {
                    tagSelect.innerHTML = '<option value="">— Failed to load tickers —</option>';
                });
        });

        // ── Engine hint ─────────────────────────────────────────────────────────
        var engineSelect = document.getElementById('SelectedPipeline');
        var engineHint   = document.getElementById('engineHint');
        engineSelect && engineSelect.addEventListener('change', function () {
            if (this.value === 'tradingagents') {
                engineHint.innerHTML = '<i class="bi bi-info-circle me-1" style="color:var(--accent)"></i>'
                    + '12 agents &middot; yfinance + FRED + StockTwits + Polymarket real data. Expect 3–8 minutes.';
            } else {
                engineHint.innerHTML = '';
            }
        });

        // ── Ticker → auto-select sector (reverse direction) ─────────────────────
        tagSelect.addEventListener('change', function () {
            var tagId = this.value;
            if (!tagId) return;

            fetch('/Staff/RunAnalysis/GetCategoryByTag?tagId=' + encodeURIComponent(tagId))
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.categoryId) {
                        categorySelect.value = String(data.categoryId);
                        if (sectorSearch) sectorSearch.value = '';
                        filterSelect(categorySelect, allCategoryOptions, '');
                        categorySelect.value = String(data.categoryId);
                    }
                })
                .catch(function () { /* ignore reverse-lookup failure */ });
        });
    })();
    </script>
}
