@{
    ViewData["Title"] = "Staff Dashboard";
    var accountName = ViewData["AccountName"] ?? "Staff";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="mb-1">Welcome, @accountName!</h2>
        <p class="text-muted">Manage market data and run AI trading analyses.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100 border-primary shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-cpu text-primary" viewBox="0 0 16 16">
                        <path d="M5 3a5 5 0 0 1 0 10H3a5 5 0 0 1 0-10h2zm1 0h2a5 5 0 0 1 0 10H6a5 5 0 0 1 0-10zm5-3a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm0 8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z"/>
                        <path d="M9 0v1a1 1 0 0 1-1 1H3a1 1 0 0 0-1 1v1a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h1a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1v-1a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1H9z"/>
                    </svg>
                </div>
                <h5 class="card-title">Run AI Analysis</h5>
                <p class="card-text text-muted small">Fetch news and generate a BUY / SELL / HOLD trading recommendation.</p>
                <a asp-controller="Analysis" asp-action="Index" class="btn btn-primary stretched-link">Get Started</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-success shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-folder2 text-success" viewBox="0 0 16 16">
                        <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h2.764c.958 0 1.76.56 2.311 1.184C7.985 3.648 8.48 4 9 4h4.5A1.5 1.5 0 0 1 15 5.5v.64c.57.265.94.876.856 1.546l-.64 5.124A2.5 2.5 0 0 1 12.733 15H3.266a2.5 2.5 0 0 1-2.481-2.19l-.64-5.124A1.5 1.5 0 0 1 1 6.14V3.5zM2 6h12v-.5a.5.5 0 0 0-.5-.5H9c.964 0 1.71-.629 2.174-1.154.265-.354.512-.74.727-1.14H3.266A1.5 1.5 0 0 1 2 3.5V6z"/>
                    </svg>
                </div>
                <h5 class="card-title">Manage Categories</h5>
                <p class="card-text text-muted small">Create and maintain market sector definitions.</p>
                <a asp-controller="Category" asp-action="Index" class="btn btn-success stretched-link">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-tags text-warning" viewBox="0 0 16 16">
                        <path d="M3 2v1l1.5 5H2v1h11v-1H9.5L11 3V2H3zm.5 0v1L5.5 8H2v1h7.5L8 3.5 3.5 2zm3 3v5h1v-5h-1zm2 0h1v5h-1v-5z"/>
                    </svg>
                </div>
                <h5 class="card-title">Manage Tickers</h5>
                <p class="card-text text-muted small">Add and edit stock ticker symbols.</p>
                <a asp-controller="Tag" asp-action="Index" class="btn btn-warning text-dark stretched-link">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-info shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-clock-history text-info" viewBox="0 0 16 16">
                        <path d="M8.515 1.019A7 7 0 0 0 1.07 1.52a6.978 6.978 0 0 0-1.414 2.681 5.965 5.965 0 0 0-.08.916C.056 6.29.064 8.036 0 10c.002.14.018.277.034.411.036.29.106.565.205.82.206.552.508 1.086.906 1.577C1.65 14.16 2.536 14.5 3.5 14.5h9c.964 0 1.85-.34 2.498-.976.398-.491.7-1.025.906-1.577.1-.257.17-.53.205-.82.016-.134.028-.27.034-.411.064-1.964-.002-3.71-.002-5.5-.004-1.784-.012-3.02.004-5.016-.008-.14.006-.277-.008-.411z"/>
                        <path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0zM1.5 8a6.5 6.5 0 1 1 13 0 6.5 6.5 0 0 1-13 0z"/>
                    </svg>
                </div>
                <h5 class="card-title">My Reports</h5>
                <p class="card-text text-muted small">View all reports you have generated and manage their visibility.</p>
                <a asp-controller="Report" asp-action="History" class="btn btn-info text-white stretched-link">View History</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-secondary shadow-sm">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-person-circle text-secondary" viewBox="0 0 16 16">
                        <path d="M11 14s1 0 1-1 1-4 5-4 5 3 5 4-1 1-1 1H4a1 1 0 0 1-1-1s1-1 1-1zm-2.5-3a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                        <path d="M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                    </svg>
                </div>
                <h5 class="card-title">My Profile</h5>
                <p class="card-text text-muted small">Update your display name and change your password.</p>
                <a asp-controller="Account" asp-action="Profile" class="btn btn-secondary stretched-link">Edit Profile</a>
            </div>
        </div>
    </div>
</div>
