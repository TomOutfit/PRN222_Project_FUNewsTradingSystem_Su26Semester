@using Microsoft.AspNetCore.Html
@model IEnumerable<FUNewsTradingSystem_DataAccessLayer.Models.Category>
@{
    ViewData["Title"] = "Staff Dashboard & Categories";
    var accountName = ViewData["AccountName"] ?? "Staff";
    var reportCount = ViewData["ReportCount"] ?? 0;
}

@* ──────────────────────────────────────────────────────────────────────────
   1. KHU VỰC DASHBOARD CARDS (Giữ nguyên giao diện của bạn)
   ────────────────────────────────────────────────────────────────────────── *@
<div class="row mb-4">
    <div class="col-12">
        <h2 class="mb-1">Welcome, @accountName!</h2>
        <p class="text-muted">Manage market data and run AI trading analyses.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 border-primary shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-cpu text-primary" viewBox="0 0 16 16">
                        <path d="M5 3a5 5 0 0 1 0 10H3a5 5 0 0 1 0-10h2zm1 0h2a5 5 0 0 1 0 10H6a5 5 0 0 1 0-10zm5-3a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm0 8a3 3 0 1 0 0 6 3 3 0 0 0 0-6z" />
                        <path d="M9 0v1a1 1 0 0 1-1 1H3a1 1 0 0 0-1 1v1a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1h1a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v1a1 1 0 0 1-1 1h-1a1 1 0 0 1-1-1v-1a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1H9z" />
                    </svg>
                </div>
                <h5 class="card-title">Run AI Analysis</h5>
                <p class="card-text text-muted small">Fetch news and generate a BUY / SELL / HOLD trading recommendation.</p>
                <a asp-controller="RunAnalysis" asp-action="Index" class="btn btn-primary stretched-link">Get Started</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-success shadow-sm card-dashboard bg-light">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-folder2 text-success" viewBox="0 0 16 16">
                        <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h2.764c.958 0 1.76.56 2.311 1.184C7.985 3.648 8.48 4 9 4h4.5A1.5 1.5 0 0 1 15 5.5v.64c.57.265.94.876.856 1.546l-.64 5.124A2.5 2.5 0 0 1 12.733 15H3.266a2.5 2.5 0 0 1-2.481-2.19l-.64-5.124A1.5 1.5 0 0 1 1 6.14V3.5zM2 6h12v-.5a.5.5 0 0 0-.5-.5H9c.964 0 1.71-.629 2.174-1.154.265-.354.512-.74.727-1.14H3.266A1.5 1.5 0 0 1 2 3.5V6z" />
                    </svg>
                </div>
                <h5 class="card-title fw-bold text-success">Managing Categories</h5>
                <p class="card-text text-muted small">You are currently looking at the market sectors configuration table below.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 border-warning shadow-sm card-dashboard">
            <div class="card-body text-center">
                <div class="mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-tags text-warning" viewBox="0 0 16 16">
                        <path d="M3 2v1l1.5 5H2v1h11v-1H9.5L11 3V2H3zm.5 0v1L5.5 8H2v1h7.5L8 3.5 3.5 2zm3 3v5h1v-5h-1zm2 0h1v5h-1v-5z" />
                    </svg>
                </div>
                <h5 class="card-title">Manage Tickers</h5>
                <p class="card-text text-muted small">Add and edit stock ticker symbols.</p>
                <a asp-controller="Tag" asp-action="Index" class="btn btn-warning text-dark stretched-link">Manage</a>
            </div>
        </div>
    </div>
</div>

@* ──────────────────────────────────────────────────────────────────────────
   2. KHU VỰC QUẢN LÝ DANH MỤC (TABLE & CRUD BUTTONS)
   ────────────────────────────────────────────────────────────────────────── *@
<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center border-bottom-0">
        <h4 class="mb-0 text-dark fw-bold"><i class="bi bi-folder-fill text-success me-2"></i>Market Sectors & Categories</h4>
        <button type="button" class="btn btn-success d-flex align-items-center gap-2" onclick="openCreateModal()">
            <i class="bi bi-plus-circle"></i> Add Category
        </button>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary">
                    <tr>
                        <th class="ps-4" style="width: 80px;">ID</th>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Parent Category</th>
                        <th class="text-center" style="width: 120px;">Status</th>
                        <th class="text-center" style="width: 150px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2"></i> No categories found. Click "Add Category" to start.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.CategoryID">
                                <td class="ps-4 fw-medium text-secondary">@item.CategoryID</td>
                                <td class="fw-bold text-dark">@item.CategoryName</td>
                                <td class="text-muted text-truncate" style="max-width: 250px;">
                                    @* SỬA: Đổi từ item.CategoryDescription thành item.CategoryDes để khớp Entity *@
                                    @(string.IsNullOrEmpty(item.CategoryDescription) ? "---" : item.CategoryDescription)
                                </td>
                                <td>
                                    @if (item.ParentCategory != null)
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary px-2 py-1">
                                            <i class="bi bi-arrow-return-right me-1"></i>@item.ParentCategory.CategoryName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">None (Top Level)</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @* IsActive Toggle Switch *@
                                    <div class="form-check form-switch d-inline-block">
                                        @* SỬA: Hàm onclick đổi từ toggleStatus(id) sang toggleActive(id, this) theo file JS *@
                                        <input class="form-check-input cursor-pointer" type="checkbox" role="switch"
                                               id="switch-@item.CategoryID" @(item.IsActive ? "checked" : "")
                                               onclick="toggleActive(@item.CategoryID, this)">
                                    </div>
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group gap-1">
                                        <button class="btn btn-sm btn-outline-primary rounded border-0" onclick="openEditModal(@item.CategoryID)" title="Edit">
                                            <i class="bi bi-pencil-square fs-5"></i>
                                        </button>
                                        @* SỬA: Hàm onclick gọi trực tiếp deleteCategory(id, name) đồng bộ với file JS mới *@
                                        <button class="btn btn-sm btn-outline-danger rounded border-0" title="Delete"
                                                onclick="deleteCategory(@item.CategoryID, '@System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(item.CategoryName)')">
                                            <i class="bi bi-trash3 fs-5"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ──────────────────────────────────────────────────────────────────────────
   3. CÁC KHỐI MODAL PHỤ TRỢ (CONTAINER DIVS)
   ────────────────────────────────────────────────────────────────────────── *@

<form id="ajax-antiforgery">@Html.AntiForgeryToken()</form>

<div class="modal fade" id="categoryCrudModal" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-light border-0">
                <h5 class="modal-title fw-bold text-dark" id="modalTitle">Category Details</h5>
                <button type="button" class="btn-close" data-bs-close="modal" aria-label="Close"></button>
            </div>
            <div id="modalBodyContainer">
                @* Nội dung Form tạo/sửa sẽ được inject động vào đây *@
            </div>
            <div class="modal-footer border-0 bg-light py-2">
                <button type="button" class="btn btn-outline-secondary px-3" data-bs-close="modal">Cancel</button>
                @* LƯU Ý: Thuộc tính onclick sẽ tự động được file JS ghi đè linh hoạt thành submitCreateForm() hoặc submitEditForm() *@
                <button type="button" class="btn btn-success px-4" id="btnSaveCategory">
                    <span class="spinner-border spinner-border-sm d-none me-1" id="saveSpinner" role="status"></span> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_ConfirmDeleteModal")

@* ──────────────────────────────────────────────────────────────────────────
   4. BỘ SCRIPT ĐIỀU KHIỂN HOẠT ĐỘNG (Nhúng file JavaScript ngoài)
   ────────────────────────────────────────────────────────────────────────── *@
@section Scripts {
    @* SỬA: Thay thế toàn bộ đoạn code script cũ bằng lệnh nhúng filecategories.js sạch sẽ *@
    <script src="~/js/categories.js"></script>
}