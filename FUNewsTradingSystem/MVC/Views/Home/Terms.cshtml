@{
    ViewData["Title"] = "Terms of Service";
}

<style>
    .terms-hero {
        background: linear-gradient(135deg, rgba(30,27,75,0.95), rgba(15,15,26,0.98)), radial-gradient(circle at 60% 30%, rgba(219,39,119,0.12) 0%, transparent 55%);
        border-radius: var(--radius-xl);
        padding: 2.5rem 2.5rem;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border-light);
        position: relative;
        overflow: hidden;
        color: #fff;
        margin-bottom: 2rem;
    }
    .terms-card {
        background: var(--surface-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
        transition: box-shadow 0.3s ease, transform 0.3s ease;
    }
    .terms-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-3px);
    }
    .terms-card .terms-header {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: rgba(124,58,237,0.04);
    }
    .terms-card .terms-header i {
        font-size: 1.2rem;
        color: var(--brand-1);
    }
    [data-bs-theme="dark"] .terms-card .terms-header i {
        color: var(--brand-3);
    }
    .terms-card .terms-body {
        padding: 1.25rem 1.5rem;
    }
    .terms-card .terms-body p {
        color: var(--text-muted);
        font-size: 0.875rem;
        line-height: 1.65;
        margin-bottom: 0.75rem;
    }
    .terms-card .terms-body p:last-child { margin-bottom: 0; }
    .terms-card .terms-body strong { color: var(--text-main); }
    .terms-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }
    .terms-list li {
        display: flex;
        gap: 0.6rem;
        align-items: flex-start;
        color: var(--text-muted);
        font-size: 0.875rem;
        line-height: 1.5;
    }
    .terms-list li i {
        color: var(--brand-1);
        margin-top: 3px;
        flex-shrink: 0;
    }
    [data-bs-theme="dark"] .terms-list li i {
        color: var(--brand-3);
    }
    .highlight-card {
        background: linear-gradient(135deg, rgba(109,40,217,0.06), rgba(219,39,119,0.04));
        border: 1px solid rgba(109,40,217,0.15);
        border-radius: var(--radius-md);
        padding: 0.875rem 1.25rem;
    }
    .highlight-card .highlight-title {
        font-weight: 700;
        color: var(--text-main);
        font-size: 0.875rem;
        margin-bottom: 0.25rem;
    }
    .highlight-card p {
        color: var(--text-muted);
        font-size: 0.825rem;
        margin-bottom: 0;
        line-height: 1.5;
    }
</style>

<div class="animate-fade-in-up">
    <!-- Hero Banner -->
    <div class="terms-hero">
        <div class="d-flex align-items-center gap-3 mb-2">
            <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#db2777,#be185d);display:flex;align-items:center;justify-content:center;">
                <i class="bi bi-file-earmark-text-fill fs-5 text-white"></i>
            </div>
            <div>
                <h2 class="fw-bold text-white mb-0" style="letter-spacing:-0.5px;">Terms of Service</h2>
                <p class="text-white-50 mb-0 small">Last updated: July 2026 · FNTS Inc.</p>
            </div>
        </div>
        <p class="text-white-50 mb-0 mt-2" style="max-width:700px;font-size:0.9rem;line-height:1.6;">
            By accessing or using the FUNews Trading System ("FNTS"), you agree to be bound by these Terms of Service. Please read them carefully before using the platform.
        </p>
    </div>

    <!-- Key Notice -->
    <div class="highlight-card mb-4">
        <div class="highlight-title">
            <i class="bi bi-exclamation-triangle-fill text-warning me-1"></i>Important Notice
        </div>
        <p>FNTS is an <strong>educational and informational tool only</strong>. All BUY / SELL / HOLD recommendations, sentiment signals, and AI-synthesized reports are generated automatically and must <strong>not</strong> be treated as financial, investment, or trading advice.</p>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <!-- Trading Disclaimer -->
            <div class="terms-card animate-fade-in-up" style="animation-delay:50ms;">
                <div class="terms-header">
                    <i class="bi bi-graph-up"></i>
                    <h5 class="fw-bold mb-0">Trading Disclaimer</h5>
                </div>
                <div class="terms-body">
                    <p>Sentiment signals and recommendations generated by FNTS are <strong>automated, simulated, and educational</strong>. They do not constitute professional financial advice.</p>
                    <ul class="terms-list">
                        <li><i class="bi bi-dot"></i><span>BUY / SELL / HOLD are <strong>not</strong> guaranteed outcomes</span></li>
                        <li><i class="bi bi-dot"></i><span>Past AI analysis does not predict future market results</span></li>
                        <li><i class="bi bi-dot"></i><span>Users retain full responsibility for all trading decisions</span></li>
                        <li><i class="bi bi-dot"></i><span>FNTS does not hold licenses for regulated financial advice</span></li>
                    </ul>
                </div>
            </div>

            <!-- API Keys Usage -->
            <div class="terms-card animate-fade-in-up" style="animation-delay:100ms;">
                <div class="terms-header">
                    <i class="bi bi-key-fill"></i>
                    <h5 class="fw-bold mb-0">API Keys & Credentials</h5>
                </div>
                <div class="terms-body">
                    <p>External integrations with AlphaVantage, NewsAPI, and OpenAI require careful credential handling:</p>
                    <ul class="terms-list">
                        <li><i class="bi bi-dot"></i><span>API keys are subject to provider rate limits and quotas</span></li>
                        <li><i class="bi bi-dot"></i><span>Raw API responses must not be redistributed commercially</span></li>
                        <li><i class="bi bi-dot"></i><span>Keys must be rotated regularly and stored securely</span></li>
                        <li><i class="bi bi-dot"></i><span>Unauthorized use of third-party APIs may result in service suspension</span></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <!-- Account Responsibilities -->
            <div class="terms-card animate-fade-in-up" style="animation-delay:75ms;">
                <div class="terms-header">
                    <i class="bi bi-person-badge-fill"></i>
                    <h5 class="fw-bold mb-0">Account Responsibilities</h5>
                </div>
                <div class="terms-body">
                    <p>Account holders must maintain security and comply with platform usage policies:</p>
                    <ul class="terms-list">
                        <li><i class="bi bi-dot"></i><span>Keep credentials confidential — do not share login details</span></li>
                        <li><i class="bi bi-dot"></i><span>Report suspected unauthorized access immediately</span></li>
                        <li><i class="bi bi-dot"></i><span>Operate strictly within assigned role permissions</span></li>
                        <li><i class="bi bi-dot"></i><span>Automated scraping, brute-force, or abuse is strictly prohibited</span></li>
                    </ul>
                </div>
            </div>

            <!-- System Limitations -->
            <div class="terms-card animate-fade-in-up" style="animation-delay:125ms;">
                <div class="terms-header">
                    <i class="bi bi-sliders"></i>
                    <h5 class="fw-bold mb-0">System Limitations</h5>
                </div>
                <div class="terms-body">
                    <p>FNTS is provided "as is" with expected operational boundaries:</p>
                    <ul class="terms-list">
                        <li><i class="bi bi-dot"></i><span>Report generation depends on third-party API availability</span></li>
                        <li><i class="bi bi-dot"></i><span>Scheduled maintenance may temporarily pause live market updates</span></li>
                        <li><i class="bi bi-dot"></i><span>Interface features may evolve across product iterations</span></li>
                        <li><i class="bi bi-dot"></i><span>SignalR real-time updates require a stable internet connection</span></li>
                    </ul>
                </div>
            </div>

            <!-- Intellectual Property -->
            <div class="terms-card animate-fade-in-up" style="animation-delay:150ms;">
                <div class="terms-header">
                    <i class="bi bi-lightbulb-fill"></i>
                    <h5 class="fw-bold mb-0">Intellectual Property</h5>
                </div>
                <div class="terms-body">
                    <p>The FNTS platform, its design, architecture, and branding are property of FNTS Inc. The 3-layer architecture, SignalR implementation, and AI synthesis engine are protected by copyright. News content sourced from third-party APIs remains subject to each provider's own licensing terms.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="text-center mt-4">
        <p class="text-muted small">
            Questions about these terms?
            <a asp-controller="Home" asp-action="Contact" class="text-primary fw-semibold">Contact our support team</a>
            or read the <a asp-controller="Home" asp-action="Privacy" class="text-primary fw-semibold">Privacy Policy</a>.
        </p>
    </div>
</div>
