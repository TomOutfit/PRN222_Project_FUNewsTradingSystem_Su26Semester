@section Scripts {
    <script>
        (function() {
            var tickerConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/marketTicker")
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            var container = document.getElementById("aboutTickerList");

            tickerConnection.on("ReceiveMarketTicks", function (ticks) {
                if (!container) return;
                
                // Clear wait state on first ticks
                container.innerHTML = "";

                if (!ticks || ticks.length === 0) {
                    container.innerHTML = `<div class="text-white-50 text-center py-3 small">No active tickers available</div>`;
                    return;
                }

                // Render all tickers received dynamically
                ticks.forEach(function(tick) {
                    var changeColor = tick.changePercent >= 0 ? "#4ade80" : "#f87171";
                    var changeSign = tick.changePercent >= 0 ? "+" : "";
                    var iconClass = tick.changePercent >= 0 ? "bi-caret-up-fill" : "bi-caret-down-fill";
                    
                    var itemHtml = `
                        <div class="d-flex justify-content-between align-items-center py-1 border-bottom border-white border-opacity-10">
                            <div>
                                <span class="fw-bold text-white small" style="letter-spacing:0.05em;">${tick.symbol}</span>
                            </div>
                            <div class="text-end">
                                <span class="text-white small fw-semibold me-2">$${tick.price.toLocaleString(undefined, {minimumFractionDigits: (tick.symbol === "BTC" || tick.price > 1000) ? 0 : 2, maximumFractionDigits: (tick.symbol === "BTC" || tick.price > 1000) ? 0 : 2})}</span>
                                <span class="small fw-bold" style="color: ${changeColor}; font-size: 0.75rem;">
                                    <i class="bi ${iconClass} me-1"></i>${changeSign}${tick.changePercent.toFixed(2)}%
                                </span>
                            </div>
                        </div>
                    `;
                    container.insertAdjacentHTML('beforeend', itemHtml);
                });
            });

            tickerConnection.start().catch(function (err) {
                console.error("MarketTickerHub connection failed: ", err);
            });
        })();
    </script>
}
