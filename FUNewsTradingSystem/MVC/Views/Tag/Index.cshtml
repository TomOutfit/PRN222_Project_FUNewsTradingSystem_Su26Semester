@using X.PagedList;
@using X.PagedList.Mvc.Core;
@model IPagedList<FUNewsTradingSystem_DataAccessLayer.Models.Tag>

@{
    ViewData["Title"] = "Tag Management";
    var totalTags = Model.Count();
}

<style>
    /* ── Stat Pill ── */
    .tag-stat-pill {
        display: inline-flex; align-items: center; gap: .35rem;
        padding: .35rem .9rem;
        border-radius: 30px;
        font-size: .8rem; font-weight: 600;
        background: rgba(245,158,11,.07);
        color: #d97706;
        border: 1px solid rgba(245,158,11,.18);
    }
    [data-bs-theme="dark"] .tag-stat-pill {
        background: rgba(251,191,36,.1);
        color: #fbbf24;
        border-color: rgba(251,191,36,.25);
    }

    /* ════════════════════════════════════════════
       PREMIUM TAG TABLE
       ════════════════════════════════════════════ */
    .tag-table-card {
        background: var(--surface-card);
        border-radius: 20px;
        border: 1px solid var(--border);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: box-shadow 0.3s ease;
    }
    .tag-table-card:hover { box-shadow: var(--shadow-lg); }

    .tag-table-header {
        background: linear-gradient(135deg, #78350f 0%, #92400e 50%, #78350f 100%);
        padding: 1rem 1.5rem;
        display: flex; align-items: center; justify-content: space-between;
        position: relative; overflow: hidden;
    }
    .tag-table-header::before {
        content: '';
        position: absolute; top: 0; left: -100%;
        width: 60%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(251,191,36,0.15), transparent);
        animation: headerShimmer 3s ease-in-out infinite;
    }
    @@keyframes headerShimmer {
        0%   { left: -60%; }
        100% { left: 120%; }
    }
    .tag-table-header-title {
        display: flex; align-items: center; gap: .6rem;
        color: rgba(255,255,255,0.85);
        font-weight: 700; font-size: .875rem;
    }
    .tag-table-header-title i { color: #fbbf24; font-size: 1.1rem; }
    .tag-table-header-count {
        background: rgba(251,191,36,0.15);
        border: 1px solid rgba(251,191,36,0.25);
        color: #fbbf24;
        font-size: .72rem; font-weight: 700;
        padding: .2rem .6rem; border-radius: 99px;
    }

    /* ── Column Headers ── */
    .tag-thead th {
        background: linear-gradient(180deg, rgba(248,250,252,0.95) 0%, rgba(241,245,249,0.9) 100%);
        color: #64748b !important;
        font-weight: 700 !important;
        text-transform: uppercase !important;
        font-size: .68rem !important;
        letter-spacing: .08em !important;
        padding: .75rem 1.1rem !important;
        border-bottom: 2px solid var(--border) !important;
        white-space: nowrap;
        vertical-align: middle;
    }
    [data-bs-theme="dark"] .tag-thead th {
        background: linear-gradient(180deg, rgba(30,41,59,0.9) 0%, rgba(15,23,42,0.9) 100%);
        border-bottom-color: rgba(255,255,255,0.06) !important;
    }
    .tag-thead th .th-inner { display: flex; align-items: center; gap: .35rem; }
    .tag-thead th .th-icon {
        width: 18px; height: 18px;
        border-radius: 5px;
        display: inline-flex; align-items: center; justify-content: center;
        font-size: .7rem;
        background: rgba(245,158,11,.08);
        color: #d97706;
    }
    [data-bs-theme="dark"] .tag-thead th .th-icon {
        background: rgba(251,191,36,.1);
        color: #fbbf24;
    }

    /* ── Table Rows ── */
    .tag-tbody tr {
        border-bottom: 1px solid var(--border) !important;
        background: var(--surface-card);
        transition: background 0.2s ease, transform 0.2s ease;
    }
    .tag-tbody tr:last-child { border-bottom: none !important; }
    .tag-tbody tr:hover { background: rgba(245,158,11,.05) !important; transform: translateX(2px); }
    [data-bs-theme="dark"] .tag-tbody tr:hover { background: rgba(251,191,36,.05) !important; }
    .tag-tbody td {
        padding: .85rem 1.1rem !important;
        vertical-align: middle;
        color: var(--text-main);
        font-size: .85rem;
    }
    .tag-tbody .row-num { color: var(--text-muted); font-size: .8rem; width: 52px; }

    /* ── Row Entrance Animation ── */
    @@keyframes tagRowEntrance {
        from { opacity: 0; transform: translateY(4px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .tag-tbody tr { animation: tagRowEntrance 0.35s ease both; }
    .tag-tbody tr:nth-child(1)  { animation-delay: 0.03s; }
    .tag-tbody tr:nth-child(2)  { animation-delay: 0.06s; }
    .tag-tbody tr:nth-child(3)  { animation-delay: 0.09s; }
    .tag-tbody tr:nth-child(n+4) { animation-delay: 0.12s; }

    /* ── Tag Chip ── */
    .tag-chip {
        display: inline-flex; align-items: center; gap: .3rem;
        padding: .28em .75em;
        border-radius: 20px;
        font-size: .8rem; font-weight: 700;
        background: rgba(245,158,11,.07);
        color: #d97706;
        border: 1px solid rgba(245,158,11,.18);
    }
    [data-bs-theme="dark"] .tag-chip {
        background: rgba(251,191,36,.1);
        color: #fbbf24;
        border-color: rgba(251,191,36,.25);
    }
    .note-text { font-size: .8rem; color: var(--text-muted); }

    /* ── Action Buttons ── */
    .tag-btn {
        display: inline-flex; align-items: center; gap: .3rem;
        padding: .4rem .85rem;
        border-radius: 10px;
        font-size: .76rem; font-weight: 700;
        border: 1.5px solid;
        cursor: pointer;
        transition: all .22s cubic-bezier(0.16, 1, 0.3, 1);
        white-space: nowrap;
        position: relative; overflow: hidden;
    }
    .tag-btn::after {
        content: '';
        position: absolute; inset: 0;
        background: rgba(255,255,255,0.15);
        transform: translateX(-100%);
        transition: transform .3s ease;
    }
    .tag-btn:hover::after { transform: translateX(0); }
    .tag-btn:active { transform: scale(0.95) !important; }
    .tag-btn-edit {
        background: rgba(245,158,11,.07);
        border-color: rgba(245,158,11,.2);
        color: #d97706;
    }
    .tag-btn-edit:hover {
        background: #d97706; border-color: #d97706; color: #fff;
        box-shadow: 0 4px 16px rgba(245,158,11,.4);
        transform: translateY(-2px);
    }
    .tag-btn-delete {
        background: rgba(239,68,68,.07);
        border-color: rgba(239,68,68,.2);
        color: #dc2626;
    }
    .tag-btn-delete:hover {
        background: #dc2626; border-color: #dc2626; color: #fff;
        box-shadow: 0 4px 16px rgba(239,68,68,.4);
        transform: translateY(-2px);
    }

    /* ── Row shimmer ── */
    @@keyframes rowShimmer { 0% { left: -75%; } 100% { left: 120%; } }
    .tag-tbody tr .row-shimmer {
        position: absolute; top: 0; bottom: 0; width: 50%;
        background: linear-gradient(90deg, transparent, rgba(245,158,11,0.04), transparent);
        pointer-events: none; display: none;
    }
    .tag-tbody tr:hover .row-shimmer { display: block; animation: rowShimmer 1.2s ease-in-out; }

    /* ── Table wrapper ── */
    .tag-table-wrap { border-radius: 0 0 20px 20px; overflow: hidden; border-top: none; }

    /* ── Empty State ── */
    .fnts-empty { text-align: center; padding: 4rem 2rem; display: flex; flex-direction: column; align-items: center; gap: .6rem; }
    .fnts-empty-icon { width: 64px; height: 64px; border-radius: 50%; background: rgba(245,158,11,.06); display: flex; align-items: center; justify-content: center; }
    [data-bs-theme="dark"] .fnts-empty-icon { background: rgba(245,158,11,.1); }
    .fnts-empty h6 { font-weight: 700; color: var(--text-muted); margin: 0; }
    .fnts-empty p   { color: var(--text-muted); font-size: .85rem; margin: 0; }
</style>

<div class="page-header">
    <div>
        <h2>
            <i class="bi bi-tags-fill me-2"
               style="background:var(--brand-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent"></i>
            Tag Management
        </h2>
        <p class="text-muted mb-0">Manage stock ticker symbols used to label and filter trading news.</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <span class="tag-stat-pill">
            <i class="bi bi-hash"></i>@totalTags tags total
        </span>
        <button class="btn fintech-btn-primary" onclick="openCreateModal()">
            <i class="bi bi-plus-circle me-1"></i>Add Tag
        </button>
    </div>
</div>

<!-- ── Premium Table Card ── -->
<div class="tag-table-card">
    <!-- Gradient Header -->
    <div class="tag-table-header">
        <div class="tag-table-header-title">
            <i class="bi bi-tags-fill"></i>
            All Tags
        </div>
        <span class="tag-table-header-count">@totalTags tags</span>
    </div>

    <div class="tag-table-wrap">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="tagTableBody">
                <thead class="tag-thead">
                    <tr>
                        <th>
                            <div class="th-inner"><span class="th-icon"><i class="bi bi-hash"></i></span>#</div>
                        </th>
                        <th>
                            <div class="th-inner"><span class="th-icon"><i class="bi bi-tag"></i></span>Tag / Ticker</div>
                        </th>
                        <th>
                            <div class="th-inner"><span class="th-icon"><i class="bi bi-card-text"></i></span>Note</div>
                        </th>
                        <th class="text-end">
                            <div class="th-inner justify-content-end"><span class="th-icon"><i class="bi bi-gear"></i></span>Actions</div>
                        </th>
                    </tr>
                </thead>
                <tbody class="tag-tbody">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4">
                                <div class="fnts-empty">
                                    <div class="fnts-empty-icon">
                                        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:#fbbf24;opacity:.6">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z"/>
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z"/>
                                        </svg>
                                    </div>
                                    <h6>No tags yet</h6>
                                    <p>Click "Add Tag" to create the first ticker symbol.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="row-num">@item.TagID</td>
                                <td><span class="tag-chip"><i class="bi bi-hash"></i>@item.TagName</span></td>
                                <td><span class="note-text">@(item.Note ?? "—")</span></td>
                                <td class="text-end">
                                    <a class="tag-btn tag-btn-edit me-1" onclick="openEditModal(@item.TagID)">
                                        <i class="bi bi-pencil"></i>Edit
                                    </a>
                                    <a class="tag-btn tag-btn-delete"
                                       onclick="deleteTag(@item.TagID, '@item.TagName')"
                                       data-entity-name="@item.TagName"
                                       data-delete-url="/Staff/Tags/Delete/@item.TagID"
                                       data-bs-toggle="modal"
                                       data-bs-target="#confirmDeleteModal">
                                        <i class="bi bi-trash"></i>Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Pagination Controls -->
@await Html.PartialAsync("_Pagination", Model)

<form id="ajax-antiforgery">@Html.AntiForgeryToken()</form>

<div class="modal fade" id="tagCrudModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="modalTitle" class="modal-title"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div id="modalBodyContainer" class="modal-body"></div>
            <div class="modal-footer">
                <button type="button" class="btn fintech-btn-outline" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnSaveTag" class="btn fintech-btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#dc2626,#ef4444);border:none">
                <h5 class="modal-title text-white">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="deleteMessage" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn fintech-btn-outline" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </div>
        </div>
    </div>
</div>

<script src="~/js/tags.js"></script>

<partial name="_ConfirmDeleteModal" />
