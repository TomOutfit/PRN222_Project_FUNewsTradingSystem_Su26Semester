@using X.PagedList;
@using X.PagedList.Mvc.Core;
@using FUNewsTradingSystem_DataAccessLayer.Models;
@model IPagedList<FUNewsTradingSystem_MVC.ViewModels.Report.ReportListItemViewModel>

@{
    ViewData["Title"] = "Trading Analysis Reports";
    var categories = ViewBag.Categories as IEnumerable<Category> ?? new List<Category>();
    var tags = ViewBag.Tags as IEnumerable<Tag> ?? new List<Tag>();
    int? selectedCategory = ViewBag.SelectedCategory as int?;
    int? selectedTag = ViewBag.SelectedTag as int?;
    string selectedDecision = ViewBag.SelectedDecision as string ?? "";
    bool savedOnly = ViewBag.SavedOnly == true;

    // Markdown → HTML renderer (supports bold, italic, inline code, headers, lists, tables)
    string RenderMd(string? md)
    {
        if (string.IsNullOrEmpty(md)) return "";
        
        // Normalize tables
        var text = System.Text.RegularExpressions.Regex.Replace(
            md, @"^([^|\n]+?)(\|(?:[^|\n]+\|)+)\s*$", "$1\n$2",
            System.Text.RegularExpressions.RegexOptions.Multiline);
        text = System.Text.RegularExpressions.Regex.Replace(text, @"(\|)[ \t]+(\|)", "$1\n$2");

        // Bold + italic + inline code
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*\*(.+?)\*\*\*", "<strong><em>$1</em></strong>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*([^\n*]+?)\*", "<em>$1</em>");
        text = System.Text.RegularExpressions.Regex.Replace(text, @"`([^`]+)`", "<code style='background:rgba(0,0,0,0.06);padding:.1em .3em;border-radius:4px;font-size:.85em;'>$1</code>");

        var lines = text.Split('\n');
        var sb = new System.Text.StringBuilder();
        bool inTable = false, inList = false, firstTableRow = true;

        foreach (var rawLine in lines)
        {
            var ln = rawLine.TrimEnd();

            // Table row
            if (ln.StartsWith('|') && ln.EndsWith('|'))
            {
                var cells = ln.Split('|');
                var cols = new System.Collections.Generic.List<string>();
                for (int ci = 1; ci < cells.Length - 1; ci++) cols.Add(cells[ci].Trim());
                bool isSep = cols.TrueForAll(c => System.Text.RegularExpressions.Regex.IsMatch(c, @"^:?-+:?$"));
                if (!inTable)
                {
                    sb.Append("<div class='table-responsive my-3'><table class='table table-sm table-bordered align-middle' style='font-size:.82rem;'>");
                    inTable = true; firstTableRow = true;
                }
                if (isSep) { if (firstTableRow) { sb.Append("</thead><tbody>"); firstTableRow = false; } continue; }
                if (firstTableRow) { sb.Append("<thead class='table-dark'><tr>"); foreach (var c in cols) sb.Append($"<th>{c}</th>"); sb.Append("</tr>"); }
                else               { sb.Append("<tr>"); foreach (var c in cols) sb.Append($"<td>{c}</td>"); sb.Append("</tr>"); }
                continue;
            }
            if (inTable) { sb.Append("</tbody></table></div>"); inTable = false; }

            // Unordered list
            if (System.Text.RegularExpressions.Regex.IsMatch(ln, @"^[-*] "))
            {
                if (!inList) { sb.Append("<ul class='mb-2 ps-4'>"); inList = true; }
                sb.Append($"<li class='mb-1'>{ln.Substring(2)}</li>");
                continue;
            }
            // Ordered list
            if (System.Text.RegularExpressions.Regex.IsMatch(ln, @"^\d+\.\s+"))
            {
                var content = System.Text.RegularExpressions.Regex.Replace(ln, @"^\d+\.\s+", "");
                if (!inList) { sb.Append("<ol class='mb-2 ps-4'>"); inList = true; }
                sb.Append($"<li class='mb-1'>{content}</li>");
                continue;
            }
            if (inList) { sb.Append("</ul>"); inList = false; }

            // Headers
            if (ln.StartsWith("### ")) { sb.Append($"<h6 class='fw-semibold mt-2 mb-1' style='font-size:.9rem'>{ln.Substring(4)}</h6>"); continue; }
            if (ln.StartsWith("## "))  { sb.Append($"<h5 class='fw-bold mt-3 mb-2'>{ln.Substring(3)}</h5>"); continue; }
            if (ln.StartsWith("# "))   { sb.Append($"<h4 class='fw-bold mt-3 mb-2'>{ln.Substring(2)}</h4>"); continue; }

            // Paragraph / blank
            if (string.IsNullOrWhiteSpace(ln))
            {
                sb.Append("<br>");
            }
            else
            {
                sb.Append($"<p class='mb-2' style='line-height:1.65'>{ln}</p>");
            }
        }
        if (inTable) sb.Append("</tbody></table></div>");
        if (inList)  sb.Append("</ul>");
        return sb.ToString();
    }

    string GetTagColor(string tag, int index = 0)
    {
        var tagColors = new[] {
            (bg: "rgba(14, 165, 233, 0.12)", border: "rgba(14, 165, 233, 0.3)", text: "#0284c7"), // Cyan
            (bg: "rgba(139, 92, 246, 0.12)", border: "rgba(139, 92, 246, 0.3)", text: "#7c3aed"), // Purple
            (bg: "rgba(16, 185, 129, 0.12)", border: "rgba(16, 185, 129, 0.3)", text: "#059669"), // Green
            (bg: "rgba(249, 115, 22, 0.12)", border: "rgba(249, 115, 22, 0.3)", text: "#ea580c"), // Orange
            (bg: "rgba(236, 72, 153, 0.12)", border: "rgba(236, 72, 153, 0.3)", text: "#db2777"), // Pink
            (bg: "rgba(234, 179, 8, 0.15)",  border: "rgba(234, 179, 8, 0.35)", text: "#b45309"), // Amber
            (bg: "rgba(20, 184, 166, 0.12)", border: "rgba(20, 184, 166, 0.3)", text: "#0d9488"), // Teal
            (bg: "rgba(99, 102, 241, 0.12)", border: "rgba(99, 102, 241, 0.3)", text: "#4f46e5")  // Indigo
        };
        int hash = Math.Abs((tag ?? "").GetHashCode() + index);
        var c = tagColors[hash % tagColors.Length];
        return $"background:{c.bg}; border:1px solid {c.border}; color:{c.text};";
    }
}

<style>
    .filter-card {
        background: var(--surface-card);
        border-radius: 16px;
        border: 1px solid var(--border);
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
        box-shadow: var(--shadow-sm);
    }
    .filter-card .form-label {
        font-size: .78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-muted);
    }
</style>

<div class="container px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1"><i class="bi bi-newspaper me-2" style="background:linear-gradient(135deg,#0284c7,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent"></i>Trading Analysis Reports</h2>
            <p class="text-muted mb-0">Latest AI-generated market analysis and investment recommendations</p>
        </div>
    </div>

    <!-- Search & Filter Card -->
    <div class="filter-card fintech-card">
        <form method="get" asp-controller="Report" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label"><i class="bi bi-folder2 me-1"></i>Sector (Category)</label>
                    <select name="categoryId" class="form-select fintech-form-control">
                        <option value="">All Sectors</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryID" selected="@(selectedCategory == cat.CategoryID ? "selected" : null)">
                                @cat.CategoryName
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="bi bi-hash me-1"></i>Ticker (Tag)</label>
                    <select name="tagId" class="form-select fintech-form-control">
                        <option value="">All Tickers</option>
                        @foreach (var tag in tags)
                        {
                            <option value="@tag.TagID" selected="@(selectedTag == tag.TagID ? "selected" : null)">
                                @tag.TagName
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label"><i class="bi bi-compass me-1"></i>Decision Type</label>
                    <select name="decision" class="form-select fintech-form-control">
                        <option value="">All Decisions</option>
                        <option value="BUY" selected="@(selectedDecision == "BUY" ? "selected" : null)">BUY 🚀</option>
                        <option value="SELL" selected="@(selectedDecision == "SELL" ? "selected" : null)">SELL 📉</option>
                        <option value="HOLD" selected="@(selectedDecision == "HOLD" ? "selected" : null)">HOLD ⚖️</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn fintech-btn-primary flex-grow-1">
                        <i class="bi bi-funnel-fill me-1"></i>Filter
                    </button>
                    <a asp-controller="Report" asp-action="Index" class="btn fintech-btn-outline d-flex align-items-center justify-content-center px-3">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </div>

            @if (User.Identity!.IsAuthenticated)
            {
                <div class="mt-3 pt-3" style="border-top: 1px solid var(--border);">
                    <div class="form-check form-switch mb-0 d-flex align-items-center gap-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="savedOnlyToggle"
                               style="width: 2.5em; height: 1.25em; cursor: pointer;"
                               @(savedOnly ? "checked" : "")
                               onchange="document.getElementById('savedOnlyHidden').value = this.checked ? 'true' : 'false'; this.form.submit();">
                        <input type="hidden" id="savedOnlyHidden" name="savedOnly" value="@(savedOnly ? "true" : "false")" />
                        <label class="form-check-label mb-0" for="savedOnlyToggle"
                               style="cursor: pointer; font-size: .85rem; font-weight: 600; color: @(savedOnly ? "#059669" : "var(--text-muted)")">
                            <i class="bi bi-bookmark-fill me-1"></i>Show Saved Only
                        </label>
                        @if (savedOnly)
                        {
                            <span class="badge" style="background: rgba(16,185,129,.12); color: #059669; border: 1px solid rgba(16,185,129,.25); font-size: .72rem; padding: .3em .6em; border-radius: 8px;">
                                <i class="bi bi-check-circle me-1"></i>Active
                            </span>
                        }
                    </div>
                </div>
            }
        </form>
    </div>

    <!-- Real-time Notification Banner -->
    <div id="realtimeNotify" class="alert alert-info alert-dismissible fade show d-none mb-3 shadow-sm" role="alert" style="border-left: 4px solid var(--accent); border-radius: 12px; background: rgba(56, 189, 248, 0.08);">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div class="d-flex align-items-center">
                <i class="bi bi-bell-fill text-primary me-2 animate-bounce"></i>
                <span id="realtimeNotifyTitle" class="text-main">New report generated!</span>
            </div>
            <div>
                <a href="" id="realtimeNotifyLink" class="btn btn-primary btn-sm rounded-pill px-3 py-1">
                    <i class="bi bi-file-text me-1"></i>View Report
                </a>
                <button type="button" class="btn-close position-relative ms-2" style="top: auto; right: auto; padding: 0.5rem;" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card p-5 text-center my-4">
            <div style="font-size:3.5rem;opacity:.3" class="mb-3">📭</div>
            <h5 class="text-muted">No reports matching your criteria</h5>
            <p class="text-muted small mb-0">Try adjusting your filters or search terms.</p>
        </div>
    }
    else
    {
        <div class="pagination-content">
            @foreach (var item in Model)
            {
                string badgeClass = item.Decision switch
                {
                    "BUY" => "fintech-badge-buy",
                    "SELL" => "fintech-badge-sell",
                    _ => "fintech-badge-hold"
                };

                <div class="card fintech-card mb-3 border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge @badgeClass" style="font-size:.85rem;padding:.4em .8em">
                                <i class="bi bi-lightning-charge-fill me-1"></i>
                                @item.Decision
                            </span>
                            <small class="text-muted">
                                <i class="bi bi-calendar-event me-1"></i>
                                @item.CreatedDate.ToString("MMM dd, yyyy HH:mm")
                            </small>
                        </div>

                        <h5 class="card-title fw-bold mt-2">
                            <a asp-controller="Report" asp-action="Detail"
                               asp-route-id="@item.NewsArticleId"
                               class="text-decoration-none"
                               style="color:inherit;transition:color .15s;"
                               onmouseover="this.style.color='var(--accent)'"
                               onmouseout="this.style.color='inherit'">@item.NewsTitle</a>
                        </h5>

                        <div class="card-text text-muted mb-3">
                            @Html.Raw(RenderMd(item.Headline))
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                <span class="badge bg-secondary">
                                    <i class="bi bi-folder2 me-1"></i>@item.CategoryName
                                </span>
                                @{
                                    bool isMultiAgent = item.NewsSource.Contains("TradingAgents");
                                }
                                <span class="badge" style="background:@(isMultiAgent ? "rgba(124,58,237,.15)" : "rgba(37,99,235,.12)");color:@(isMultiAgent ? "#7c3aed" : "#2563eb");border:1px solid @(isMultiAgent ? "rgba(124,58,237,.3)" : "rgba(37,99,235,.25)");font-size:.72rem;">
                                    <i class="bi @(isMultiAgent ? "bi-cpu-fill" : "bi-robot") me-1"></i>@(isMultiAgent ? "Multi-Agent" : "Classic")
                                </span>
                                @{
                                    var tagList = item.TagNames.ToList();
                                }
                                @for (int ti = 0; ti < tagList.Count; ti++)
                                {
                                    var tag = tagList[ti];
                                    <span class="badge" style="@GetTagColor(tag, ti) font-size:.72rem;">
                                        <i class="bi bi-hash"></i>@tag
                                    </span>
                                }
                            </div>
                            <a asp-controller="Report" asp-action="Detail"
                               asp-route-id="@item.NewsArticleId"
                               class="btn fintech-btn-outline btn-sm">
                                <i class="bi bi-arrow-right me-1"></i>Read Analysis
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination Controls -->
        @await Html.PartialAsync("_Pagination", Model)
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function() {
            var connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/reports")
                .configureLogging(signalR.LogLevel.Warning)
                .build();

            connection.on("ReceiveNewReport", function (report) {
                var notifyBanner = document.getElementById('realtimeNotify');
                var notifyTitle = document.getElementById('realtimeNotifyTitle');
                var notifyLink = document.getElementById('realtimeNotifyLink');
                
                if (notifyBanner && notifyTitle && notifyLink) {
                    notifyTitle.innerHTML = 'New automated analysis for <strong>' + report.tagName + '</strong> is now available!';
                    notifyLink.href = '/Report/Detail/' + report.newsArticleId;
                    notifyLink.innerHTML = '<i class="bi bi-file-text me-1"></i>View Report';
                    notifyBanner.classList.remove('d-none');
                }
            });

            connection.start().catch(function (err) {
                console.error("SignalR failed to start: ", err);
            });
        })();
    </script>
}