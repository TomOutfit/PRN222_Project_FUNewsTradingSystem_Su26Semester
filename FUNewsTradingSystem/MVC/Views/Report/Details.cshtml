@model FUNewsTradingSystem_MVC.ViewModels.Report.ReportDetailViewModel

@{
    ViewData["Title"] = Model.NewsTitle ?? "Report Detail";

    string badgeClass = Model.Decision switch
    {
        "BUY" => "bg-success",
        "SELL" => "bg-danger",
        _ => "bg-secondary"
    };
    string decisionIcon = Model.Decision switch
    {
        "BUY" => "bi-graph-up-arrow",
        "SELL" => "bi-graph-down-arrow",
        _ => "bi-dash-circle"
    };
}

<div class="container px-0" style="max-width: 900px;">
    <!-- Navigation Back Button -->
    <div class="mb-4">
        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">
            <i class="bi bi-arrow-left me-1"></i> Back to Analysis Reports
        </a>
    </div>

    <!-- Header Section -->
    <div class="card shadow-sm border-0 mb-4 overflow-hidden">
        <div class="card-body p-4 p-md-5">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
                <span class="badge @badgeClass fs-6 px-3 py-2 rounded-pill shadow-sm">
                    <i class="bi @decisionIcon me-1"></i> RECOMMENDATION: @Model.Decision
                </span>
                <div class="text-muted small">
                    <i class="bi bi-calendar-event me-1"></i> Published: @Model.CreatedDate.ToString("MMM dd, yyyy HH:mm") UTC
                </div>
            </div>

            <h1 class="fw-bold mb-3" style="font-size: 2rem; line-height: 1.3;">@Model.NewsTitle</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Headline))
            {
                <div class="p-3 bg-light rounded-3 border-start border-4 border-primary mb-4">
                    <p class="mb-0 text-secondary lead" style="font-size: 1.1rem;">
                        <i class="bi bi-quote me-2 fs-4 text-primary align-middle"></i>@Model.Headline
                    </p>
                </div>
            }

            <div class="d-flex flex-wrap gap-2 align-items-center border-top pt-3 mt-4">
                <div class="me-3">
                    <span class="text-muted small d-block">Sector / Category:</span>
                    <span class="badge bg-secondary px-2 py-1"><i class="bi bi-folder2 me-1"></i>@Model.CategoryName</span>
                </div>

                @if (Model.Tags != null && Model.Tags.Any())
                {
                    <div>
                        <span class="text-muted small d-block">Related Tickers:</span>
                        <div class="d-flex gap-1 flex-wrap">
                            @foreach (var tag in Model.Tags)
                            {
                                <span class="badge bg-light text-dark border px-2 py-1"><i class="bi bi-hash"></i>@tag</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Main Content Breakdown -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-transparent border-0 pt-4 px-4 px-md-5 pb-0">
            <h4 class="fw-bold m-0"><i class="bi bi-file-text me-2 text-primary"></i>Detailed Analysis Breakdown</h4>
        </div>
        <div class="card-body p-4 p-md-5">
            @if (!string.IsNullOrWhiteSpace(Model.NewsContent))
            {
                var paragraphs = Model.NewsContent.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                foreach (var para in paragraphs)
                {
                    <p class="fs-6 text-dark lh-base mb-3" style="text-align: justify;">@para</p>
                }
            }
            else
            {
                <p class="text-muted fst-italic">No detailed content available for this report.</p>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.NewsSource))
        {
            <div class="card-footer bg-light border-0 px-4 px-md-5 py-3 d-flex justify-content-between align-items-center">
                <span class="small text-muted"><i class="bi bi-info-circle me-1"></i> Data Source & Engine:</span>
                <span class="badge bg-white text-dark border small">@Model.NewsSource</span>
            </div>
        }
    </div>
</div>
