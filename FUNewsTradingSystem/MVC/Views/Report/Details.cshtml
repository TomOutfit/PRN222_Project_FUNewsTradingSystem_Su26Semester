@model FUNewsTradingSystem_MVC.ViewModels.Report.ReportDetailViewModel

@{
    ViewData["Title"] = Model.NewsTitle ?? "Report Detail";

    // Style variables depending on recommendation
    string recGradient = Model.Decision switch
    {
        "BUY" => "linear-gradient(135deg, #10b981 0%, #047857 100%)",
        "SELL" => "linear-gradient(135deg, #f43f5e 0%, #be123c 100%)",
        _ => "linear-gradient(135deg, #f59e0b 0%, #b45309 100%)"
    };

    string recShadow = Model.Decision switch
    {
        "BUY" => "rgba(16, 185, 129, 0.3)",
        "SELL" => "rgba(244, 63, 94, 0.3)",
        _ => "rgba(245, 158, 11, 0.3)"
    };

    string recShadowPulse = Model.Decision switch
    {
        "BUY" => "rgba(16, 185, 129, 0.4)",
        "SELL" => "rgba(244, 63, 94, 0.4)",
        _ => "rgba(245, 158, 11, 0.4)"
    };

    string sectionColor = Model.Decision switch
    {
        "BUY" => "#10b981",
        "SELL" => "#f43f5e",
        _ => "#f59e0b"
    };

    string decisionIcon = Model.Decision switch
    {
        "BUY" => "bi-graph-up-arrow",
        "SELL" => "bi-graph-down-arrow",
        _ => "bi-dash-circle-fill"
    };

    // Parsing structured AI trading reports if matching pattern
    string sentimentContent = "";
    string fundamentalContent = "";
    string riskContent = "";
    bool isParsed = false;

    if (!string.IsNullOrWhiteSpace(Model.NewsContent))
    {
        var content = Model.NewsContent;
        int sIndex = content.IndexOf("(1) ");
        int fIndex = content.IndexOf("(2) ");
        int rIndex = content.IndexOf("(3) ");

        if (sIndex >= 0 && fIndex > sIndex && rIndex > fIndex)
        {
            sentimentContent = content.Substring(sIndex + 4, fIndex - (sIndex + 4)).Trim();
            fundamentalContent = content.Substring(fIndex + 4, rIndex - (fIndex + 4)).Trim();
            riskContent = content.Substring(rIndex + 4).Trim();
            isParsed = true;
        }
    }
}

<style>
    :root {
        --rec-gradient: @recGradient;
        --rec-shadow: @recShadow;
        --rec-shadow-pulse: @recShadowPulse;
        --section-color: @sectionColor;
    }

    .report-detail-container {
        animation: pageEnter 0.40s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .recommendation-card {
        background: var(--rec-gradient);
        color: #fff;
        border: none;
        box-shadow: 0 10px 30px var(--rec-shadow);
        position: relative;
        overflow: hidden;
        border-radius: var(--radius-lg);
        transition: transform var(--transition);
    }
    .recommendation-card:hover {
        transform: translateY(-2px);
    }

    .recommendation-card::before {
        content: "";
        position: absolute;
        top: -40%;
        right: -20%;
        width: 180px;
        height: 180px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
    }

    .recommendation-card::after {
        content: "";
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 120px;
        height: 120px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
    }

    .analysis-section-card {
        border-left: 5px solid var(--section-color);
        background: var(--surface-card);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        transition: transform var(--transition), box-shadow var(--transition);
        border-top: 1px solid var(--border-light);
        border-right: 1px solid var(--border-light);
        border-bottom: 1px solid var(--border-light);
    }

    .analysis-section-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-md);
    }

    .ticker-pill {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 30px;
        color: var(--text-main);
        padding: 0.35rem 0.85rem;
        font-weight: 600;
        font-size: 0.825rem;
        transition: all var(--transition);
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .ticker-pill:hover {
        border-color: var(--brand-1);
        background: rgba(37, 99, 235, 0.08);
        color: var(--brand-1);
        transform: translateY(-1px);
    }

    .author-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.9rem;
        border-radius: 30px;
        background: var(--surface);
        border: 1px solid var(--border);
        font-weight: 500;
        font-size: 0.875rem;
    }

    .deleted-author {
        background: rgba(239, 68, 68, 0.08);
        border-color: rgba(239, 68, 68, 0.2);
        color: #ef4444 !important;
    }

    .pulse-badge {
        position: relative;
    }
    .pulse-badge::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 30px;
        box-shadow: 0 0 0 0 var(--rec-shadow-pulse);
        animation: badgePulse 2s infinite;
    }
    @@keyframes badgePulse {
        0% {
            box-shadow: 0 0 0 0 var(--rec-shadow-pulse);
        }
        70% {
            box-shadow: 0 0 0 8px rgba(0, 0, 0, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(0, 0, 0, 0);
        }
    }

    .back-btn {
        transition: all var(--transition);
    }
    .back-btn:hover {
        transform: translateX(-4px);
    }
</style>

<div class="container px-0 report-detail-container">
    <!-- Navigation Back Button -->
    <div class="mb-4">
        <a asp-controller="Report" asp-action="Index" class="btn fintech-btn-outline btn-sm rounded-pill px-3 back-btn">
            <i class="bi bi-arrow-left me-1"></i> Back to Analysis Reports
        </a>
    </div>

    <!-- Main Grid Layout -->
    <div class="row g-4">
        <!-- LEFT: Main Article details -->
        <div class="col-lg-8">
            <article class="card fintech-card p-4 p-md-5 mb-4 border-0">
                <!-- Title Header -->
                <header class="mb-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-primary px-3 py-1.5"><i class="bi bi-folder2 me-1"></i>@Model.CategoryName</span>
                        <time class="text-muted small" datetime="@Model.CreatedDate.ToString("o")">
                            <i class="bi bi-calendar-event me-1"></i>@Model.CreatedDate.ToString("MMM dd, yyyy HH:mm") UTC
                        </time>
                    </div>
                    <h1 class="fw-bold mb-3 text-main" style="font-size: 2.25rem; line-height: 1.25; letter-spacing: -0.5px;">
                        @Model.NewsTitle
                    </h1>
                </header>

                <!-- Headline blockquote -->
                @if (!string.IsNullOrWhiteSpace(Model.Headline))
                {
                    <div class="p-3 bg-light bg-opacity-50 rounded-3 border-start border-4 border-primary mb-4">
                        <p class="mb-0 text-muted fst-italic lead" style="font-size: 1.05rem;">
                            <i class="bi bi-quote me-2 fs-3 text-primary align-middle opacity-50"></i>@Model.Headline
                        </p>
                    </div>
                }

                <hr class="my-4 opacity-50">

                <!-- Content Area -->
                <section class="content-body">
                    @if (isParsed)
                    {
                        <!-- Dynamic Beautiful Sections for Automated Trading Reports -->
                        <div class="d-flex flex-column gap-4">
                            <!-- 1. Sentiment View -->
                            <div class="analysis-section-card p-4">
                                <h4 class="fw-bold text-main d-flex align-items-center gap-2 mb-3" style="font-size: 1.15rem;">
                                    <span class="d-inline-flex align-items-center justify-content-center bg-success bg-opacity-10 text-success rounded-circle" style="width: 32px; height: 32px;">
                                        <i class="bi bi-chat-left-heart-fill"></i>
                                    </span>
                                    Market Sentiment View
                                </h4>
                                <p class="mb-0 text-main" style="text-align: justify; line-height: 1.6;">
                                    @sentimentContent
                                </p>
                            </div>

                            <!-- 2. Fundamental View -->
                            <div class="analysis-section-card p-4" style="--section-color: var(--accent);">
                                <h4 class="fw-bold text-main d-flex align-items-center gap-2 mb-3" style="font-size: 1.15rem;">
                                    <span class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle" style="width: 32px; height: 32px;">
                                        <i class="bi bi-bar-chart-steps"></i>
                                    </span>
                                    Fundamental Indicators
                                </h4>
                                <p class="mb-0 text-main" style="text-align: justify; line-height: 1.6;">
                                    @fundamentalContent
                                </p>
                            </div>

                            <!-- 3. Risk Warning View -->
                            <div class="analysis-section-card p-4" style="--section-color: #ef4444;">
                                <h4 class="fw-bold text-main d-flex align-items-center gap-2 mb-3" style="font-size: 1.15rem;">
                                    <span class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 text-danger rounded-circle" style="width: 32px; height: 32px;">
                                        <i class="bi bi-shield-exclamation"></i>
                                    </span>
                                    Key Risk Warnings
                                </h4>
                                <p class="mb-0 text-main" style="text-align: justify; line-height: 1.6;">
                                    @riskContent
                                </p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Fallback normal paragraph rendering -->
                        @if (!string.IsNullOrWhiteSpace(Model.NewsContent))
                        {
                            var paragraphs = Model.NewsContent.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                            foreach (var para in paragraphs)
                            {
                                <p class="text-main lh-lg mb-3" style="text-align: justify; font-size: 1rem;">@para</p>
                            }
                        }
                        else
                        {
                            <p class="text-muted fst-italic">No detailed content available for this report.</p>
                        }
                    }
                </section>

                <!-- Data Source / Footer -->
                @if (!string.IsNullOrWhiteSpace(Model.NewsSource))
                {
                    <footer class="mt-5 pt-3 border-top d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <span class="small text-muted"><i class="bi bi-cpu me-1"></i> Synthesis Engine & Source:</span>
                        <span class="badge bg-light text-dark border px-3 py-2">@Model.NewsSource</span>
                    </footer>
                }
            </article>

            <!-- Price Chart Card -->
            <div class="card fintech-card p-4 p-md-5 mb-4 border-0">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                    <h4 class="fw-bold m-0 text-main" style="font-size: 1.25rem;">
                        <i class="bi bi-activity text-primary me-2"></i>
                        @(Model.Tags != null && Model.Tags.Any() ? $"{Model.Tags.First()} Price Trend" : "FNTS Index Composite Trend")
                    </h4>
                    <span class="badge @(Model.Decision == "BUY" ? "fintech-badge-buy" : Model.Decision == "SELL" ? "fintech-badge-sell" : "fintech-badge-hold") px-3 py-1">
                        Signal: @Model.Decision
                    </span>
                </div>
                <div style="height: 280px; position: relative;">
                    <canvas id="tradingChart"></canvas>
                </div>
                <div class="text-muted small mt-3">
                    <i class="bi bi-info-circle me-1"></i> Market trend data powered by Yahoo Finance API proxy.
                </div>
            </div>
        </div>

        <!-- RIGHT: Recommendation & Metadata Sidebar -->
        <div class="col-lg-4">
            <aside class="d-flex flex-column gap-4">
                <!-- Action Recommendation Card -->
                <div class="card recommendation-card p-4 shadow">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-uppercase fw-bold tracking-wider small opacity-75">Analysis Signal</span>
                        <span class="pulse-badge"></span>
                    </div>
                    <div class="d-flex align-items-center gap-3 my-2">
                        <i class="bi @decisionIcon display-4"></i>
                        <div>
                            <h2 class="m-0 fw-extrabold display-6 text-white">@Model.Decision</h2>
                            <p class="m-0 small opacity-75">Recommended Action</p>
                        </div>
                    </div>
                </div>

                <!-- Metadata / Author info Card -->
                <div class="card fintech-card p-4 border-0">
                    <h5 class="fw-bold mb-3 text-main"><i class="bi bi-info-circle-fill me-2 text-primary"></i>Report Information</h5>

                    <!-- Author -->
                    <div class="mb-3">
                        <span class="text-muted small d-block mb-1">Author / Publisher:</span>
                        @if (string.IsNullOrEmpty(Model.CreatedByName) || Model.CreatedByName == "Deleted User")
                        {
                            <span class="author-badge deleted-author">
                                <i class="bi bi-trash-fill"></i> Deleted Staff
                            </span>
                        }
                        else
                        {
                            <span class="author-badge">
                                <i class="bi bi-person-badge-fill text-primary"></i> @Model.CreatedByName
                            </span>
                        }
                    </div>

                    <!-- Category -->
                    <div class="mb-3">
                        <span class="text-muted small d-block mb-1">Category Sector:</span>
                        <span class="badge bg-secondary px-3 py-2"><i class="bi bi-folder2 me-1"></i>@Model.CategoryName</span>
                    </div>

                    <!-- Timestamps -->
                    @if (Model.ModifiedDate.HasValue)
                    {
                        <div class="mb-3">
                            <span class="text-muted small d-block mb-1">Last Updated:</span>
                            <span class="text-secondary small"><i class="bi bi-clock-history me-1"></i>@Model.ModifiedDate.Value.ToString("MMM dd, yyyy HH:mm") UTC</span>
                        </div>
                    }
                </div>

                <!-- Related Tickers / Tags -->
                @if (Model.Tags != null && Model.Tags.Any())
                {
                    <div class="card fintech-card p-4 border-0">
                        <h5 class="fw-bold mb-3 text-main"><i class="bi bi-tags-fill me-2 text-primary"></i>Analyzed Assets</h5>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var tag in Model.Tags)
                            {
                                <span class="ticker-pill">
                                    <i class="bi bi-hash text-muted"></i>@tag
                                </span>
                            }
                        </div>
                    </div>
                }
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        (function() {
            const ctx = document.getElementById('tradingChart');
            if (!ctx) return;

            const decision = "@Model.Decision";
            const ticker = "@(Model.Tags != null && Model.Tags.Any() ? Model.Tags.First() : "FNTS")";

            let chartInstance = null;

            function getChartColors(isDark) {
                let strokeColor = '#374151';
                let fillColor = 'rgba(55, 65, 81, 0.08)';
                if (decision === "BUY")      { strokeColor = '#10b981'; fillColor = 'rgba(16, 185, 129, 0.08)'; }
                else if (decision === "SELL") { strokeColor = '#ef4444'; fillColor = 'rgba(239, 68, 68, 0.08)'; }
                const gridColor = isDark ? 'rgba(255, 255, 255, 0.06)' : 'rgba(0, 0, 0, 0.05)';
                const textColor = isDark ? '#cbd5e1' : '#64748b';
                return { strokeColor, fillColor, gridColor, textColor };
            }

            function renderChart(labels, data, source) {
                const isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                const { strokeColor, fillColor, gridColor, textColor } = getChartColors(isDark);

                // Update source badge
                const cardHeader = ctx.closest('.card').querySelector('h4');
                if (cardHeader && !cardHeader.querySelector('.source-badge')) {
                    cardHeader.innerHTML += ` <span class="badge bg-secondary bg-opacity-10 text-secondary source-badge" style="font-size:0.7rem;font-weight:500;margin-left:6px;"><i class="bi bi-broadcast me-1"></i>${source}</span>`;
                }

                if (chartInstance) { chartInstance.destroy(); chartInstance = null; }

                chartInstance = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: ticker + ' (USD)',
                            data: data,
                            borderColor: strokeColor,
                            borderWidth: 2.5,
                            fill: true,
                            backgroundColor: fillColor,
                            tension: 0.35,
                            pointRadius: 1.5,
                            pointHoverRadius: 5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: { duration: 0 },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                mode: 'index', intersect: false,
                                backgroundColor: isDark ? '#1e1b4b' : '#ffffff',
                                titleColor: isDark ? '#fff' : '#1e1b4b',
                                bodyColor: isDark ? '#e2e8f0' : '#1e1b4b',
                                borderColor: strokeColor, borderWidth: 1
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: gridColor },
                                ticks: { color: textColor, font: { family: 'Inter', size: 10 }, maxTicksLimit: 8 }
                            },
                            y: {
                                grid: { color: gridColor },
                                ticks: { color: textColor, font: { family: 'Inter', size: 10 } }
                            }
                        }
                    }
                });

                // Re-render chart colors when theme toggles
                const themeObserver = new MutationObserver(() => {
                    const currentDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                    const { strokeColor: sc, fillColor: fc, gridColor: gc, textColor: tc } = getChartColors(currentDark);
                    chartInstance.options.scales.x.grid.color = gc;
                    chartInstance.options.scales.y.grid.color = gc;
                    chartInstance.options.scales.x.ticks.color = tc;
                    chartInstance.options.scales.y.ticks.color = tc;
                    chartInstance.options.plugins.tooltip.backgroundColor = currentDark ? '#1e1b4b' : '#ffffff';
                    chartInstance.options.plugins.tooltip.titleColor = currentDark ? '#fff' : '#1e1b4b';
                    chartInstance.options.plugins.tooltip.bodyColor = currentDark ? '#e2e8f0' : '#1e1b4b';
                    chartInstance.data.datasets[0].borderColor = sc;
                    chartInstance.data.datasets[0].backgroundColor = fc;
                    chartInstance.update();
                });
                themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
            }

            // ── 1. Fetch initial data from MarketDataService (live tick history) ──
            fetch(`/api/market/chart/${encodeURIComponent(ticker)}`)
                .then(response => response.json())
                .then(data => {
                    if (data && data.success && data.prices && data.prices.length > 0) {
                        renderChart(data.labels, data.prices, data.source || 'Live Market Data');
                        initSignalR();
                    } else {
                        throw new Error('No live data available yet.');
                    }
                })
                .catch(() => {
                    // MarketDataService has no history yet (app just started).
                    // Live ticking will build the chart in real-time.
                    const emptyLabels = Array.from({ length: 30 }, () => '');
                    const emptyPrices = Array.from({ length: 30 }, () => null);
                    renderChart(emptyLabels, emptyPrices, 'Awaiting Live Data…');
                    initSignalR();
                });

            // ── 2. SignalR: connect to MarketTickerHub for real-time price updates ──
            function initSignalR() {
                const sourceBadge = document.querySelector('.source-badge');
                if (sourceBadge) sourceBadge.textContent = '⏳ Connecting…';

                const connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/marketTicker')
                    .configureLogging(signalR.LogLevel.Warning)
                    .build();

                connection.on('ReceiveMarketTicks', function(ticks) {
                    const tick = ticks.find(t => t.symbol === ticker);
                    if (!tick || !chartInstance) return;

                    const now = new Date();
                    const label = now.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit', second: '2-digit' });

                    chartInstance.data.labels.push(label);
                    chartInstance.data.datasets[0].data.push(tick.price);

                    // Keep max 120 points visible (~6 min of 3-second ticks)
                    const MAX_POINTS = 120;
                    if (chartInstance.data.datasets[0].data.length > MAX_POINTS) {
                        chartInstance.data.labels.shift();
                        chartInstance.data.datasets[0].data.shift();
                    }

                    chartInstance.update('none');

                    // Update source badge to confirm live
                    const badge = document.querySelector('.source-badge');
                    if (badge && !badge.textContent.includes('Live')) {
                        badge.innerHTML = `<i class="bi bi-broadcast me-1"></i>Live (SignalR)`;
                    }
                });

                connection.start()
                    .then(() => {
                        const badge = document.querySelector('.source-badge');
                        if (badge) badge.innerHTML = `<i class="bi bi-broadcast me-1" style="font-weight:bold"></i>Live Market Data`;
                    })
                    .catch(() => {
                        const badge = document.querySelector('.source-badge');
                        if (badge) badge.innerHTML = `<i class="bi bi-wifi-off me-1"></i>Reconnecting…`;
                    });
            }
        })();
    </script>
}
