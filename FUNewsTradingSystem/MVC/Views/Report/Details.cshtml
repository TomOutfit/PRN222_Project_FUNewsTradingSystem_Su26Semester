@model FUNewsTradingSystem_MVC.ViewModels.Report.ReportDetailViewModel

@{
    ViewData["Title"] = Model.NewsTitle ?? "Report Detail";

    // ── Style variables depending on recommendation ──
    string recGradient = Model.Decision switch
    {
        "BUY" => "linear-gradient(135deg, #10b981 0%, #047857 100%)",
        "SELL" => "linear-gradient(135deg, #f43f5e 0%, #be123c 100%)",
        _ => "linear-gradient(135deg, #f59e0b 0%, #b45309 100%)"
    };

    string recShadow = Model.Decision switch
    {
        "BUY" => "rgba(16, 185, 129, 0.35)",
        "SELL" => "rgba(244, 63, 94, 0.35)",
        _ => "rgba(245, 158, 11, 0.35)"
    };

    string recShadowPulse = Model.Decision switch
    {
        "BUY" => "rgba(16, 185, 129, 0.5)",
        "SELL" => "rgba(244, 63, 94, 0.5)",
        _ => "rgba(245, 158, 11, 0.5)"
    };

    string sectionColor = Model.Decision switch
    {
        "BUY" => "#10b981",
        "SELL" => "#f43f5e",
        _ => "#f59e0b"
    };

    string decisionIcon = Model.Decision switch
    {
        "BUY" => "bi-graph-up-arrow",
        "SELL" => "bi-graph-down-arrow",
        _ => "bi-dash-circle-fill"
    };

    string decisionLabel = Model.Decision switch
    {
        "BUY" => "Strong Buy Signal",
        "SELL" => "Strong Sell Signal",
        _ => "Hold / Neutral"
    };

    // ── Parse structured AI reports ──
    string sentimentContent = "";
    string fundamentalContent = "";
    string riskContent = "";
    bool isParsed = false;

    if (!string.IsNullOrWhiteSpace(Model.NewsContent))
    {
        var content = Model.NewsContent;
        int sIndex = content.IndexOf("(1) ");
        int fIndex = content.IndexOf("(2) ");
        int rIndex = content.IndexOf("(3) ");

        if (sIndex >= 0 && fIndex > sIndex && rIndex > fIndex)
        {
            sentimentContent = content.Substring(sIndex + 4, fIndex - (sIndex + 4)).Trim();
            fundamentalContent = content.Substring(fIndex + 4, rIndex - (fIndex + 4)).Trim();
            riskContent = content.Substring(rIndex + 4).Trim();
            isParsed = true;
        }
    }

    // ── Compute fake key stats for visual richness ──
    var confColor = Model.ConfidenceScore switch
    {
        >= 80 => "#10b981",
        >= 60 => "#f59e0b",
        _ => "#ef4444"
    };
}

<style>
    :root {
        --rec-gradient: @recGradient;
        --rec-shadow: @recShadow;
        --rec-shadow-pulse: @recShadowPulse;
        --section-color: @sectionColor;
        --conf-color: @confColor;
    }

    /* ── Page entrance ── */
    .report-detail-container {
        animation: pageEnter 0.45s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
    @@keyframes pageEnter {
        from { opacity: 0; transform: translateY(18px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Hero Banner ── */
    .report-hero {
        background: var(--rec-gradient);
        border-radius: var(--radius-xl);
        padding: 2.5rem 2.5rem 2rem;
        margin-bottom: 1.75rem;
        position: relative;
        overflow: hidden;
        color: #fff;
        box-shadow: 0 16px 48px var(--rec-shadow);
    }
    .report-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.15);
        pointer-events: none;
        z-index: 0;
    }
    .report-hero::after {
        content: "";
        position: absolute;
        top: -60px; right: -40px;
        width: 280px; height: 280px;
        background: rgba(255,255,255,0.07);
        border-radius: 50%;
        pointer-events: none;
    }
    .report-hero > * { position: relative; z-index: 1; }

    /* Bottom decorative orb */
    .report-hero .hero-orb {
        position: absolute;
        bottom: -50px; left: -20px;
        width: 180px; height: 180px;
        background: rgba(255,255,255,0.05);
        border-radius: 50%;
        pointer-events: none;
        z-index: 0;
    }
    .hero-category-badge {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(0,0,0,0.3);
        border: 1.5px solid rgba(255,255,255,0.5);
        color: #fff;
        padding: .3rem .85rem;
        border-radius: 30px;
        font-size: .8rem;
        font-weight: 700;
        letter-spacing: .04em;
    }
    .hero-title {
        font-size: clamp(1.6rem, 3vw, 2.5rem);
        font-weight: 800;
        line-height: 1.18;
        letter-spacing: -0.5px;
        margin: 1rem 0 .75rem;
        text-shadow: 0 2px 12px rgba(0,0,0,0.25);
    }
    .hero-headline {
        font-size: 1rem;
        font-style: italic;
        color: rgba(255,255,255,0.95);
        border-left: 3px solid rgba(255,255,255,0.7);
        padding-left: .85rem;
        margin: 1.25rem 0;
        line-height: 1.55;
        text-shadow: 0 1px 6px rgba(0,0,0,0.2);
    }
    .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem 1.5rem;
        font-size: .82rem;
        color: rgba(255,255,255,0.95);
        margin-top: 1.25rem;
    }
    .hero-meta-item {
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    /* ── Decision pill inside hero ── */
    .decision-pill {
        display: inline-flex;
        align-items: center;
        gap: .6rem;
        background: rgba(255,255,255,0.95);
        color: #1a1a2e;
        padding: .5rem 1.25rem;
        border-radius: 40px;
        font-weight: 800;
        font-size: .88rem;
        letter-spacing: .04em;
        box-shadow: 0 4px 20px rgba(0,0,0,0.25);
    }
    .decision-pill .bi {
        font-size: 1rem;
        color: var(--section-color);
    }

    /* ── Stats strip ── */
    .stats-strip {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
        gap: 6px;
        background: rgba(0,0,0,0.22);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: var(--radius-md);
        overflow: hidden;
        margin-top: 1.5rem;
    }
    .stat-item {
        background: rgba(0,0,0,0.18);
        padding: .85rem 1rem;
        text-align: center;
    }
    .stat-value {
        display: block;
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: .25rem;
        color: #fff;
    }
    .stat-label {
        display: block;
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: rgba(255,255,255,0.7);
    }
        line-height: 1;
        margin-bottom: .2rem;
    }
    .stat-label {
        display: block;
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .08em;
        opacity: 0.75;
    }

    /* ── Analysis section cards ── */
    .analysis-section-card {
        border-left: 4px solid var(--section-color);
        background: var(--surface-card);
        border-radius: var(--radius-md);
        box-shadow: var(--shadow-sm);
        transition: transform .2s, box-shadow .2s, border-left-color .2s;
        border-top: 1px solid var(--border-light);
        border-right: 1px solid var(--border-light);
        border-bottom: 1px solid var(--border-light);
        overflow: hidden;
    }
    .analysis-section-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }
    .analysis-section-card .section-icon-wrap {
        width: 38px; height: 38px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
    }
    .analysis-section-card .section-body {
        font-size: .95rem;
        line-height: 1.7;
        color: var(--text-main);
    }

    /* ── Chart card enhancements ── */
    .chart-card {
        border: 1px solid var(--border-light);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition: box-shadow .25s;
    }
    .chart-card:hover {
        box-shadow: var(--shadow-md);
    }
    .chart-header {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid var(--border-light);
        background: var(--surface-card);
    }
    .chart-body {
        padding: 1.25rem;
        background: var(--surface-card);
    }
    .chart-footer {
        padding: .75rem 1.5rem;
        border-top: 1px solid var(--border-light);
        background: rgba(0,0,0,.02);
        font-size: .75rem;
        color: var(--text-muted);
    }

    /* ── Metadata sidebar cards ── */
    .meta-card {
        border: 1px solid var(--border-light);
        border-radius: var(--radius-md);
        overflow: hidden;
        background: var(--surface-card);
        box-shadow: var(--shadow-xs);
        transition: box-shadow .2s, transform .2s;
    }
    .meta-card:hover {
        box-shadow: var(--shadow-sm);
        transform: translateY(-2px);
    }
    .meta-card-header {
        padding: .85rem 1.25rem;
        font-size: .75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-muted);
        border-bottom: 1px solid var(--border-light);
        background: rgba(0,0,0,.02);
        display: flex;
        align-items: center;
        gap: .5rem;
    }
    .meta-card-body {
        padding: 1.25rem;
    }
    .meta-row {
        display: flex;
        align-items: flex-start;
        gap: .6rem;
        padding: .5rem 0;
        border-bottom: 1px solid var(--border-light);
    }
    .meta-row:last-child { border-bottom: none; }
    .meta-row-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        flex-shrink: 0;
        margin-top: 2px;
    }
    .meta-row-label {
        font-size: .72rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: var(--text-muted);
        margin-bottom: .1rem;
    }
    .meta-row-value {
        font-size: .9rem;
        font-weight: 600;
        color: var(--text-main);
    }

    /* ── Tag pills ── */
    .tag-pill {
        display: inline-flex;
        align-items: center;
        gap: .3rem;
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 30px;
        padding: .35rem .9rem;
        font-weight: 600;
        font-size: .82rem;
        color: var(--text-main);
        transition: all .18s;
        cursor: default;
    }
    .tag-pill:hover {
        border-color: var(--brand-1);
        color: var(--brand-1);
        background: rgba(37,99,235,.06);
        transform: translateY(-1px);
    }

    /* ── Back button ── */
    .back-btn {
        transition: all .2s;
    }
    .back-btn:hover {
        transform: translateX(-5px);
    }

    /* ── Recommendation sidebar card ── */
    .recommendation-card {
        background: var(--rec-gradient);
        color: #fff;
        border: none;
        box-shadow: 0 12px 36px var(--rec-shadow);
        position: relative;
        overflow: hidden;
        border-radius: var(--radius-xl);
    }
    .recommendation-card::before {
        content: "";
        position: absolute;
        top: -50%; right: -25%;
        width: 220px; height: 220px;
        background: rgba(255,255,255,0.07);
        border-radius: 50%;
    }
    .recommendation-card::after {
        content: "";
        position: absolute;
        bottom: -35%; left: -15%;
        width: 150px; height: 150px;
        background: rgba(255,255,255,0.04);
        border-radius: 50%;
    }
    .pulse-dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 0 0 var(--rec-shadow-pulse);
        animation: pulseDot 2s infinite;
    }
    @@keyframes pulseDot {
        0%   { box-shadow: 0 0 0 0 var(--rec-shadow-pulse); }
        70%  { box-shadow: 0 0 0 10px rgba(0,0,0,0); }
        100% { box-shadow: 0 0 0 0 rgba(0,0,0,0); }
    }

    /* ── Confidence bar inside rec card ── */
    .conf-track {
        height: 8px;
        background: rgba(255,255,255,0.18);
        border-radius: 99px;
        overflow: hidden;
        margin-top: .35rem;
    }
    .conf-fill {
        height: 100%;
        border-radius: 99px;
        background: rgba(255,255,255,0.9);
        transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .conf-badge {
        background: rgba(255,255,255,0.28);
        border: 1px solid rgba(255,255,255,0.4);
        color: #fff;
        font-weight: 700;
        font-size: .85rem;
        padding: .2rem .6rem;
        border-radius: 8px;
    }

    /* ── Responsive tweaks ── */
    @@media (max-width: 767.98px) {
        .report-hero { padding: 1.75rem 1.25rem; }
        .hero-title  { font-size: 1.5rem; }
    }
</style>

<div class="container px-0 report-detail-container">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-controller="Report" asp-action="Index" class="btn fintech-btn-outline btn-sm rounded-pill px-3 back-btn">
            <i class="bi bi-arrow-left me-1"></i> Back to Analysis Reports
        </a>
    </div>

    <!-- ═══════════════════════════════════════
         HERO BANNER
    ════════════════════════════════════════ -->
    <div class="report-hero mb-4">
        <!-- Top row: category + decision pill + bookmark -->
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <span class="hero-category-badge">
                <i class="bi bi-folder2-open"></i> @Model.CategoryName
            </span>
            <div class="d-flex align-items-center gap-2">
                @if (User.Identity.IsAuthenticated)
                {
                    <button id="bookmarkBtn" class="btn btn-sm" title="Save Report"
                            style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); color: white; border-radius: 8px; padding: 6px 12px; display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; transition: all 0.2s;"
                            onclick="toggleBookmark(@Model.NewsArticleId)">
                        <i id="bookmarkIcon" class="bi bi-bookmark"></i>
                        <span id="bookmarkLabel">Save</span>
                    </button>
                }
                <div class="decision-pill">
                    <i class="bi @decisionIcon"></i>
                    @decisionLabel
                </div>
            </div>
        </div>

        <!-- Title -->
        <h1 class="hero-title">@Model.NewsTitle</h1>

        <!-- Headline -->
        @if (!string.IsNullOrWhiteSpace(Model.Headline))
        {
            <p class="hero-headline mb-0">
                <i class="bi bi-quote" style="font-size:1.2rem; opacity:.6;"></i>
                @Model.Headline
            </p>
        }

        <!-- Stats strip: Tags, Confidence, Date, Source -->
        <div class="stats-strip">
            @if (Model.Tags != null && Model.Tags.Any())
            {
                <div class="stat-item">
                    <span class="stat-value d-flex flex-wrap justify-content-center gap-1">
                        @foreach (var t in Model.Tags)
                        {
                            <span style="background:#fff; color:#1a1a2e; font-size:.72rem; font-weight:700; padding:.15rem .55rem; border-radius:30px; white-space:nowrap;">@t</span>
                        }
                    </span>
                    <span class="stat-label">Assets Tracked</span>
                </div>
            }
            @if (Model.ConfidenceScore > 0)
            {
                <div class="stat-item">
                    <span class="stat-value" style="color:#fff;">@Model.ConfidenceScore%</span>
                    <span class="stat-label">AI Confidence</span>
                </div>
            }
            <div class="stat-item">
                <span class="stat-value" style="font-size:.95rem; text-transform:uppercase; letter-spacing:.05em;">@Model.Decision</span>
                <span class="stat-label">Signal Type</span>
            </div>
            <div class="stat-item">
                <span class="stat-value" style="font-size:.78rem; line-height:1.3;">@Model.CreatedDate.ToString("MMM dd")</span>
                <span class="stat-label">Published</span>
            </div>
        </div>

        <!-- Meta row -->
        <div class="hero-meta">
            <span class="hero-meta-item">
                <i class="bi bi-calendar3"></i>
                @Model.CreatedDate.ToString("MMMM dd, yyyy")
            </span>
            <span class="hero-meta-item">
                <i class="bi bi-person-badge"></i>
                @(string.IsNullOrEmpty(Model.CreatedByName) || Model.CreatedByName == "Deleted User" ? "Unknown Author" : Model.CreatedByName)
            </span>
            @if (!string.IsNullOrWhiteSpace(Model.NewsSource))
            {
                <span class="hero-meta-item">
                    <i class="bi bi-rss"></i> @Model.NewsSource
                </span>
            }
        </div>
    </div>

    <!-- ═══════════════════════════════════════
         MAIN CONTENT GRID
    ════════════════════════════════════════ -->
    <div class="row g-4">
        <!-- LEFT COLUMN: Article + Chart -->
        <div class="col-lg-8">
            <!-- ── Article Body ── -->
            <article class="card fintech-card p-4 p-md-5 mb-4 border-0">
                @if (isParsed)
                {
                    <!-- Parsed 3-section analysis -->
                    <div class="d-flex flex-column gap-4">
                        <!-- Sentiment -->
                        <div class="analysis-section-card p-4">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="section-icon-wrap" style="background:rgba(16,185,129,.12); color:#10b981;">
                                    <i class="bi bi-chat-square-heart-fill"></i>
                                </div>
                                <h4 class="fw-bold mb-0 text-main" style="font-size:1.05rem;">Market Sentiment</h4>
                            </div>
                            <p class="section-body mb-0">@sentimentContent</p>
                        </div>

                        <!-- Fundamental -->
                        <div class="analysis-section-card p-4" style="border-left-color: var(--brand-1);">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="section-icon-wrap" style="background:rgba(37,99,235,.12); color:#2563eb;">
                                    <i class="bi bi-bar-chart-fill"></i>
                                </div>
                                <h4 class="fw-bold mb-0 text-main" style="font-size:1.05rem;">Fundamental Indicators</h4>
                            </div>
                            <p class="section-body mb-0">@fundamentalContent</p>
                        </div>

                        <!-- Risk -->
                        <div class="analysis-section-card p-4" style="border-left-color: #ef4444;">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div class="section-icon-wrap" style="background:rgba(239,68,68,.1); color:#ef4444;">
                                    <i class="bi bi-shield-exclamation-fill"></i>
                                </div>
                                <h4 class="fw-bold mb-0 text-main" style="font-size:1.05rem;">Key Risk Warnings</h4>
                            </div>
                            <p class="section-body mb-0">@riskContent</p>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Raw paragraph fallback -->
                    @if (!string.IsNullOrWhiteSpace(Model.NewsContent))
                    {
                        var paragraphs = Model.NewsContent.Split(new[] { "\r\n", "\r", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                        foreach (var para in paragraphs)
                        {
                            <p class="text-main lh-lg mb-3" style="text-align:justify; font-size:.95rem; line-height:1.7;">@para</p>
                        }
                    }
                    else
                    {
                        <p class="text-muted fst-italic">No detailed content available for this report.</p>
                    }
                }
            </article>

            <!-- ── Price Chart ── -->
            <div class="chart-card mb-4">
                <div class="chart-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h4 class="fw-bold m-0 text-main d-flex align-items-center gap-2" style="font-size:1.1rem;">
                        <i class="bi bi-graph-up text-primary"></i>
                        <span id="chartTitle">@(Model.Tags != null && Model.Tags.Any() ? $"{Model.Tags.First()} Market Trend (6M)" : "Market Trend (6M)")</span>
                    </h4>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @if (Model.ConfidenceScore > 0)
                        {
                            <span class="badge fw-bold px-3 py-2"
                                  style="font-size:.78rem; background:#fff; color:@sectionColor; border:2px solid @sectionColor; letter-spacing:.03em;">
                                <i class="bi bi-shield-check me-1"></i>AI Conf: @Model.ConfidenceScore%
                            </span>
                        }
                        <span class="badge @(Model.Decision == "BUY" ? "fintech-badge-buy" : Model.Decision == "SELL" ? "fintech-badge-sell" : "fintech-badge-hold") px-3 py-2 fw-bold"
                              style="font-size:.78rem; letter-spacing:.03em;">
                            Signal: @Model.Decision
                        </span>
                    </div>
                </div>

                <!-- Period Selector -->
                <div class="d-flex gap-2 mb-3 flex-wrap" style="margin-top: 1rem;">
                    <button class="btn btn-sm fintech-btn-primary period-btn active" data-period="SixMonths" style="padding: 6px 12px; font-size: 0.8rem;">6M</button>
                    <button class="btn btn-sm fintech-btn-outline period-btn" data-period="OneDay" style="padding: 6px 12px; font-size: 0.8rem;">1D</button>
                    <button class="btn btn-sm fintech-btn-outline period-btn" data-period="OneWeek" style="padding: 6px 12px; font-size: 0.8rem;">1W</button>
                    <button class="btn btn-sm fintech-btn-outline period-btn" data-period="OneMonth" style="padding: 6px 12px; font-size: 0.8rem;">1M</button>
                    <button class="btn btn-sm fintech-btn-outline period-btn" data-period="ThreeMonths" style="padding: 6px 12px; font-size: 0.8rem;">3M</button>
                    <button class="btn btn-sm fintech-btn-outline period-btn" data-period="OneYear" style="padding: 6px 12px; font-size: 0.8rem;">1Y</button>
                </div>

                <div class="chart-body" style="height:300px; position:relative;">
                    <canvas id="tradingChart"></canvas>
                </div>
                <div class="chart-footer d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <span><i class="bi bi-info-circle me-1"></i><span id="chartFooter">Historical data from Yahoo Finance · 6-month window</span></span>
                    <span id="dataPointCount" class="text-muted" style="font-size:.7rem;"></span>
                </div>
            </div>
        </div>

        <!-- RIGHT COLUMN: Sidebar -->
        <div class="col-lg-4">
            <aside class="d-flex flex-column gap-3">

                <!-- ── Recommendation Card ── -->
                <div class="recommendation-card p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3" style="position:relative; z-index:1;">
                        <span class="text-uppercase fw-bold tracking-wider small opacity-75" style="letter-spacing:.1em;">Analysis Signal</span>
                        <div class="pulse-dot"></div>
                    </div>
                    <div class="d-flex align-items-center gap-3 mb-3" style="position:relative; z-index:1;">
                        <i class="bi @decisionIcon" style="font-size:3rem; opacity:.9;"></i>
                        <div>
                            <h2 class="m-0 fw-extrabold text-white" style="font-size:2.2rem; line-height:1;">@Model.Decision</h2>
                            <p class="m-0 small opacity-75 mt-1">Recommended Action</p>
                        </div>
                    </div>
                    @if (Model.ConfidenceScore > 0)
                    {
                        <div class="mt-3 pt-3 border-top border-white border-opacity-20" style="position:relative; z-index:1;">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="small fw-bold text-white" style="opacity:.85">AI Confidence Score</span>
                                <span class="conf-badge">@Model.ConfidenceScore%</span>
                            </div>
                            <div class="conf-track">
                                <div class="conf-fill" style="width:@Model.ConfidenceScore%"></div>
                            </div>
                        </div>
                    }
                </div>

                <!-- ── Report Info Card ── -->
                <div class="meta-card">
                    <div class="meta-card-header">
                        <i class="bi bi-file-earmark-text text-primary"></i>
                        Report Information
                    </div>
                    <div class="meta-card-body p-0">
                        <div class="meta-row">
                            <div class="meta-row-icon" style="background:rgba(37,99,235,.1); color:#2563eb;">
                                <i class="bi bi-person-badge-fill"></i>
                            </div>
                            <div>
                                <div class="meta-row-label">Author / Publisher</div>
                                <div class="meta-row-value">
                                    @if (string.IsNullOrEmpty(Model.CreatedByName) || Model.CreatedByName == "Deleted User")
                                    {
                                        <span class="text-danger"><i class="bi bi-trash me-1"></i>Deleted Staff</span>
                                    }
                                    else
                                    {
                                        @Model.CreatedByName
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="meta-row">
                            <div class="meta-row-icon" style="background:rgba(99,102,241,.1); color:#6366f1;">
                                <i class="bi bi-folder-fill"></i>
                            </div>
                            <div>
                                <div class="meta-row-label">Category Sector</div>
                                <div class="meta-row-value">@Model.CategoryName</div>
                            </div>
                        </div>
                        <div class="meta-row">
                            <div class="meta-row-icon" style="background:rgba(16,185,129,.1); color:#10b981;">
                                <i class="bi bi-calendar-event"></i>
                            </div>
                            <div>
                                <div class="meta-row-label">Published Date</div>
                                <div class="meta-row-value">@Model.CreatedDate.ToString("MMM dd, yyyy HH:mm") UTC</div>
                            </div>
                        </div>
                        @if (Model.ModifiedDate.HasValue)
                        {
                            <div class="meta-row">
                                <div class="meta-row-icon" style="background:rgba(245,158,11,.1); color:#f59e0b;">
                                    <i class="bi bi-clock-history"></i>
                                </div>
                                <div>
                                    <div class="meta-row-label">Last Updated</div>
                                    <div class="meta-row-value">@Model.ModifiedDate.Value.ToString("MMM dd, yyyy HH:mm") UTC</div>
                                </div>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.NewsSource))
                        {
                            <div class="meta-row">
                                <div class="meta-row-icon" style="background:rgba(14,165,233,.1); color:#0ea5e9;">
                                    <i class="bi bi-rss"></i>
                                </div>
                                <div>
                                    <div class="meta-row-label">Data Source</div>
                                    <div class="meta-row-value">@Model.NewsSource</div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- ── Analyzed Assets Card ── -->
                @if (Model.Tags != null && Model.Tags.Any())
                {
                    <div class="meta-card">
                        <div class="meta-card-header">
                            <i class="bi bi-tags-fill text-primary"></i>
                            Analyzed Assets
                        </div>
                        <div class="meta-card-body">
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var tag in Model.Tags)
                                {
                                    <span class="tag-pill">
                                        <i class="bi bi-hash text-muted" style="font-size:.7rem;"></i>@tag
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                }

            </aside>
        </div>
    </div>
</div>

@* Antiforgery token for bookmark AJAX calls *@
@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    @* ── Bookmark toggle ── *@
    <script>
        (function () {
            var isBookmarked = @(Model.IsBookmarked ? "true" : "false");
            var articleId = @Model.NewsArticleId;

            function setBookmarkState(saved) {
                isBookmarked = saved;
                var icon = document.getElementById('bookmarkIcon');
                var label = document.getElementById('bookmarkLabel');
                var btn = document.getElementById('bookmarkBtn');
                if (!icon || !label || !btn) return;
                if (saved) {
                    icon.className = 'bi bi-bookmark-fill';
                    label.textContent = 'Saved';
                    btn.style.background = 'rgba(16,185,129,0.3)';
                    btn.style.borderColor = 'rgba(16,185,129,0.6)';
                } else {
                    icon.className = 'bi bi-bookmark';
                    label.textContent = 'Save';
                    btn.style.background = 'rgba(255,255,255,0.15)';
                    btn.style.borderColor = 'rgba(255,255,255,0.3)';
                }
            }

            // Apply initial state from server
            setBookmarkState(isBookmarked);

            window.toggleBookmark = function (id) {
                var token = document.querySelector('input[name="__RequestVerificationToken"]');
                if (!token) { console.error('No antiforgery token found'); return; }

                var btn = document.getElementById('bookmarkBtn');
                if (btn) btn.disabled = true;

                fetch('/Report/BookmarkReport/' + id, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': token.value,
                        'Content-Type': 'application/json'
                    }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        setBookmarkState(data.bookmarked);
                    } else {
                        console.error('Bookmark error:', data.message);
                        alert('Could not save: ' + (data.message || 'Unknown error'));
                    }
                })
                .catch(function (err) {
                    console.error('Bookmark fetch failed:', err);
                    alert('Network error — bookmark not saved.');
                })
                .finally(function () {
                    if (btn) btn.disabled = false;
                });
            };
        })();
    </script>

    <script>
        (function() {
            var ctx = document.getElementById('tradingChart');
            if (!ctx) return;

            var decision = "@Model.Decision";
            var ticker = "@(Model.Tags != null && Model.Tags.Any() ? Model.Tags.First() : "FNTS")";

            var chartInstance = null;
            var MAX_LIVE_POINTS = 50;

            function getChartColors(isDark) {
                var strokeColor = '#374151';
                var fillColor = 'rgba(55, 65, 81, 0.08)';
                if (decision === "BUY")      { strokeColor = '#10b981'; fillColor = 'rgba(16, 185, 129, 0.08)'; }
                else if (decision === "SELL") { strokeColor = '#ef4444'; fillColor = 'rgba(239, 68, 68, 0.08)'; }
                var gridColor = isDark ? 'rgba(255, 255, 255, 0.06)' : 'rgba(0, 0, 0, 0.05)';
                var textColor = isDark ? '#cbd5e1' : '#64748b';
                return { strokeColor: strokeColor, fillColor: fillColor, gridColor: gridColor, textColor: textColor };
            }

            function buildDatasets(allLabels, allPrices, livePrices) {
                var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                var colors = getChartColors(isDark);

                return [
                    {
                        label: ticker + ' Historical',
                        data: allPrices,
                        borderColor: 'rgba(100, 116, 139, 0.35)',
                        borderWidth: 1.5,
                        fill: false,
                        tension: 0.3,
                        pointRadius: 0,
                        pointHoverRadius: 5
                    },
                    {
                        label: ticker + ' (Live)',
                        data: livePrices,
                        borderColor: colors.strokeColor,
                        backgroundColor: colors.fillColor,
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.2,
                        pointRadius: 2,
                        pointHoverRadius: 6
                    }
                ];
            }

            function renderChart(labels, prices, source) {
                var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                var colors = getChartColors(isDark);

                // Source badge
                var headerEl = ctx.closest('.chart-card').querySelector('.chart-header');
                if (headerEl && !headerEl.querySelector('.source-badge')) {
                    var badge = document.createElement('span');
                    badge.className = 'badge source-badge';
                    badge.style.cssText = 'font-size:.7rem;font-weight:500;background:rgba(0,0,0,.06);color:var(--text-muted);padding:.3rem .7rem;';
                    badge.innerHTML = '<i class="bi bi-broadcast me-1"></i>' + source;
                    headerEl.appendChild(badge);
                }

                if (chartInstance) { chartInstance.destroy(); chartInstance = null; }

                chartInstance = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: buildDatasets(labels, prices, [])
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        animation: { duration: 600 },
                        interaction: { mode: 'index', intersect: false },
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top',
                                labels: {
                                    color: colors.textColor,
                                    font: { size: 11, family: 'Inter' },
                                    boxWidth: 18,
                                    filter: function(item) { return item.text !== undefined; }
                                }
                            },
                            tooltip: {
                                mode: 'index',
                                intersect: false,
                                backgroundColor: isDark ? '#1e1b4b' : '#ffffff',
                                titleColor: isDark ? '#fff' : '#1e1b4b',
                                bodyColor: isDark ? '#e2e8f0' : '#1e1b4b',
                                borderColor: colors.gridColor,
                                borderWidth: 1
                            }
                        },
                        scales: {
                            x: {
                                grid: { color: colors.gridColor },
                                ticks: {
                                    color: colors.textColor,
                                    font: { family: 'Inter', size: 10 },
                                    maxTicksLimit: 12,
                                    maxRotation: 0
                                }
                            },
                            y: {
                                grid: { color: colors.gridColor },
                                ticks: {
                                    color: colors.textColor,
                                    font: { family: 'Inter', size: 10 }
                                }
                            }
                        }
                    }
                });

                // Theme observer
                var themeObserver = new MutationObserver(function() {
                    if (!chartInstance) return;
                    var cd = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                    var c = getChartColors(cd);
                    chartInstance.options.scales.x.grid.color = c.gridColor;
                    chartInstance.options.scales.y.grid.color = c.gridColor;
                    chartInstance.options.scales.x.ticks.color = c.textColor;
                    chartInstance.options.scales.y.ticks.color = c.textColor;
                    chartInstance.options.plugins.tooltip.backgroundColor = cd ? '#1e1b4b' : '#ffffff';
                    chartInstance.options.plugins.tooltip.titleColor = cd ? '#fff' : '#1e1b4b';
                    chartInstance.options.plugins.tooltip.bodyColor = cd ? '#e2e8f0' : '#1e1b4b';
                    chartInstance.options.plugins.legend.labels.color = c.textColor;
                    if (chartInstance.data.datasets.length > 1) {
                        chartInstance.data.datasets[1].borderColor = c.strokeColor;
                        chartInstance.data.datasets[1].backgroundColor = c.fillColor;
                    }
                    chartInstance.update('none');
                });
                themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
            }

            // ── 1. Fetch 6-month data from API ──
            fetch('/api/market/chart/' + encodeURIComponent(ticker))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data && data.success && data.prices && data.prices.length > 0) {
                        renderChart(data.labels, data.prices, data.source || 'Yahoo Finance');
                        var countEl = document.getElementById('dataPointCount');
                        if (countEl) countEl.textContent = data.prices.length + ' data points loaded';
                        initSignalR();
                    } else {
                        throw new Error('no data');
                    }
                })
                .catch(function() {
                    var emptyLabels = Array.from({ length: 30 }, function() { return ''; });
                    var emptyPrices = Array.from({ length: 30 }, function() { return null; });
                    renderChart(emptyLabels, emptyPrices, 'Connecting…');
                    initSignalR();
                });

            // ── 2. SignalR live ticks ──
            function initSignalR() {
                var connection = new signalR.HubConnectionBuilder()
                    .withUrl('/hubs/marketTicker')
                    .configureLogging(signalR.LogLevel.Warning)
                    .build();

                connection.on('ReceiveMarketTicks', function(ticks) {
                    var tick = ticks.find(function(t) { return t.symbol === ticker; });
                    if (!tick || !chartInstance) return;

                    var now = new Date();
                    var label = now.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                    var liveDataset = chartInstance.data.datasets[1];
                    liveDataset.data.push(tick.price);
                    chartInstance.data.labels.push(label);

                    if (liveDataset.data.length > MAX_LIVE_POINTS) {
                        var excess = liveDataset.data.length - MAX_LIVE_POINTS;
                        liveDataset.data.splice(0, excess);
                        chartInstance.data.labels.splice(0, excess);
                    }

                    chartInstance.update('none');

                    var badge = document.querySelector('.source-badge');
                    if (badge) badge.innerHTML = '<i class="bi bi-broadcast me-1" style="animation:pulse 1s infinite"></i>Live';
                });

                connection.start().catch(function() {
                    var badge = document.querySelector('.source-badge');
                    if (badge) badge.innerHTML = '<i class="bi bi-wifi-off me-1"></i>Reconnecting…';
                });
            }

            // ── Period selector button handlers ──
            var periodBtns = document.querySelectorAll('.period-btn');
            periodBtns.forEach(function(btn) {
                btn.addEventListener('click', function(e) {
                    e.preventDefault();
                    var period = this.getAttribute('data-period');

                    // Update button states
                    periodBtns.forEach(function(b) {
                        b.classList.remove('fintech-btn-primary');
                        b.classList.add('fintech-btn-outline');
                    });
                    this.classList.remove('fintech-btn-outline');
                    this.classList.add('fintech-btn-primary');

                    // Update title
                    var periodNames = {
                        'OneDay': '1D',
                        'OneWeek': '1W',
                        'OneMonth': '1M',
                        'ThreeMonths': '3M',
                        'SixMonths': '6M',
                        'OneYear': '1Y'
                    };
                    var periodLabels = {
                        'OneDay': '1-day',
                        'OneWeek': '1-week',
                        'OneMonth': '1-month',
                        'ThreeMonths': '3-month',
                        'SixMonths': '6-month',
                        'OneYear': '1-year'
                    };

                    var titleEl = document.getElementById('chartTitle');
                    if (titleEl) {
                        titleEl.textContent = ticker + ' Market Trend (' + periodNames[period] + ')';
                    }
                    var footerEl = document.getElementById('chartFooter');
                    if (footerEl) {
                        footerEl.textContent = 'Historical data from Yahoo Finance · ' + periodLabels[period] + ' window';
                    }

                    // Fetch new data with period parameter
                    fetch('/api/market/chart/' + encodeURIComponent(ticker) + '?period=' + period)
                        .then(function(r) { return r.json(); })
                        .then(function(data) {
                            if (data && data.success && data.prices && data.prices.length > 0) {
                                // Clear existing dataset but keep chart structure
                                chartInstance.data.labels = data.labels;
                                chartInstance.data.datasets[0].data = data.prices;
                                chartInstance.data.datasets[1].data = []; // Clear live ticks
                                chartInstance.update();
                                var countEl = document.getElementById('dataPointCount');
                                if (countEl) countEl.textContent = data.prices.length + ' data points loaded';
                            }
                        })
                        .catch(function() {
                            console.error('Failed to fetch chart data for period:', period);
                        });
                });
            });
        })();
    </script>
}
