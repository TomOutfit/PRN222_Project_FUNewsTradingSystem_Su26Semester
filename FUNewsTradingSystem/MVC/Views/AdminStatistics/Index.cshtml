                    <span class="chart-card-badge">@dailyCounts.Sum(d => d.count) reports · @dailyCounts.Count days</span>
                </div>
                <div class="chart-canvas-wrap" style="height: 180px;">
                    <canvas id="dailyTrendChart"></canvas>
                </div>
            </div>
