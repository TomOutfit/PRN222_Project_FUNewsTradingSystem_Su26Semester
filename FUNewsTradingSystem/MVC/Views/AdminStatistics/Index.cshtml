    }

    <!-- ── Results Table ── -->
    <div class="results-card mb-4">
        <div class="results-header">
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <h6>
                    <i class="bi bi-table" style="color:var(--accent)"></i>
                    Results
                </h6>
                @if (Model.Results != null && Model.Results.Any())
                {
                    <span class="stat-pill stat-pill-buy">
                        <i class="bi bi-arrow-up-circle me-1"></i>@Model.BuyCount BUY
                    </span>
                    <span class="stat-pill stat-pill-hold">
                        <i class="bi bi-pause-circle me-1"></i>@Model.HoldCount HOLD
                    </span>
