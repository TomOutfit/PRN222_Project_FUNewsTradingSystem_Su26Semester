            </div>
        </div>
    </div>

    <!-- ── Daily Trend Full Width ── -->
    @if (Model.Results != null && Model.Results.Any())
    {
        var dailyCounts = Model.Results
            .GroupBy(r => r.CreatedDate.Date)
            .OrderBy(g => g.Key)
            .Select(g => new { date = g.Key, count = g.Count() })
