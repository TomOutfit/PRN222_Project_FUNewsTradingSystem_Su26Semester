        <!-- Confidence Bars -->
        <div class="col-lg-4">
            <div class="chart-card h-100">
                <div class="chart-card-header">
                    <span class="chart-card-title">
                        <span class="chart-icon" style="background:rgba(245,158,11,0.1);color:#f59e0b">
