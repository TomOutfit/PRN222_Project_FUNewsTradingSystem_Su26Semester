@model FUNewsTradingSystem_MVC.ViewModels.Statistics.StatisticsResultViewModel
@{
    ViewData["Title"] = "Statistical Reports";

    int totalCount = Model.BuyCount + Model.SellCount + Model.HoldCount;
    double totalAvgConf = Model.AverageConfidence;
    int reportPeriodDays = (Model.Filter.EndDate - Model.Filter.StartDate).Days + 1;
}

<style>
    /* ── Filter Bar ── */
    .stats-filter-bar {
        background: var(--surface-card);
        border-radius: 22px;
        border: 1px solid var(--border);
        padding: 1.5rem 1.75rem;
        margin-bottom: 2rem;
        box-shadow: 0 2px 16px rgba(0,0,0,0.04);
        position: relative;
        overflow: hidden;
    }
    .stats-filter-bar::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(135deg, rgba(37,99,235,0.15), rgba(16,185,129,0.1), rgba(0,0,0,0));
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        pointer-events: none;
    }
    .stats-filter-bar .form-label {
        font-size: .72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-muted);
        margin-bottom: .4rem;
    }
    .stats-date-input {
        border-radius: 12px !important;
        border: 1.5px solid var(--border) !important;
        background: var(--surface) !important;
        color: var(--text-main) !important;
        font-size: .875rem;
        font-weight: 600;
        padding: .55rem .875rem !important;
        transition: border-color .25s, box-shadow .25s;
    }
    .stats-date-input:focus {
        border-color: var(--brand-1) !important;
        box-shadow: 0 0 0 3px rgba(37,99,235,0.12) !important;
        outline: none;
    }
    .stats-btn-generate {
        background: var(--brand-gradient);
        border: none;
        border-radius: 12px;
        font-weight: 700;
        font-size: .875rem;
        letter-spacing: .03em;
        padding: .6rem 1.5rem;
        color: #fff;
        transition: opacity .25s, transform .2s, box-shadow .25s;
        box-shadow: 0 4px 14px rgba(37,99,235,0.35);
        white-space: nowrap;
    }
    .stats-btn-generate:hover {
        opacity: .92;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(37,99,235,0.45);
        color: #fff;
    }
    .stats-btn-generate:active { transform: translateY(0); }

    /* ── KPI Cards ── */
    .kpi-card {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface-card);
        padding: 1.35rem 1.4rem;
        position: relative;
        overflow: hidden;
        transition: transform .35s cubic-bezier(0.16,1,0.3,1), box-shadow .35s;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        display: flex;
        flex-direction: column;
        gap: .3rem;
    }
    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 36px rgba(0,0,0,0.09);
    }
    .kpi-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3.5px;
        border-radius: 20px 20px 0 0;
    }
    .kpi-card.kpi-total::before  { background: var(--brand-gradient); }
    .kpi-card.kpi-buy::before    { background: linear-gradient(90deg, #10b981, #059669); }
    .kpi-card.kpi-sell::before   { background: linear-gradient(90deg, #ef4444, #dc2626); }
    .kpi-card.kpi-hold::before   { background: linear-gradient(90deg, #f59e0b, #d97706); }
    .kpi-card.kpi-conf::before   { background: linear-gradient(90deg, #0284c7, #38bdf8); }
    .kpi-card.kpi-period::before { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

    .kpi-icon-wrap {
        width: 36px; height: 36px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        margin-bottom: .4rem;
        flex-shrink: 0;
    }
    .kpi-icon-total  { background: rgba(37,99,235,0.1);  color: #2563eb; }
    .kpi-icon-buy    { background: rgba(16,185,129,0.1);   color: #10b981; }
    .kpi-icon-sell   { background: rgba(239,68,68,0.1);   color: #ef4444; }
    .kpi-icon-hold   { background: rgba(245,158,11,0.1);  color: #f59e0b; }
    .kpi-icon-conf   { background: rgba(2,132,199,0.1);   color: #0284c7; }
    .kpi-icon-period { background: rgba(139,92,246,0.1);  color: #8b5cf6; }

    .kpi-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .09em;
        color: var(--text-muted);
    }
    .kpi-value {
        font-size: 1.85rem;
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: -.02em;
    }
    .kpi-value.kpi-total { color: var(--brand-1); }
    .kpi-value.kpi-buy   { color: #10b981; }
    .kpi-value.kpi-sell  { color: #ef4444; }
    .kpi-value.kpi-hold  { color: #f59e0b; }
    .kpi-value.kpi-conf  { color: #0284c7; }
    .kpi-value.kpi-period{ color: #8b5cf6; }
    .kpi-sub {
        font-size: .73rem;
        color: var(--text-muted);
        font-weight: 500;
        line-height: 1.3;
    }
    .kpi-trend {
        display: inline-flex; align-items: center; gap: .25rem;
        font-size: .7rem; font-weight: 700;
        border-radius: 99px;
        padding: .15rem .5rem .15rem .35rem;
        margin-top: .2rem;
        width: fit-content;
    }
    .kpi-trend.up   { background: rgba(16,185,129,0.1);  color: #10b981; }
    .kpi-trend.neutral { background: rgba(100,116,139,0.1); color: #64748b; }

    /* ── Chart Cards ── */
    .chart-card {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface-card);
        padding: 1.4rem 1.5rem 1.25rem;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
        transition: box-shadow .3s, transform .3s;
        position: relative;
        overflow: hidden;
    }
    .chart-card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.08);
        transform: translateY(-2px);
    }
    .chart-card-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 1.1rem;
    }
    .chart-card-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--text-main);
        display: flex; align-items: center; gap: .45rem;
    }
    .chart-card-title .chart-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem;
    }
    .chart-card-badge {
        font-size: .68rem;
        font-weight: 700;
        border-radius: 99px;
        padding: .2rem .6rem;
        letter-spacing: .04em;
        background: var(--surface);
        border: 1px solid var(--border);
        color: var(--text-muted);
    }
    .chart-canvas-wrap { position: relative; }

    /* ── Chart Legend ── */
    .chart-legend {
        display: flex; flex-wrap: wrap; gap: .875rem;
        margin-top: .875rem;
        padding-top: .875rem;
        border-top: 1px solid var(--border);
    }
    .legend-item {
        display: flex; align-items: center; gap: .35rem;
        font-size: .78rem; font-weight: 600;
    }
    .legend-dot {
        width: 9px; height: 9px;
        border-radius: 50%; flex-shrink: 0;
    }
    .legend-value { color: var(--text-main); font-weight: 700; }
    .legend-pct   { color: var(--text-muted); font-weight: 500; }

    /* ── Confidence Bars ── */
    .conf-section { display: flex; flex-direction: column; gap: .875rem; }
    .conf-item    { display: flex; flex-direction: column; gap: .3rem; }
    .conf-header  { display: flex; justify-content: space-between; align-items: center; }
    .conf-label   { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; }
    .conf-val     { font-size: .8rem; font-weight: 800; }
    .conf-bar     { height: 5px; border-radius: 99px; background: var(--border); overflow: hidden; }
    .conf-fill    { height: 100%; border-radius: 99px; transition: width 1s cubic-bezier(0.16,1,0.3,1); }

    /* ── Results Table ── */
    .results-card {
        border-radius: 20px;
        border: 1px solid var(--border);
        background: var(--surface-card);
        overflow: hidden;
        box-shadow: 0 1px 4px rgba(0,0,0,0.04);
    }
    .results-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.4rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
    }
    .results-header h6 {
        font-weight: 700; margin: 0;
        color: var(--text-main);
        display: flex; align-items: center; gap: .5rem;
        font-size: .875rem;
    }
    /* Table cell specifics (cell-level overrides only, no base table rules) */
    .table .title-cell {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 600;
        color: var(--text-main);
        font-size: .875rem;
    }
    .table .headline-cell {
        max-width: 260px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        color: var(--text-muted);
        font-size: .8rem;
        line-height: 1.4;
    }
    .table .date-cell {
        white-space: nowrap;
        color: var(--text-muted);
        font-size: .8rem;
    }
    .table .sector-badge {
        border-radius: 8px;
        font-size: .73rem;
        font-weight: 600;
        padding: .25rem .55rem;
        background: rgba(37,99,235,0.08);
        color: var(--brand-1);
        border: 1px solid rgba(37,99,235,0.12);
        white-space: nowrap;
    }
    .table .signal-badge {
        border-radius: 8px;
        font-size: .73rem;
        font-weight: 800;
        padding: .28rem .6rem;
        letter-spacing: .04em;
        white-space: nowrap;
    }
    .signal-buy  { background: rgba(16,185,129,0.1);  color: #059669; border: 1px solid rgba(16,185,129,0.2);  }
    .signal-sell { background: rgba(239,68,68,0.1);    color: #dc2626; border: 1px solid rgba(239,68,68,0.2);  }
    .signal-hold { background: rgba(245,158,11,0.1);   color: #d97706; border: 1px solid rgba(245,158,11,0.2); }
    .conf-mini-bar {
        display: flex; align-items: center; gap: .4rem;
    }
    .conf-mini-track {
        width: 52px; height: 4.5px;
        border-radius: 99px;
        background: var(--border);
        overflow: hidden; flex-shrink: 0;
    }
    .conf-mini-fill {
        height: 100%; border-radius: 99px;
        transition: width .8s cubic-bezier(0.16,1,0.3,1);
    }
    .conf-mini-val {
        font-size: .75rem; font-weight: 700;
        color: var(--text-main); min-width: 30px;
    }
    .creator-chip {
        display: flex; align-items: center; gap: .45rem;
        white-space: nowrap;
    }
    .creator-avatar {
        width: 26px; height: 26px;
        border-radius: 50%;
        background: var(--brand-gradient);
        display: flex; align-items: center; justify-content: center;
        color: #fff; font-weight: 700; font-size: .7rem;
        flex-shrink: 0;
    }
    .creator-name { font-size: .82rem; font-weight: 600; }

    /* ── Empty State ── */
    .stats-empty {
        text-align: center; padding: 4.5rem 2rem;
        display: flex; flex-direction: column; align-items: center; gap: .75rem;
    }
    .stats-empty-icon {
        width: 72px; height: 72px; border-radius: 50%;
        background: rgba(37,99,235,0.06);
        display: flex; align-items: center; justify-content: center;
        margin-bottom: .5rem;
    }
    .stats-empty h6 { font-weight: 700; color: var(--text-muted); margin: 0; }
    .stats-empty p   { color: var(--text-muted); font-size: .875rem; margin: 0; }

    /* ── Quick Stat Pills in table header ── */
    .stat-pill {
        border-radius: 99px;
        font-size: .72rem; font-weight: 700;
        padding: .2rem .6rem;
        border: 1px solid;
    }
    .stat-pill-buy  { background: rgba(16,185,129,0.08);  color: #10b981; border-color: rgba(16,185,129,0.2); }
    .stat-pill-sell { background: rgba(239,68,68,0.08);   color: #ef4444; border-color: rgba(239,68,68,0.2); }
    .stat-pill-hold { background: rgba(245,158,11,0.08); color: #f59e0b; border-color: rgba(245,158,11,0.2); }

    /* ── Export buttons ── */
    .btn-export {
        border-radius: 10px;
        font-size: .78rem;
        font-weight: 700;
        padding: .45rem .875rem;
        transition: all .2s;
        display: inline-flex; align-items: center; gap: .35rem;
    }
    .btn-export-excel {
        background: rgba(16,185,129,0.08);
        border: 1px solid rgba(16,185,129,0.25);
        color: #10b981;
    }
    .btn-export-excel:hover {
        background: rgba(16,185,129,0.15);
        color: #059669;
        transform: translateY(-1px);
    }
    .btn-export-pdf {
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.25);
        color: #ef4444;
    }
    .btn-export-pdf:hover {
        background: rgba(239,68,68,0.15);
        color: #dc2626;
        transform: translateY(-1px);
    }

    /* ── Count-up animation ── */
    .kpi-value { transition: color .3s; }

    /* ── Dark mode overrides ── */
    [data-bs-theme="dark"] .stats-filter-bar { background: #161b2e; border-color: rgba(255,255,255,0.06); }
    [data-bs-theme="dark"] .stats-date-input { background: #1e2236 !important; border-color: rgba(255,255,255,0.08) !important; color: #e2e8f0 !important; }
    [data-bs-theme="dark"] .chart-card { background: #161b2e; border-color: rgba(255,255,255,0.06); }
    [data-bs-theme="dark"] .chart-card-header { border-color: rgba(255,255,255,0.05); }
    [data-bs-theme="dark"] .chart-legend { border-color: rgba(255,255,255,0.06); }
    [data-bs-theme="dark"] .kpi-card { background: #161b2e; border-color: rgba(255,255,255,0.06); }
    [data-bs-theme="dark"] .kpi-icon-total { background: rgba(37,99,235,0.15); }
    [data-bs-theme="dark"] .kpi-icon-buy   { background: rgba(16,185,129,0.15); }
    [data-bs-theme="dark"] .kpi-icon-sell  { background: rgba(239,68,68,0.15); }
    [data-bs-theme="dark"] .kpi-icon-hold  { background: rgba(245,158,11,0.15); }
    [data-bs-theme="dark"] .kpi-icon-conf  { background: rgba(2,132,199,0.15); }
    [data-bs-theme="dark"] .kpi-icon-period{ background: rgba(139,92,246,0.15); }
    [data-bs-theme="dark"] .results-card { background: #161b2e; border-color: rgba(255,255,255,0.06); }
    [data-bs-theme="dark"] .results-header { background: #1e2236; border-color: rgba(255,255,255,0.06); }
    [data-bs-theme="dark"] .table thead th { background: #0f172a !important; }
    [data-bs-theme="dark"] .table { color: #e2e8f0; }
    [data-bs-theme="dark"] .table tbody tr { border-color: rgba(255,255,255,0.04); }
    [data-bs-theme="dark"] .table tbody tr:hover { background: rgba(37,99,235,0.06); }
    [data-bs-theme="dark"] .table .headline-cell { color: rgba(226,232,240,0.6); }
    [data-bs-theme="dark"] .table .date-cell { color: rgba(226,232,240,0.5); }
    [data-bs-theme="dark"] .table .title-cell { color: #e2e8f0; }
    [data-bs-theme="dark"] .sector-badge { background: rgba(59,130,246,0.12); color: #60a5fa; border-color: rgba(59,130,246,0.2); }
    [data-bs-theme="dark"] .signal-buy  { background: rgba(16,185,129,0.12);  color: #34d399; border-color: rgba(16,185,129,0.25); }
    [data-bs-theme="dark"] .signal-sell { background: rgba(239,68,68,0.12);   color: #f87171; border-color: rgba(239,68,68,0.25); }
    [data-bs-theme="dark"] .signal-hold { background: rgba(245,158,11,0.12);  color: #fbbf24; border-color: rgba(245,158,11,0.25); }
    [data-bs-theme="dark"] .creator-name { color: #e2e8f0; }
    [data-bs-theme="dark"] .kpi-sub { color: rgba(226,232,240,0.5); }
    [data-bs-theme="dark"] .conf-label { color: rgba(226,232,240,0.6); }
    [data-bs-theme="dark"] .conf-bar { background: rgba(255,255,255,0.08); }
    [data-bs-theme="dark"] .conf-mini-track { background: rgba(255,255,255,0.08); }
    [data-bs-theme="dark"] .stat-pill-buy  { background: rgba(16,185,129,0.1);  color: #34d399; border-color: rgba(16,185,129,0.2); }
    [data-bs-theme="dark"] .stat-pill-sell { background: rgba(239,68,68,0.1);   color: #f87171; border-color: rgba(239,68,68,0.2); }
    [data-bs-theme="dark"] .stat-pill-hold { background: rgba(245,158,11,0.1);  color: #fbbf24; border-color: rgba(245,158,11,0.2); }
    [data-bs-theme="dark"] .chart-card-badge { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.08); color: rgba(226,232,240,0.5); }
    [data-bs-theme="dark"] .btn-export-excel { background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.2); color: #34d399; }
    [data-bs-theme="dark"] .btn-export-pdf   { background: rgba(239,68,68,0.1);  border-color: rgba(239,68,68,0.2);  color: #f87171; }
    [data-bs-theme="dark"] .stats-empty-icon { background: rgba(37,99,235,0.1); }
    [data-bs-theme="dark"] .stats-empty-icon svg { color: rgba(96,165,250,0.5); }
    [data-bs-theme="dark"] .kpi-label { color: rgba(226,232,240,0.45); }
    [data-bs-theme="dark"] .legend-pct { color: rgba(226,232,240,0.45); }

    /* ── Row expansion ── */
    .detail-row { background: var(--surface) !important; }
    .detail-panel {
        background: var(--surface);
        border-bottom: 2px solid var(--brand-1);
        transition: background 0.2s;
    }
    [data-bs-theme="dark"] .detail-panel { background: #0f172a; border-bottom-color: rgba(37,99,235,0.3); }
    .detail-inner {
        background: var(--surface-card);
        border-radius: 12px;
        border: 1px solid var(--border);
        margin: .5rem 0;
    }
    [data-bs-theme="dark"] .detail-inner { background: #1e2236; border-color: rgba(255,255,255,0.06); }
    .detail-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .07em;
        color: var(--text-muted);
        margin-bottom: .2rem;
    }
    .detail-content {
        font-size: .85rem;
        color: var(--text-main);
        line-height: 1.4;
    }
    .row-chevron { transition: transform 0.25s ease; }
    tr.clickable-row[aria-expanded="true"] .row-chevron { transform: rotate(90deg); }
    tr.clickable-row:hover { background: rgba(37,99,235,0.04) !important; }
    [data-bs-theme="dark"] tr.clickable-row:hover { background: rgba(37,99,235,0.06) !important; }
    .clickable-row { cursor: pointer; }
    .clickable-row:hover td:first-child { border-left-color: var(--brand-1) !important; }

    /* ── Export loading button ── */
    #btnExportExcel, #btnExportPdf { min-width: 90px; transition: all 0.2s; }
</style>

<!-- ── Page Header ── -->
<div class="page-header">
    <div>
        <h2>
            <i class="bi bi-graph-up-arrow me-2" style="background:var(--brand-gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent"></i>
            Statistical Reports
        </h2>
        <p class="text-muted mb-0">AI-generated trading analysis across all staff members — filtered by date range.</p>
    </div>
</div>

<!-- ── Filter Bar ── -->
<div class="stats-filter-bar">
    <form id="filterForm" asp-controller="AdminStatistics" asp-action="Index" method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label asp-for="Filter.StartDate" class="form-label d-block"></label>
                <div class="input-group">
                    <span class="input-group-text" style="border-radius:12px 0 0 12px;border-color:var(--border);background:var(--surface);color:var(--text-muted)">
                        <i class="bi bi-calendar3"></i>
                    </span>
                    <input name="startDate" value="@Model.Filter.StartDate.ToString("yyyy-MM-dd")"
                           class="form-control stats-date-input" type="date" id="startDate" />
                </div>
                <span asp-validation-for="Filter.StartDate" class="text-danger d-block" style="font-size:.75rem;margin-top:.2rem"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Filter.EndDate" class="form-label d-block"></label>
                <div class="input-group">
                    <span class="input-group-text" style="border-radius:12px 0 0 12px;border-color:var(--border);background:var(--surface);color:var(--text-muted)">
                        <i class="bi bi-calendar3-range"></i>
                    </span>
                    <input name="endDate" value="@Model.Filter.EndDate.ToString("yyyy-MM-dd")"
                            class="form-control stats-date-input" type="date" id="endDate" />
                </div>
                <span asp-validation-for="Filter.EndDate" class="text-danger d-block" style="font-size:.75rem;margin-top:.2rem"></span>
            </div>
            <div class="col-md-3">
                <label class="form-label d-block"><i class="bi bi-hash me-1"></i>Ticker (Tag)</label>
                <select name="tagId" class="form-select fintech-form-control stats-date-input" style="border-radius:12px 12px 12px 12px !important">
                    <option value="">All Tickers</option>
                    @{
                        var allTags = ViewBag.AllTags as IEnumerable<FUNewsTradingSystem_DataAccessLayer.Models.Tag> ?? Enumerable.Empty<FUNewsTradingSystem_DataAccessLayer.Models.Tag>();
                        int? selectedTagId = ViewBag.SelectedTagId as int?;
                        foreach (var t in allTags)
                        {
                            <option value="@t.TagID" selected="@(selectedTagId == t.TagID ? "selected" : null)">@t.TagName</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn stats-btn-generate w-100" onclick="return validateDates()">
                    <i class="bi bi-sparkles me-2"></i>Generate Report
                </button>
            </div>
        </div>
    </form>
</div>

@if (Model.HasResults)
{
    <!-- ── KPI Summary Cards ── -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-2">
            <div class="kpi-card kpi-total">
                <div class="kpi-icon-wrap kpi-icon-total">
                    <i class="bi bi-files-alt"></i>
                </div>
                <div class="kpi-label">Total Reports</div>
                <div class="kpi-value kpi-total" data-target="@totalCount">@totalCount</div>
                <div class="kpi-sub">in selected period</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="kpi-card kpi-buy">
                <div class="kpi-icon-wrap kpi-icon-buy">
                    <i class="bi bi-arrow-up-circle-fill"></i>
                </div>
                <div class="kpi-label">BUY Signals</div>
                <div class="kpi-value kpi-buy" data-target="@Model.BuyCount">@Model.BuyCount</div>
                <div class="kpi-sub">Average Confidence: @Model.BuyAverageConfidence%</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="kpi-card kpi-sell">
                <div class="kpi-icon-wrap kpi-icon-sell">
                    <i class="bi bi-arrow-down-circle-fill"></i>
                </div>
                <div class="kpi-label">SELL Signals</div>
                <div class="kpi-value kpi-sell" data-target="@Model.SellCount">@Model.SellCount</div>
                <div class="kpi-sub">Average Confidence: @Model.SellAverageConfidence%</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="kpi-card kpi-hold">
                <div class="kpi-icon-wrap kpi-icon-hold">
                    <i class="bi bi-pause-circle-fill"></i>
                </div>
                <div class="kpi-label">HOLD Signals</div>
                <div class="kpi-value kpi-hold" data-target="@Model.HoldCount">@Model.HoldCount</div>
                <div class="kpi-sub">Average Confidence: @Model.HoldAverageConfidence%</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="kpi-card kpi-conf">
                <div class="kpi-icon-wrap kpi-icon-conf">
                    <i class="bi bi-gauge-high"></i>
                </div>
                <div class="kpi-label">Average Confidence</div>
                <div class="kpi-value kpi-conf" data-target="@totalAvgConf" data-suffix="%">@totalAvgConf%</div>
                <div class="kpi-sub">Across all signals</div>
            </div>
        </div>
        <div class="col-6 col-lg-2">
            <div class="kpi-card kpi-period">
                <div class="kpi-icon-wrap kpi-icon-period">
                    <i class="bi bi-calendar-week"></i>
                </div>
                <div class="kpi-label">Report Period</div>
                <div class="kpi-value kpi-period">@reportPeriodDays</div>
                <div class="kpi-sub">Days selected</div>
            </div>
        </div>
    </div>

    <!-- ── Charts Row ── -->
    <div class="row g-4 mb-4">
        <!-- Doughnut: Signal Distribution -->
        <div class="col-lg-4">
            <div class="chart-card h-100">
                <div class="chart-card-header">
                    <span class="chart-card-title">
                        <span class="chart-icon" style="background:rgba(37,99,235,0.1);color:#2563eb">
                            <i class="bi bi-pie-chart-fill"></i>
                        </span>
                        Signal Distribution
                    </span>
                    <span class="chart-card-badge">@totalCount total</span>
                </div>
                <div class="chart-canvas-wrap" style="height: 210px;">
                    <canvas id="decisionChart"></canvas>
                </div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <span class="legend-dot" style="background:#10b981"></span>
                        <span>BUY</span>
                        <span class="legend-value">@Model.BuyCount</span>
                        <span class="legend-pct">(@(totalCount > 0 ? Math.Round((double)Model.BuyCount / totalCount * 100) : 0)%)</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot" style="background:#f59e0b"></span>
                        <span>HOLD</span>
                        <span class="legend-value">@Model.HoldCount</span>
                        <span class="legend-pct">(@(totalCount > 0 ? Math.Round((double)Model.HoldCount / totalCount * 100) : 0)%)</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot" style="background:#ef4444"></span>
                        <span>SELL</span>
                        <span class="legend-value">@Model.SellCount</span>
