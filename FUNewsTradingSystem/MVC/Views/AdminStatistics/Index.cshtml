        @await Html.PartialAsync("_Pagination", Model.Results)
    }
}
else
{
    <div class="stats-empty" style="margin-top:2rem">
        <div class="stats-empty-icon">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="color:var(--accent);opacity:.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/>
            </svg>
        </div>
        <h6>Select a date range to get started</h6>
        <p>Choose a start and end date above, then click <strong>Generate Report</strong> to view statistics.</p>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function validateDates() {
            var startDateStr = document.getElementById("startDate").value;
            var endDateStr   = document.getElementById("endDate").value;
            if (startDateStr && endDateStr) {
                if (new Date(startDateStr) > new Date(endDateStr)) {
                    alert("Start date must be before or equal to end date.");
                    return false;
                }
            }
            return true;
        }

        /* ── Export helpers (Excel/PDF via fetch — no tab switch) ── */
        async function exportReport(format) {
            var startDate = document.getElementById("startDate").value;
            var endDate   = document.getElementById("endDate").value;
            if (!startDate || !endDate) {
                alert("Please set a date range first.");
                return;
            }

            var btn = format === 'excel'
                ? document.getElementById('btnExportExcel')
                : document.getElementById('btnExportPdf');
            var label = btn.querySelector('.btn-label');

            // ── Loading state ──
            btn.disabled = true;
            label.textContent = 'Exporting…';
            var origClass = btn.className;
            btn.style.cssText = 'opacity:0.7;cursor:wait;pointer-events:none;min-width:90px';

            try {
                var url = (format === 'excel'
                    ? '@Url.Action("ExportExcel", "AdminStatistics")'
                    : '@Url.Action("ExportPdf", "AdminStatistics")')
                    + `?startDate=${encodeURIComponent(startDate)}&endDate=${encodeURIComponent(endDate)}`;

                var response = await fetch(url);
                if (!response.ok) throw new Error('Server error: ' + response.status);

                var filename = format === 'excel'
                    ? `Statistics_${startDate}_to_${endDate}.xlsx`
                    : `Statistics_${startDate}_to_${endDate}.pdf`;
                var mimeType = format === 'excel'
                    ? 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
                    : 'application/pdf';

                var blob = await response.blob();
                var objectUrl = URL.createObjectURL(blob);

                var a = document.createElement('a');
                a.href = objectUrl;
                a.download = filename;
                a.style.display = 'none';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(objectUrl);

                // ── Success feedback ──
                btn.style.cssText = '';
                btn.className = origClass;
                label.textContent = format === 'excel' ? 'Exported!' : 'Exported!';
                btn.classList.remove('btn-export-excel', 'btn-export-pdf');
                btn.classList.add('btn', 'btn-success', 'btn-sm');
                setTimeout(function() {
                    btn.className = origClass;
                    btn.disabled = false;
                    label.textContent = format === 'excel' ? 'Excel' : 'PDF';
                }, 2500);
            } catch (err) {
                console.error('Export failed:', err);
                btn.style.cssText = '';
                btn.className = origClass;
                label.textContent = 'Failed!';
                btn.style.borderColor = '#dc2626';
                btn.style.color = '#dc2626';
                setTimeout(function() {
                    btn.disabled = false;
                    label.textContent = format === 'excel' ? 'Excel' : 'PDF';
                    btn.style.borderColor = '';
                    btn.style.color = '';
                }, 3000);
            }
        }

        (function() {
            var buyCount  = @Model.BuyCount;
            var sellCount = @Model.SellCount;
            var holdCount = @Model.HoldCount;
            var totalCount = buyCount + sellCount + holdCount;

            var sectorLabels = @Html.Raw(Json.Serialize(Model.SectorCounts?.Keys ?? Enumerable.Empty<string>()));
            var sectorValues = @Html.Raw(Json.Serialize(Model.SectorCounts?.Values ?? Enumerable.Empty<int>()));

            var dailyLabels = @Html.Raw(Json.Serialize(
                (Model.Results?.GroupBy(r => r.CreatedDate.Date)
                               .OrderBy(g => g.Key)
                               .Select(g => g.Key.ToString("MM-dd"))
                               .ToList() ?? new List<string>())
            ));
            var dailyValues = @Html.Raw(Json.Serialize(
                (Model.Results?.GroupBy(r => r.CreatedDate.Date)
                               .OrderBy(g => g.Key)
                               .Select(g => g.Count())
                               .ToList() ?? new List<int>())
            ));

            var isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';

            function getChartColors() {
                return {
                    text:  isDark ? '#94a3b8' : '#374151',
                    grid:  isDark ? 'rgba(255,255,255,0.05)' : 'rgba(55,65,81,0.07)',
                    surface: isDark ? '#1e2236' : '#ffffff',
                    border: isDark ? 'rgba(255,255,255,0.08)' : '#e2e8f0'
                };
            }

            function renderCharts() {
                var c = getChartColors();

                /* ── Doughnut: Signal Distribution ── */
                var dc = document.getElementById('decisionChart');
                if (dc) {
                    if (dc.chart) dc.chart.destroy();
                    if (totalCount > 0) {
                        dc.chart = new Chart(dc, {
                            type: 'doughnut',
                            data: {
                                labels: ['BUY', 'HOLD', 'SELL'],
                                datasets: [{
                                    data: [buyCount, holdCount, sellCount],
                                    backgroundColor: ['rgba(16,185,129,0.85)', 'rgba(245,158,11,0.85)', 'rgba(239,68,68,0.85)'],
                                    borderColor: [c.surface, c.surface, c.surface],
                                    borderWidth: 3,
                                    hoverOffset: 8,
                                    hoverBorderWidth: 0
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                cutout: '70%',
                                plugins: {
                                    legend: { display: false },
                                    tooltip: {
                                        backgroundColor: c.surface,
                                        titleColor: c.text,
                                        bodyColor: c.text,
                                        borderColor: c.border,
                                        borderWidth: 1,
                                        padding: 10,
                                        cornerRadius: 10,
                                        callbacks: {
                                            label: function(ctx) {
                                                var pct = totalCount > 0 ? Math.round(ctx.raw / totalCount * 100) : 0;
                                                return ' ' + ctx.label + ': ' + ctx.raw + ' (' + pct + '%)';
                                            }
                                        }
                                    }
                                }
                            }
                        });
                    }
                }

                /* ── Bar: Sector Breakdown ── */
                var sc = document.getElementById('sectorChart');
                if (sc) {
                    if (sc.chart) sc.chart.destroy();
                    if (sectorLabels && sectorLabels.length > 0) {
                        var palette = ['#2563eb','#10b981','#f59e0b','#ef4444','#8b5cf6','#06b6d4','#ec4899','#64748b'];
                        var barColors = sectorLabels.map(function(_, i) { return palette[i % palette.length]; });
                        sc.chart = new Chart(sc, {
                            type: 'bar',
                            data: {
                                labels: sectorLabels,
                                datasets: [{
                                    label: 'Reports',
                                    data: sectorValues,
                                    backgroundColor: barColors.map(function(c) { return c + 'cc'; }),
                                    borderColor: barColors,
                                    borderWidth: 1.5,
                                    borderRadius: 8,
                                    borderSkipped: false
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: false },
                                    tooltip: {
                                        backgroundColor: c.surface,
                                        titleColor: c.text,
                                        bodyColor: c.text,
                                        borderColor: c.border,
                                        borderWidth: 1,
                                        padding: 10,
                                        cornerRadius: 10
                                    }
                                },
                                scales: {
                                    x: {
                                        grid: { display: false },
                                        ticks: { color: c.text, font: { size: 10, weight: '600' } }
                                    },
                                    y: {
                                        beginAtZero: true,
                                        grid: { color: c.grid },
                                        ticks: { color: c.text, precision: 0, font: { size: 10 } }
                                    }
                                }
                            }
                        });
                    }
                }

                /* ── Line: Daily Volume Trend ── */
                var lc = document.getElementById('dailyTrendChart');
                if (lc) {
                    if (lc.chart) lc.chart.destroy();
                    if (dailyLabels && dailyLabels.length > 0) {
                        lc.chart = new Chart(lc, {
                            type: 'line',
                            data: {
                                labels: dailyLabels,
                                datasets: [{
                                    label: 'Reports',
                                    data: dailyValues,
                                    borderColor: '#8b5cf6',
                                    backgroundColor: 'rgba(139,92,246,0.07)',
                                    borderWidth: 2.5,
                                    fill: true,
                                    tension: 0.4,
                                    pointRadius: 3,
                                    pointBackgroundColor: '#8b5cf6',
                                    pointBorderColor: c.surface,
                                    pointBorderWidth: 2,
                                    pointHoverRadius: 6,
                                    pointHoverBackgroundColor: '#8b5cf6',
                                    pointHoverBorderColor: c.surface
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: false },
                                    tooltip: {
                                        backgroundColor: c.surface,
                                        titleColor: c.text,
                                        bodyColor: c.text,
                                        borderColor: c.border,
                                        borderWidth: 1,
                                        padding: 10,
                                        cornerRadius: 10,
                                        mode: 'index',
                                        intersect: false
                                    }
                                },
                                scales: {
                                    x: {
                                        grid: { display: false },
                                        ticks: { color: c.text, font: { size: 10 } }
                                    },
                                    y: {
                                        beginAtZero: true,
                                        grid: { color: c.grid },
                                        ticks: { color: c.text, precision: 0, font: { size: 10 } }
                                    }
                                }
                            }
                        });
                    }
                }
            }

            // Animate confidence bars on load
            function animateConfBars() {
                ['confBuy', 'confSell', 'confHold', 'confOverall'].forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        var target = el.getAttribute('data-width');
                        setTimeout(function() {
                            el.style.width = target + '%';
                        }, 300);
                    }
                });
            }

            renderCharts();
            animateConfBars();

            // Re-render charts when theme toggles
            var themeObserver = new MutationObserver(function() {
                isDark = document.documentElement.getAttribute('data-bs-theme') === 'dark';
                renderCharts();
                animateConfBars();
            });
            themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-bs-theme'] });
        })();
    </script>
}
